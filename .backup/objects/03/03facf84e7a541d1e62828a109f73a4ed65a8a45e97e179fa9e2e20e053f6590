/* ============================================
   NovelFlow — 核心翻译引擎
   三层记忆系统 + 术语表 + 文风锚定
   ============================================ */

class TranslationEngine {
    constructor(config) {
        this.llm = new LLMAdapter(config.api);
        this.config = {
            targetLang: config.targetLang || '简体中文',
            novelType: config.novelType || '通用',
            windowSize: config.windowSize || 8,
            summaryInterval: config.summaryInterval || 20,
            temperature: config.temperature || 0.3,
            autoGlossary: config.autoGlossary !== false,
            autoStyle: config.autoStyle !== false,
        };

        // 核心状态
        this.glossary = new GlossaryManager();
        this.styleProfile = null;
        this.globalSummary = '';
        this.chapterSummaries = {};
        this.slidingWindow = []; // [{original, translation}]

        // 统计
        this.tokensInput = 0;
        this.tokensOutput = 0;
        this.completedSentences = 0;
        this.totalSentences = 0;

        // 控制
        this._paused = false;
        this._cancelled = false;
        this._onProgress = null; // callback(event, data)
    }

    /**
     * 翻译全书 — 主入口
     */
    async translateBook(chapters, onProgress) {
        this._onProgress = onProgress;
        this._cancelled = false;
        this._paused = false;
        this.totalSentences = chapters.reduce((sum, ch) => sum + ch.sentences.length, 0);
        this.completedSentences = 0;

        // === Phase 0: 预处理 ===
        this._emit('phase', { phase: 'preprocessing', message: '预处理中...' });

        // 收集全文前部分用于分析
        const allText = chapters.map(ch => ch.sentences.join(' ')).join('\n\n');
        const sampleText = allText.slice(0, 2500);

        // 文风分析
        if (this.config.autoStyle) {
            this._emit('phase', { phase: 'style', message: '分析文风...' });
            await this._analyzeStyle(sampleText);
        }

        // 术语提取
        if (this.config.autoGlossary) {
            this._emit('phase', { phase: 'glossary', message: '提取术语...' });
            await this._extractGlossary(allText);
        }

        // === Phase 1: 逐章翻译 ===
        this._emit('phase', { phase: 'translating', message: '开始翻译...' });

        const results = [];

        for (let chIdx = 0; chIdx < chapters.length; chIdx++) {
            await this._checkPauseCancel();
            const chapter = chapters[chIdx];

            this._emit('chapterStart', {
                chapterIndex: chIdx,
                title: chapter.title,
                sentenceCount: chapter.sentences.length,
            });

            // 保留跨章上下文（最后3句）
            if (this.slidingWindow.length > 3) {
                this.slidingWindow = this.slidingWindow.slice(-3);
            }

            const translatedSentences = [];
            const batchSize = this.config.summaryInterval;

            for (let i = 0; i < chapter.sentences.length; i++) {
                await this._checkPauseCancel();

                const sentence = chapter.sentences[i];

                // 构建上下文
                const windowText = this.slidingWindow.map(w => w.original + ' ' + w.translation).join(' ');
                const relevantTerms = this.glossary.getRelevant(sentence + ' ' + windowText);

                const context = {
                    chapterIndex: chIdx,
                    sentenceIndex: i,
                    slidingWindow: [...this.slidingWindow],
                    chapterSummary: this.chapterSummaries[chIdx] || '',
                    globalSummary: this.globalSummary,
                    relevantGlossary: relevantTerms,
                };

                // 翻译单句
                const result = await this._translateSentence(sentence, context);
                translatedSentences.push(result);

                // 更新滑动窗口
                this.slidingWindow.push({ original: sentence, translation: result.translation });
                if (this.slidingWindow.length > this.config.windowSize) {
                    this.slidingWindow.shift();
                }

                // 合并新术语
                if (result.newTerms && result.newTerms.length > 0) {
                    this.glossary.addBatch(result.newTerms);
                    this._emit('glossaryUpdate', { glossary: this.glossary });
                }

                this.completedSentences++;
                this._emit('sentenceComplete', {
                    chapterIndex: chIdx,
                    sentenceIndex: i,
                    original: sentence,
                    translation: result.translation,
                    completed: this.completedSentences,
                    total: this.totalSentences,
                    percent: Math.round(this.completedSentences / this.totalSentences * 100),
                    tokensIn: this.tokensInput,
                    tokensOut: this.tokensOutput,
                });

                // 每batch句生成摘要
                if ((i + 1) % batchSize === 0 || i === chapter.sentences.length - 1) {
                    const batchStart = Math.max(0, i - batchSize + 1);
                    const batchTranslations = translatedSentences.slice(batchStart).map(s => s.translation).join(' ');
                    await this._updateChapterSummary(chIdx, batchTranslations);
                }
            }

            // 章节完成 → 更新全局摘要
            await this._updateGlobalSummary();

            results.push({
                chapterIndex: chIdx,
                title: chapter.title,
                sentences: translatedSentences,
                summary: this.chapterSummaries[chIdx] || '',
            });

            this._emit('chapterComplete', {
                chapterIndex: chIdx,
                title: chapter.title,
            });
        }

        // === Phase 2: 完成 ===
        this._emit('complete', {
            chapters: results.length,
            sentences: this.completedSentences,
            tokensIn: this.tokensInput,
            tokensOut: this.tokensOutput,
            glossaryTerms: this.glossary.entries.length,
        });

        return results;
    }

    // ── 文风分析 ──

    async _analyzeStyle(sampleText) {
        const prompt = `你是资深文学评论家。请分析以下小说原文的文风特征。

输出严格JSON格式：
{"register":"语体","era_feel":"时代感","narrative_tone":"叙事语气","sentence_pattern":"句式","vocabulary":"用词","emotional_tone":"情感基调","translation_guidelines":["指导1","指导2","指导3"],"style_summary":"50字以内的文风总结"}

原文样本：
---
${sampleText.slice(0, 1800)}
---`;

        try {
            const res = await this.llm.chat(
                [
                    { role: 'system', content: '文学分析专家，严格输出JSON。不要输出其他内容。' },
                    { role: 'user', content: prompt }
                ],
                { temperature: 0.3, maxTokens: 500 }
            );

            this.tokensInput += res.usage.prompt_tokens || 0;
            this.tokensOutput += res.usage.completion_tokens || 0;

            const data = Utils.parseJSON(res.content);
            if (data) {
                this.styleProfile = data;
                this._emit('styleAnalyzed', { style: data });
            }
        } catch (e) {
            console.warn('文风分析失败:', e);
            this.styleProfile = {
                style_summary: '保持忠实原文的翻译风格，语言流畅自然。',
                translation_guidelines: ['忠实原文', '语言流畅', '风格统一'],
            };
            this._emit('styleAnalyzed', { style: this.styleProfile });
        }
    }

    // ── 术语提取 ──

    async _extractGlossary(fullText) {
        // 分块扫描（每块约3000字符，最多扫前5块）
        const chunkSize = 3000;
        const chunks = [];
        for (let i = 0; i < fullText.length && chunks.length < 5; i += chunkSize) {
            chunks.push(fullText.slice(i, i + chunkSize));
        }

        for (let i = 0; i < chunks.length; i++) {
            this._emit('phase', {
                phase: 'glossary',
                message: `提取术语... (${i + 1}/${chunks.length})`,
            });

            const prompt = `提取以下小说文本中的所有专有名词（人名、地名、组织名、物品、术语）。
识别同一实体的不同称呼。给出推荐中文翻译。

严格输出JSON：
{"terms":[{"original":"原文","translation":"译名","category":"character|location|item|organization|concept|other","aliases":["别名"],"context":"简述"}]}

文本：
---
${chunks[i]}
---`;

            try {
                const res = await this.llm.chat(
                    [
                        { role: 'system', content: 'NER专家，严格输出JSON。' },
                        { role: 'user', content: prompt }
                    ],
                    { temperature: 0.1, maxTokens: 800 }
                );

                this.tokensInput += res.usage.prompt_tokens || 0;
                this.tokensOutput += res.usage.completion_tokens || 0;

                const data = Utils.parseJSON(res.content);
                if (data && data.terms) {
                    this.glossary.addBatch(data.terms);
                }
            } catch (e) {
                console.warn(`术语提取块${i}失败:`, e);
            }
        }

        this._emit('glossaryUpdate', { glossary: this.glossary });
    }

    // ── 翻译单句 ──

    async _translateSentence(sentence, context) {
        const messages = this._buildPrompt(sentence, context);

        // 带重试 + 自动暂停
        let lastError;
        for (let attempt = 0; attempt < 3; attempt++) {
            await this._checkPauseCancel();
            try {
                const res = await this.llm.chat(messages, {
                    temperature: this.config.temperature,
                    maxTokens: 500,
                });

                this.tokensInput += res.usage.prompt_tokens || 0;
                this.tokensOutput += res.usage.completion_tokens || 0;
                this._consecutiveErrors = 0; // 重置连续错误计数

                return this._parseTranslationResponse(res.content, sentence);
            } catch (e) {
                lastError = e;
                console.warn(`翻译重试 ${attempt + 1}/3:`, e.message);

                this._emit('error', {
                    type: 'api',
                    message: e.message,
                    attempt: attempt + 1,
                    maxAttempts: 3,
                    sentence: sentence.slice(0, 50),
                });

                if (attempt < 2) {
                    const delay = 3000 * (attempt + 1);
                    this._emit('phase', {
                        phase: 'retrying',
                        message: `API错误，${delay / 1000}秒后重试 (${attempt + 1}/3)...`,
                    });
                    await Utils.sleep(delay);
                }
            }
        }

        // 3次重试全部失败 → 自动暂停，等待用户处理
        this._consecutiveErrors = (this._consecutiveErrors || 0) + 1;

        if (this._consecutiveErrors >= 2) {
            // 连续2句都失败，自动暂停
            this._paused = true;
            this._emit('autoPaused', {
                reason: 'api_error',
                message: `API连续失败: ${lastError.message}`,
                hint: '请检查API Key/余额/网络后点击"继续"',
                consecutiveErrors: this._consecutiveErrors,
            });

            // 等待用户手动恢复
            await this._checkPauseCancel();

            // 恢复后重试一次
            try {
                const res = await this.llm.chat(messages, {
                    temperature: this.config.temperature,
                    maxTokens: 500,
                });
                this.tokensInput += res.usage.prompt_tokens || 0;
                this.tokensOutput += res.usage.completion_tokens || 0;
                this._consecutiveErrors = 0;
                return this._parseTranslationResponse(res.content, sentence);
            } catch (e) {
                lastError = e;
            }
        }

        // 最终失败，标记但继续
        console.error('翻译失败:', lastError);
        this._emit('error', {
            type: 'translate_failed',
            message: `句子翻译失败: ${lastError.message}`,
            sentence: sentence.slice(0, 80),
        });
        return { original: sentence, translation: `[翻译失败] ${sentence}`, newTerms: [], failed: true };
    }

    // ── 构建Prompt ──

    _buildPrompt(sentence, context) {
        const style = this.styleProfile;
        const styleText = style?.style_summary || '保持忠实、流畅、一致的翻译风格。';
        const guidelines = (style?.translation_guidelines || ['忠实原文', '语言流畅', '风格统一'])
            .map((g, i) => `  ${i + 1}. ${g}`).join('\n');

        const typeHints = {
            '奇幻': '庄重典雅，带有史诗感。',
            '科幻': '精确冷峻，技术描述准确严谨。',
            '文学': '细腻深沉，注重心理描写层次。',
            '言情': '温柔流畅，情感表达细腻饱满。',
        };
        const typeHint = typeHints[this.config.novelType] || '';

        const systemPrompt = `你是专业文学翻译家，正在翻译外国小说为${this.config.targetLang}。

【文风】${styleText}${typeHint ? ' ' + typeHint : ''}
${guidelines}

【原则】严格使用术语表译名；保持文风一致；忠实原文不增删；保留修辞手法。`;

        // User prompt 多层上下文
        const parts = [];

        // L1: 术语表
        const glossaryText = this.glossary.toPromptText(context.relevantGlossary);
        if (glossaryText) parts.push(glossaryText);

        // L1: 全局摘要
        if (context.globalSummary) {
            parts.push(`【故事背景】\n${context.globalSummary}`);
        }

        // L2: 章节摘要
        if (context.chapterSummary) {
            parts.push(`【章节概要】\n${context.chapterSummary}`);
        }

        // L3: 滑动窗口
        if (context.slidingWindow.length > 0) {
            const windowLines = context.slidingWindow
                .slice(-this.config.windowSize)
                .map(w => `原: ${w.original}\n译: ${w.translation}`)
                .join('\n');
            parts.push(`【前文对照】\n${windowLines}`);
        }

        // L4: 当前句
        parts.push(`【待翻译】\n${sentence}`);

        // 指令
        parts.push('只输出译文。如有新专有名词，另起一行：\nNEW_TERMS: [{"original":"...","translation":"...","category":"..."}]');

        return [
            { role: 'system', content: systemPrompt },
            { role: 'user', content: parts.join('\n\n') },
        ];
    }

    // ── 解析翻译响应 ──

    _parseTranslationResponse(response, original) {
        let translation = response.trim();
        let newTerms = [];

        if (translation.includes('NEW_TERMS:')) {
            const parts = translation.split('NEW_TERMS:');
            translation = parts[0].trim();
            try {
                const arrMatch = parts[1].match(/\[[\s\S]*\]/);
                if (arrMatch) {
                    newTerms = JSON.parse(arrMatch[0]);
                }
            } catch (e) {}
        }

        return { original, translation, newTerms };
    }

    // ── 摘要生成 ──

    async _updateChapterSummary(chIdx, newText) {
        const existing = this.chapterSummaries[chIdx] || '';
        const prompt = `为以下译文生成摘要（100字以内）。包含：情节、人物、场景、情感。
${existing ? '已有摘要：' + existing + '\n' : ''}
译文：${newText.slice(0, 1200)}

摘要：`;

        try {
            const res = await this.llm.chat(
                [{ role: 'system', content: '摘要专家，100字以内。' }, { role: 'user', content: prompt }],
                { temperature: 0.2, maxTokens: 200 }
            );
            this.tokensInput += res.usage.prompt_tokens || 0;
            this.tokensOutput += res.usage.completion_tokens || 0;
            this.chapterSummaries[chIdx] = res.content.trim().slice(0, 150);
            this._emit('summaryUpdate', {
                type: 'chapter',
                chapterIndex: chIdx,
                summary: this.chapterSummaries[chIdx],
            });
        } catch (e) {
            console.warn('章节摘要生成失败:', e);
        }
    }

    async _updateGlobalSummary() {
        const allSum = Object.entries(this.chapterSummaries)
            .sort(([a], [b]) => Number(a) - Number(b))
            .map(([k, v]) => `第${Number(k) + 1}章: ${v}`)
            .join('\n');

        if (!allSum) return;

        try {
            const res = await this.llm.chat(
                [
                    { role: 'system', content: '摘要专家。' },
                    { role: 'user', content: `合并为全局摘要（200字以内）：\n${allSum}` }
                ],
                { temperature: 0.2, maxTokens: 300 }
            );
            this.tokensInput += res.usage.prompt_tokens || 0;
            this.tokensOutput += res.usage.completion_tokens || 0;
            this.globalSummary = res.content.trim().slice(0, 250);
            this._emit('summaryUpdate', { type: 'global', summary: this.globalSummary });
        } catch (e) {
            console.warn('全局摘要生成失败:', e);
        }
    }

    // ── 控制 ──

    pause() { this._paused = true; }
    resume() { this._paused = false; }
    cancel() { this._cancelled = true; }

    async _checkPauseCancel() {
        if (this._cancelled) throw new Error('CANCELLED');
        while (this._paused) {
            await Utils.sleep(300);
            if (this._cancelled) throw new Error('CANCELLED');
        }
    }

    _emit(event, data) {
        if (this._onProgress) {
            try { this._onProgress(event, data); } catch (e) { console.warn('Progress callback error:', e); }
        }
    }
}
