/* NovelFlow — 现代高级极简主题 */
:root {
    --paper-lightest: #ffffff;
    --paper-light: #faf9f7;
    --paper-base: #f5f4f0;
    --paper-mid: #ebebe9;
    --paper-dark: #d6d6d4;
    --paper-darker: #adadab;
    --paper-darkest: #828280;
    --text-primary: #1d1d1f;
    --text-secondary: #424245;
    --text-dim: #86868b;
    --text-on-accent: #ffffff;
    --accent: #2c6e49;
    --accent-hover: #4c956c;
    --accent-light: rgba(44,110,73,0.1);
    --accent-glow: rgba(44,110,73,0.25);
    --success: #34c759;
    --warning: #f5a623;
    --danger: #ff3b30;
    --info: #007aff;
    --cat-char: #2c6e49;--cat-loc: #4a90e2;--cat-item: #f5a623;--cat-org: #d0021b;--cat-concept: #9013fe;--cat-other: #8b572a;
    --border-light: rgba(0,0,0,0.06);
    --border-mid: rgba(0,0,0,0.12);
    --border-strong: rgba(0,0,0,0.2);
    --shadow-sm: 0 2px 8px rgba(0,0,0,0.04);
    --shadow-md: 0 8px 24px rgba(0,0,0,0.08);
    --shadow-lg: 0 16px 48px rgba(0,0,0,0.12);
    --shadow-book: 0 4px 16px rgba(0,0,0,0.05), 0 1px 4px rgba(0,0,0,0.03);
    --r-sm: 8px;
    --r-md: 14px;
    --r-lg: 20px;
    --font-body: 'Noto Serif SC', 'LXGW WenKai Screen', Georgia, serif;
    --font-heading: 'Noto Serif SC', 'LXGW WenKai Screen', Georgia, serif;
    --font-mono: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
    --font-ui: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    --sp-xs: 6px;--sp-sm: 12px;--sp-md: 20px;--sp-lg: 32px;--sp-xl: 48px;
    --ease: cubic-bezier(0.25, 1, 0.5, 1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:16px;-webkit-text-size-adjust:100%;scroll-behavior:smooth}
body{font-family:var(--font-ui);color:var(--text-primary);line-height:1.6;min-height:100vh;
    background-color:var(--paper-light);
}
/* ── 顶栏 ── */
.topbar{position:sticky;top:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:14px 24px;
    background:rgba(255,255,255,0.88);backdrop-filter:saturate(180%) blur(20px);-webkit-backdrop-filter:saturate(180%) blur(20px);
    border-bottom:1px solid var(--border-light);box-shadow:0 1px 0 rgba(0,0,0,0.04)}
.topbar-left{display:flex;align-items:center;gap:12px}
.topbar-logo{font-size:1.4rem;filter:drop-shadow(0 1px 2px rgba(0,0,0,0.1))}
.topbar-title{font-family:var(--font-heading);font-size:1.15rem;font-weight:700;color:var(--accent);letter-spacing:.3px}
.topbar-sub{font-family:var(--font-ui);font-size:.72rem;color:var(--text-dim);padding-left:8px;border-left:1.5px solid var(--border-mid);font-weight:500}
.topbar-right{display:flex;gap:10px}
.tb-btn{background:var(--paper-base);border:none;border-radius:50%;width:38px;height:38px;display:flex;align-items:center;justify-content:center;font-size:1.05rem;cursor:pointer;transition:all .25s var(--ease)}
.tb-btn:hover{background:var(--accent-light);transform:scale(1.08)}
.tb-btn:active{transform:scale(0.95)}

/* ── 容器与基础 ── */
.app-container{max-width:960px;margin:0 auto;padding:var(--sp-lg) var(--sp-md);min-height:calc(100vh - 60px)}
.page{animation:fadeIn .4s var(--ease)}.hidden{display:none!important}
@keyframes fadeIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

/* ── 按钮系统 ── */
.btn-paper{font-family:var(--font-ui);display:inline-flex;align-items:center;gap:8px;padding:10px 22px;
    border:none;border-radius:var(--r-md);background:var(--paper-base);color:var(--text-primary);
    font-size:.875rem;font-weight:600;cursor:pointer;transition:all .25s var(--ease);
    box-shadow:none;position:relative;overflow:hidden}
.btn-paper:hover{background:var(--paper-mid);transform:translateY(-1px);box-shadow:var(--shadow-sm)}
.btn-paper:active{transform:translateY(0);box-shadow:none}
.btn-paper.btn-accent{background:var(--accent);color:var(--text-on-accent)}
.btn-paper.btn-accent:hover{background:var(--accent-hover);box-shadow:0 4px 20px var(--accent-glow);transform:translateY(-2px)}
.btn-paper.btn-danger{color:var(--danger);background:rgba(255,59,48,0.08)}
.btn-paper.btn-danger:hover{background:var(--danger);color:var(--text-on-accent)}
.btn-paper.btn-sm{padding:7px 14px;font-size:.78rem;border-radius:var(--r-sm)}
.btn-paper.btn-lg{padding:14px 32px;font-size:1rem;border-radius:var(--r-lg)}
.btn-link{background:none;border:none;color:var(--accent);font-family:var(--font-ui);font-size:.875rem;font-weight:600;cursor:pointer;padding:6px 2px;transition:all .2s}
.btn-link:hover{color:var(--accent-hover);text-decoration:none;opacity:.8}
.page-back{margin-bottom:var(--sp-md)}

/* ── 表单控件 ── */
select,input[type="text"],input[type="password"],input[type="number"]{
    font-family:var(--font-ui);padding:10px 14px;border:1.5px solid var(--border-mid);border-radius:var(--r-sm);
    background:var(--paper-lightest);color:var(--text-primary);font-size:.875rem;outline:none;
    transition:all .2s var(--ease);width:100%;-webkit-appearance:none;appearance:none}
select:focus,input:focus{border-color:var(--accent);box-shadow:0 0 0 4px var(--accent-light)}
input[type="checkbox"]{accent-color:var(--accent);width:20px;height:20px;cursor:pointer;border-radius:6px}
label{font-family:var(--font-ui);font-size:.78rem;font-weight:600;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.6px}

/* ── 滚动条 ── */
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--paper-dark);border-radius:10px}::-webkit-scrollbar-thumb:hover{background:var(--paper-darker)}

/* ── 响应式 ── */
@media(max-width:640px){.app-container{padding:var(--sp-md) var(--sp-sm)}.topbar{padding:12px 16px}.topbar-sub{display:none}}
