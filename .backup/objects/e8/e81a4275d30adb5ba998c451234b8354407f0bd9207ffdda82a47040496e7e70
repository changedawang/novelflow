    /* ── 沉浸式阅读器 ── */
    _openReader(book) {
        this.currentBookId = book.id;
        this._rdBook = book;
        this._rdChIdx = 0;
        const p = Utils.loadLocal('rd-prefs', {fs:18,lh:1.8,theme:'light',mode:'translated'});
        this._rdPrefs = p;
        this._rdMode = p.mode||'translated';
        const pg = document.getElementById('page-reader');
        pg.setAttribute('data-theme', p.theme||'light');
        pg.style.setProperty('--rd-fs', p.fs+'px');
        pg.style.setProperty('--rd-lh', p.lh);
        document.getElementById('reader-title').textContent = book.fileName;
        document.getElementById('rd-font-val').textContent = p.fs;
        document.getElementById('rd-lh-val').textContent = p.lh;
        document.querySelectorAll('.rd-mode-btn').forEach(b=>b.classList.toggle('active',b.dataset.rmode===this._rdMode));
        document.querySelectorAll('.rd-theme-dot').forEach(b=>b.classList.toggle('active',b.dataset.rtheme===(p.theme||'light')));
        this._updateThemeLabel();
        this._applyFont(p.font || 'serif');
        this._renderToc();
        this._goChapter(0);
        this._showPage('reader');
        // 关闭面板
        document.getElementById('rd-display-panel').classList.add('hidden');
        document.getElementById('rd-toc-overlay').classList.add('hidden');
    }
    _fontMap = {
        serif:"'Noto Serif SC',Georgia,serif",
        wenkai:"'LXGW WenKai Screen',cursive",
        xiaowei:"'ZCOOL XiaoWei',serif",
        mashanzheng:"'Ma Shan Zheng',cursive",
        longcang:"'Long Cang',cursive",
        system:"-apple-system,'Segoe UI','Noto Sans SC',sans-serif",
    };
    _saveRdPrefs(){Utils.saveLocal('rd-prefs',this._rdPrefs);}
    _applyFont(fontKey){
        const ff = this._fontMap[fontKey] || this._fontMap.serif;
        document.getElementById('page-reader').style.setProperty('--rd-ff', ff);
        document.getElementById('rd-content').style.fontFamily = ff;
        document.querySelectorAll('.rd-font-btn').forEach(b=>b.classList.toggle('active',b.dataset.rfont===fontKey));
    }
    _updateThemeLabel(){
        const t=this._rdPrefs.theme||'light';
        const dark=t==='dark'||t==='black';
        document.getElementById('rd-theme-label').textContent=dark?'日间':'夜间';
        document.querySelector('#btn-rd-theme .rd-tool-icon').textContent=dark?'☀️':'🌙';
    }
    _renderToc(){
        const b=this._rdBook; if(!b||!b.results)return;
        document.getElementById('rd-toc-list').innerHTML=b.results.map((ch,i)=>
            `<button class="rd-toc-item${i===this._rdChIdx?' active':''}" data-ch="${i}">${Utils.escapeHtml(ch.title||'第'+(i+1)+'章')}</button>`
        ).join('');
    }
    _goChapter(idx){
        const b=this._rdBook; if(!b||!b.results)return;
        const total=b.results.length;
        if(idx<0||idx>=total)return;
        this._rdChIdx=idx;
        const ch=b.results[idx];
        document.getElementById('rd-chapter-title').textContent=ch.title||'第'+(idx+1)+'章';
        document.getElementById('rd-ch-ind').textContent=(idx+1)+'/'+total;
        document.getElementById('rd-progress-fill').style.width=Math.round((idx+1)/total*100)+'%';
        this._renderChContent(ch);
        document.getElementById('rd-content').scrollTop=0;
        this._renderToc();
    }
    _renderChContent(ch){
        const body=document.getElementById('reader-body');
        const m=this._rdMode; let h='';
        for(const s of ch.sentences){
            if(m==='bilingual') h+=`<div class="reader-para"><div class="reader-tgt">${Utils.escapeHtml(s.translation)}</div><div class="reader-src">${Utils.escapeHtml(s.original)}</div></div>`;
            else if(m==='translated') h+=`<div class="reader-para"><div class="reader-tgt">${Utils.escapeHtml(s.translation)}</div></div>`;
            else h+=`<div class="reader-para"><div class="reader-src" style="opacity:1;color:var(--rd-text)">${Utils.escapeHtml(s.original)}</div></div>`;
        }
        body.innerHTML=h;
    }
    _bindReader() {
        // 返回/导出/删除
        document.getElementById('btn-reader-back').addEventListener('click',()=>{this._showPage('shelf');this._renderShelf();});
        document.getElementById('btn-reader-export').addEventListener('click',()=>document.getElementById('modal-export').classList.remove('hidden'));
        document.getElementById('btn-reader-delete').addEventListener('click',()=>{
            if(confirm('确定删除这本书？')){this._deleteBook(this.currentBookId);this._showPage('shelf');this._renderShelf();}
        });
        // 上下章
        document.getElementById('btn-prev-ch').addEventListener('click',()=>this._goChapter(this._rdChIdx-1));
        document.getElementById('btn-next-ch').addEventListener('click',()=>this._goChapter(this._rdChIdx+1));
        // 目录
        document.getElementById('btn-rd-toc').addEventListener('click',()=>{
            document.getElementById('rd-display-panel').classList.add('hidden');
            document.getElementById('rd-toc-overlay').classList.remove('hidden');
        });
        document.getElementById('btn-close-toc').addEventListener('click',()=>document.getElementById('rd-toc-overlay').classList.add('hidden'));
        document.getElementById('rd-toc-overlay').addEventListener('click',e=>{if(e.target.id==='rd-toc-overlay')e.target.classList.add('hidden');});
        document.getElementById('rd-toc-list').addEventListener('click',e=>{
            const btn=e.target.closest('.rd-toc-item'); if(!btn)return;
            this._goChapter(parseInt(btn.dataset.ch));
            document.getElementById('rd-toc-overlay').classList.add('hidden');
        });
        // 日间/夜间快速切换
        document.getElementById('btn-rd-theme').addEventListener('click',()=>{
            const cur=this._rdPrefs.theme||'light';
            const dark=cur==='dark'||cur==='black';
            this._rdPrefs.theme=dark?'light':'dark';
            document.getElementById('page-reader').setAttribute('data-theme',this._rdPrefs.theme);
            document.querySelectorAll('.rd-theme-dot').forEach(b=>b.classList.toggle('active',b.dataset.rtheme===this._rdPrefs.theme));
            this._updateThemeLabel(); this._saveRdPrefs();
        });
        // 显示设置面板
        document.getElementById('btn-rd-display').addEventListener('click',()=>{
            document.getElementById('rd-toc-overlay').classList.add('hidden');
            document.getElementById('rd-display-panel').classList.toggle('hidden');
        });
        // 字号
        document.getElementById('btn-font-up').addEventListener('click',()=>{
            this._rdPrefs.fs=Math.min(32,(this._rdPrefs.fs||18)+2);
            document.getElementById('page-reader').style.setProperty('--rd-fs',this._rdPrefs.fs+'px');
            document.getElementById('rd-font-val').textContent=this._rdPrefs.fs; this._saveRdPrefs();
        });
        document.getElementById('btn-font-down').addEventListener('click',()=>{
            this._rdPrefs.fs=Math.max(12,(this._rdPrefs.fs||18)-2);
            document.getElementById('page-reader').style.setProperty('--rd-fs',this._rdPrefs.fs+'px');
            document.getElementById('rd-font-val').textContent=this._rdPrefs.fs; this._saveRdPrefs();
        });
        // 行距
        document.getElementById('btn-lh-up').addEventListener('click',()=>{
            this._rdPrefs.lh=Math.min(3,Math.round(((this._rdPrefs.lh||1.8)+0.2)*10)/10);
            document.getElementById('page-reader').style.setProperty('--rd-lh',this._rdPrefs.lh);
            document.getElementById('rd-lh-val').textContent=this._rdPrefs.lh; this._saveRdPrefs();
        });
        document.getElementById('btn-lh-down').addEventListener('click',()=>{
            this._rdPrefs.lh=Math.max(1.2,Math.round(((this._rdPrefs.lh||1.8)-0.2)*10)/10);
            document.getElementById('page-reader').style.setProperty('--rd-lh',this._rdPrefs.lh);
            document.getElementById('rd-lh-val').textContent=this._rdPrefs.lh; this._saveRdPrefs();
        });
        // 阅读模式切换
        document.querySelectorAll('.rd-mode-btn').forEach(btn=>{
            btn.addEventListener('click',()=>{
                document.querySelectorAll('.rd-mode-btn').forEach(b=>b.classList.remove('active'));
                btn.classList.add('active');
                this._rdMode=btn.dataset.rmode; this._rdPrefs.mode=this._rdMode; this._saveRdPrefs();
                const b=this._rdBook; if(b&&b.results&&b.results[this._rdChIdx]) this._renderChContent(b.results[this._rdChIdx]);
            });
        });
        // 主题色点
        document.querySelectorAll('.rd-theme-dot').forEach(dot=>{
            dot.addEventListener('click',()=>{
                document.querySelectorAll('.rd-theme-dot').forEach(d=>d.classList.remove('active'));
                dot.classList.add('active');
                this._rdPrefs.theme=dot.dataset.rtheme;
                document.getElementById('page-reader').setAttribute('data-theme',this._rdPrefs.theme);
                this._updateThemeLabel(); this._saveRdPrefs();
            });
        });
        // 字体切换
        document.getElementById('rd-font-list').addEventListener('click',e=>{
            const btn=e.target.closest('.rd-font-btn'); if(!btn)return;
            this._rdPrefs.font=btn.dataset.rfont;
            this._applyFont(btn.dataset.rfont);
            this._saveRdPrefs();
        });
        // 设置按钮 → 打开API设置
        document.getElementById('btn-rd-settings2').addEventListener('click',()=>this._openSettingsModal());
        // 点击内容区域切换工具栏显隐
        document.getElementById('rd-content').addEventListener('click',e=>{
            if(e.target.closest('.rd-display-panel')||e.target.closest('.rd-toc-overlay'))return;
            document.getElementById('rd-display-panel').classList.add('hidden');
            const top=document.getElementById('rd-topbar'),bot=document.getElementById('rd-bottombar');
            top.classList.toggle('hid'); bot.classList.toggle('hid');
        });
    }

    /* ── 弹窗绑定 ── */
    _bindModals() {
        // 设置保存
        document.getElementById('api-provider').addEventListener('change',()=>this._toggleCustomUrl());
        document.getElementById('api-reasoning').addEventListener('change',()=>this._toggleCustomTemp());
        document.getElementById('api-keys').addEventListener('input',()=>this._updateKeyCountHint());

        // 获取模型按钮
        document.getElementById('btn-fetch-models').addEventListener('click', async ()=>{
            const btn = document.getElementById('btn-fetch-models');
            const hint = document.getElementById('model-fetch-hint');
            const sel = document.getElementById('api-model-select');
            const inp = document.getElementById('api-model');

            // 取当前填写的key和base
            const keys = document.getElementById('api-keys').value.split('\n').map(k=>k.trim()).filter(k=>k);
            if(keys.length===0){ hint.style.display='block'; hint.textContent='⚠️ 请先填写至少一个API密钥'; hint.style.color='#c00'; return; }

            const provider = document.getElementById('api-provider').value;
            const urls = { 'deepseek':'https://api.deepseek.com/v1', 'openai':'https://api.openai.com/v1' };
            const baseUrl = provider==='custom' ? document.getElementById('api-base-url').value.replace(/\/+$/,'') : (urls[provider]||urls['deepseek']);

            btn.disabled = true;
            btn.textContent = '⏳ 获取中...';
            hint.style.display = 'block';
            hint.style.color = 'var(--text-dim)';
            hint.textContent = '正在连接API获取模型列表...';

            try {
                const adapter = new LLMAdapter({ apiKey: keys[0], baseUrl, provider });
                const models = await adapter.fetchModels(baseUrl, keys[0]);
                if(!models || models.length===0) throw new Error('返回模型列表为空');

                // 填充select
                sel.innerHTML = '';
                const currentModel = inp.value.trim();
                let hasCurrentModel = false;
                for(const m of models){
                    const opt = document.createElement('option');
                    opt.value = m; opt.textContent = m;
                    if(m === currentModel) { opt.selected = true; hasCurrentModel = true; }
                    sel.appendChild(opt);
                }
                if(!hasCurrentModel && currentModel){
                    // 保留手动输入的模型作为首选项
                    const opt = document.createElement('option');
                    opt.value = currentModel; opt.textContent = currentModel + ' (手动)';
                    opt.selected = true;
                    sel.insertBefore(opt, sel.firstChild);
                }
                // 切换：显示select，隐藏input
                sel.style.display = '';
                inp.style.display = 'none';
                // select变化时同步到input
                sel.onchange = ()=>{ inp.value = sel.value; };
                if(sel.value) inp.value = sel.value;

                hint.style.color = '#2a7';
                hint.textContent = `✅ 获取到 ${models.length} 个模型`;
                btn.textContent = '🔄 刷新模型';
            } catch(e) {
                hint.style.color = '#c00';
                hint.textContent = `❌ ${e.message}`;
                // 保持input模式
                sel.style.display = 'none';
                inp.style.display = '';
                btn.textContent = '📡 获取模型';
            } finally {
                btn.disabled = false;
            }
        });

        // select ↔ input 切换：双击select可恢复手动输入
        document.getElementById('api-model-select').addEventListener('dblclick', ()=>{
            document.getElementById('api-model-select').style.display = 'none';
            document.getElementById('api-model').style.display = '';
            document.getElementById('model-fetch-hint').textContent = '已切换回手动输入模式';
            document.getElementById('model-fetch-hint').style.color = 'var(--text-dim)';
            document.getElementById('btn-fetch-models').textContent = '📡 获取模型';
        });

        document.getElementById('btn-save-settings').addEventListener('click',()=>{
            const apiKeys = document.getElementById('api-keys').value.split('\n').map(k=>k.trim()).filter(k=>k);
            if(apiKeys.length===0){alert('请至少填写一个API密钥');return;}
            const reasoning = document.getElementById('api-reasoning').value;
            let temperature;
            if(reasoning==='custom'){
                temperature = parseFloat(document.getElementById('api-temp').value)||0.3;
            } else {
                temperature = this._reasoningToTemp(reasoning) || 0.3;
            }
            // 模型：优先select值（如果可见），否则取input值
            const sel = document.getElementById('api-model-select');
            const inp = document.getElementById('api-model');
            const model = (sel.style.display !== 'none' && sel.value) ? sel.value : inp.value;
            this.settings={
                provider:document.getElementById('api-provider').value,
                apiKeys,
                baseUrl:document.getElementById('api-base-url').value,
                model: model || 'deepseek-chat',
                reasoning,
                temperature,
                maxTokens:parseInt(document.getElementById('api-max-tokens').value)||1024
            };
            Utils.saveLocal('settings',this.settings);
            document.getElementById('modal-settings').classList.add('hidden');
        });
        // 添加术语
        document.getElementById('btn-add-term').addEventListener('click',()=>document.getElementById('modal-add-term').classList.remove('hidden'));
        document.getElementById('btn-confirm-term').addEventListener('click',()=>{
            const src=document.getElementById('term-src').value.trim(),tgt=document.getElementById('term-tgt').value.trim(),cat=document.getElementById('term-cat').value;
            if(!src||!tgt){alert('请填写原文和译文');return;}
            if(this.engine){this.engine.glossary.addOrUpdate({original:src,translation:tgt,category:cat,source:'manual'});this._renderGlossary(this.engine.glossary);}
            document.getElementById('term-src').value='';document.getElementById('term-tgt').value='';
            document.getElementById('modal-add-term').classList.add('hidden');
        });
        // 导入术语
        document.getElementById('btn-import-gl').addEventListener('click',()=>{
            const input=document.createElement('input');input.type='file';input.accept='.json';
            input.addEventListener('change',()=>{
                if(!input.files[0])return;
                const r=new FileReader();r.onload=()=>{
                    try{const data=JSON.parse(r.result);if(this.engine){if(data.entries)this.engine.glossary.fromJSON(data);else if(Array.isArray(data))this.engine.glossary.addBatch(data);this._renderGlossary(this.engine.glossary);}}catch(e){alert('JSON格式错误');}
                };r.readAsText(input.files[0]);
            });input.click();
        });
        // 导出
        document.querySelectorAll('.export-item').forEach(item=>{
            item.addEventListener('click',()=>{
                const fmt=item.dataset.fmt;
                const book=this._getBook(this.currentBookId);
                const results=book?book.results:this.translationResults;
                if(!results||results.length===0){alert('没有可导出的内容');return;}
                const name=book?book.fileName:'export';
                if(fmt==='txt'){
                    const txt=results.map(ch=>ch.title+'\n\n'+ch.sentences.map(s=>s.translation).join('\n')).join('\n\n---\n\n');
                    Utils.downloadFile(txt,name+'_译文.txt');
                }else if(fmt==='bilingual'){
                    const txt=results.map(ch=>ch.title+'\n\n'+ch.sentences.map(s=>'[原] '+s.original+'\n[译] '+s.translation).join('\n\n')).join('\n\n---\n\n');
                    Utils.downloadFile(txt,name+'_双语.txt');
                }else if(fmt==='json'){
                    Utils.downloadFile(JSON.stringify(book||{results},null,2),name+'_完整.json','application/json');
                }else if(fmt==='glossary'){
                    const gl=book&&book.glossary?book.glossary:(this.engine?this.engine.glossary.toJSON():{entries:[]});
                    Utils.downloadFile(JSON.stringify(gl,null,2),name+'_术语表.json','application/json');
                }
                document.getElementById('modal-export').classList.add('hidden');
            });
        });
        // 点击背景关闭弹窗
        document.querySelectorAll('.modal-bg').forEach(bg=>{
            bg.addEventListener('click',e=>{if(e.target===bg)bg.classList.add('hidden');});
        });
    }
} /* end UIController */
