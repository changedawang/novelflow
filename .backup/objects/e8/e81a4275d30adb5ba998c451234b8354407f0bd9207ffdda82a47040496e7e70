    _processText(text) {
        const splitter = new TextSplitter();
        this.chapters = splitter.parse(text);
        const totalSent = this.chapters.reduce((s,c)=>s+c.sentences.length,0);
        const totalChars = text.length;
        document.getElementById('cfg-filename').textContent = this.fileName;
        document.getElementById('cfg-chars').textContent = Utils.formatNumber(totalChars);
        document.getElementById('cfg-sentences').textContent = totalSent;
        document.getElementById('cfg-chapters').textContent = this.chapters.length;
        document.getElementById('cfg-tokens').textContent = Utils.formatNumber(totalSent * 1650);
        document.getElementById('cfg-preview').textContent = text.slice(0,500) + (text.length>500?'...':'');
        this._showPage('config');
    }

    /* ── 配置绑定 ── */
    _bindConfig() {
        document.getElementById('btn-start-translate').addEventListener('click', () => this._startTranslation());
    }
    _startTranslation() {
        if(!this.settings.apiKeys||this.settings.apiKeys.length===0){ alert('请先在设置中填写API密钥'); this._openSettingsModal(); return; }
        if(!this.chapters || this.chapters.length===0){ alert('没有可翻译的内容'); return; }
        const bookId = Utils.uid();
        this.currentBookId = bookId;
        this.translationResults = [];
        const totalSent = this.chapters.reduce((s,c)=>s+c.sentences.length,0);
        const book = {
            id: bookId, fileName: this.fileName,
            targetLang: document.getElementById('cfg-lang').value,
            chapters: this.chapters, results: [], glossary: null, styleProfile: null,
            globalSummary:'', chapterSummaries:{}, tokensIn:0, tokensOut:0,
            completed:0, total:totalSent, status:'translating',
            createdAt: Date.now(), updatedAt: Date.now()
        };
        this._saveBook(book);
        this._launchEngine(book);
    }

    _resumeBook(book) {
        this.currentBookId = book.id;
        this.fileName = book.fileName;
        this.chapters = book.chapters;
        this.translationResults = book.results || [];
        book.status = 'translating';
        book.updatedAt = Date.now();
        this._saveBook(book);
        this._launchEngine(book);
    }

    _launchEngine(book) {
        document.getElementById('work-title').textContent = book.fileName;
        document.getElementById('src-list').innerHTML = '';
        document.getElementById('tgt-list').innerHTML = '';
        document.getElementById('done-banner').classList.add('hidden');
        document.getElementById('pause-bar').classList.remove('show');
        this._setDot('active');
        this._showPage('work');
        // 恢复已翻译的UI
        if(book.results && book.results.length>0){
            for(const ch of book.results){
                for(const s of ch.sentences){
                    this._addSentRow(s.original, s.translation, s.failed);
                }
            }
        }
        const s = this.settings;
        const cfg = {
            api:{ apiKeys:s.apiKeys, model:s.model, baseUrl:s.baseUrl, provider:s.provider },
            targetLang: book.targetLang,
            windowSize: parseInt(document.getElementById('cfg-window').value)||8,
            temperature: parseFloat(s.temperature)||0.3,
            autoGlossary: document.getElementById('cfg-glossary').checked,
            autoStyle: document.getElementById('cfg-style').checked,
        };
        this.engine = new TranslationEngine(cfg);
        // 恢复引擎状态
        if(book.glossary) this.engine.glossary.fromJSON(book.glossary);
        if(book.styleProfile) this.engine.styleProfile = book.styleProfile;
        if(book.globalSummary) this.engine.globalSummary = book.globalSummary;
        if(book.chapterSummaries) this.engine.chapterSummaries = book.chapterSummaries;
        this.engine.tokensInput = book.tokensIn||0;
        this.engine.tokensOutput = book.tokensOut||0;
        this.engine.completedSentences = book.completed||0;

        // 计算剩余章节
        const doneChapters = (book.results||[]).length;
        const remaining = this.chapters.slice(doneChapters);
        this.engine.totalSentences = this.chapters.reduce((s,c)=>s+c.sentences.length,0);

        this.engine.translateBook(remaining, (ev,d) => this._onProgress(ev,d))
            .then(results => {
                this.translationResults = [...(book.results||[]), ...results];
                this._onComplete();
            })
            .catch(err => {
                if(err.message==='CANCELLED'){ this._onCancelled(); }
                else { console.error(err); alert('翻译错误: '+err.message); }
            });
    }

    /* ── 进度回调 ── */
    _onProgress(ev, d) {
        const book = this._getBook(this.currentBookId);
        if(!book) return;
        switch(ev) {
            case 'phase':
                document.getElementById('ws-phase').textContent = d.message||d.phase;
                break;
            case 'sentenceComplete':
                this._addSentRow(d.original, d.translation, false);
                document.getElementById('progress-bar').style.width = d.percent+'%';
                document.getElementById('prog-label').textContent = d.completed+'/'+d.total;
                document.getElementById('prog-pct').textContent = d.percent+'%';
                document.getElementById('ws-tokens').textContent = Utils.formatNumber(d.tokensIn+d.tokensOut)+' tokens';
                document.getElementById('ws-detail').textContent = `Ch${d.chapterIndex+1} #${d.sentenceIndex+1}`;
                // 每5句保存
                if(d.completed % 5 === 0) this._saveProgress(d);
                break;
            case 'chapterComplete':
                this._saveProgress(null);
                break;
            case 'glossaryUpdate':
                this._renderGlossary(d.glossary);
                break;
            case 'styleAnalyzed':
                this._renderStyle(d.style);
                break;
            case 'summaryUpdate':
                this._renderSummary(d);
                break;
            case 'autoPaused':
                document.getElementById('pause-bar').classList.add('show');
                this._setDot('paused');
                document.getElementById('ws-phase').textContent = d.message||'已暂停';
                book.status='paused'; book.updatedAt=Date.now(); this._saveBook(book);
                break;
            case 'keySwitch':
                document.getElementById('ws-detail').textContent = `密钥切换 #${d.to+1}/${d.total} (${d.reason})`;
                break;
            case 'error':
                this._setDot('error');
                document.getElementById('ws-detail').textContent = d.message||'';
                break;
        }
    }
    _saveProgress(d) {
        const book = this._getBook(this.currentBookId);
        if(!book||!this.engine) return;
        book.completed = this.engine.completedSentences;
        book.tokensIn = this.engine.tokensInput;
        book.tokensOut = this.engine.tokensOutput;
        book.glossary = this.engine.glossary.toJSON();
        book.styleProfile = this.engine.styleProfile;
        book.globalSummary = this.engine.globalSummary;
        book.chapterSummaries = this.engine.chapterSummaries;
        book.updatedAt = Date.now();
        this._saveBook(book);
    }
    _onComplete() {
        const book = this._getBook(this.currentBookId);
        if(book){
            book.status='completed'; book.results=this.translationResults;
            book.completed=book.total; book.updatedAt=Date.now();
            book.glossary=this.engine.glossary.toJSON();
            book.styleProfile=this.engine.styleProfile;
            book.globalSummary=this.engine.globalSummary;
            book.chapterSummaries=this.engine.chapterSummaries;
            book.tokensIn=this.engine.tokensInput;
            book.tokensOut=this.engine.tokensOutput;
            this._saveBook(book);
        }
        this._setDot('');
        document.getElementById('ws-phase').textContent='完成';
        document.getElementById('progress-bar').style.width='100%';
        document.getElementById('prog-pct').textContent='100%';
        const banner=document.getElementById('done-banner');
        banner.classList.remove('hidden');
        document.getElementById('done-summary').textContent=`共翻译 ${this.engine.completedSentences} 句，消耗 ${Utils.formatNumber(this.engine.tokensInput+this.engine.tokensOutput)} tokens`;
    }
    _onCancelled() {
        const book = this._getBook(this.currentBookId);
        if(book){ book.status='cancelled'; book.updatedAt=Date.now(); this._saveBook(book); }
        this._setDot('');
        document.getElementById('ws-phase').textContent='已取消';
    }

    /* ── 工作台UI工具 ── */
    _addSentRow(src, tgt, failed) {
        const srcList=document.getElementById('src-list'), tgtList=document.getElementById('tgt-list');
        const s=document.createElement('div'); s.className='sent-row'; s.textContent=src;
        const t=document.createElement('div'); t.className='sent-row'+(failed?' failed':''); t.textContent=tgt;
        srcList.appendChild(s); tgtList.appendChild(t);
        if(this._autoScroll){ srcList.scrollTop=srcList.scrollHeight; tgtList.scrollTop=tgtList.scrollHeight; }
    }
    _setDot(cls) {
        const dot=document.getElementById('ws-dot');
        dot.className='ws-dot'; if(cls) dot.classList.add(cls);
    }
    _renderGlossary(gm) {
        document.getElementById('gl-count').textContent=gm.entries.length;
        const body=document.getElementById('gl-body');
        body.innerHTML=gm.entries.slice(0,100).map(e=>{
            const catCls='gl-cat gl-cat-'+e.category;
            const catLabel={character:'👤角色',location:'📍地点',item:'🗡️物品',organization:'🏛️组织',concept:'💡概念',other:'📌其他'}[e.category]||e.category;
            return `<tr><td>${Utils.escapeHtml(e.original)}</td><td>${Utils.escapeHtml(e.translation)}</td><td><span class="${catCls}">${catLabel}</span></td><td>${e.locked?'🔒':''}</td></tr>`;
        }).join('');
    }
    _renderStyle(style) {
        if(!style) return;
        const el=document.getElementById('style-content');
        el.innerHTML=`<p><strong>文风摘要：</strong>${Utils.escapeHtml(style.style_summary||'')}</p>
            <p><strong>语体：</strong>${Utils.escapeHtml(style.register||'')}</p>
            <p><strong>叙事语气：</strong>${Utils.escapeHtml(style.narrative_tone||'')}</p>
            <p><strong>翻译指导：</strong></p><ul>${(style.translation_guidelines||[]).map(g=>'<li>'+Utils.escapeHtml(g)+'</li>').join('')}</ul>`;
    }
    _renderSummary(d) {
        const el=document.getElementById('summary-content');
        if(d.type==='global') el.innerHTML=`<p><strong>全局摘要：</strong>${Utils.escapeHtml(d.summary)}</p>`+(el.innerHTML.includes('章节')?el.innerHTML.slice(el.innerHTML.indexOf('<p><strong>章节')):'');
        else if(d.type==='chapter') {
            let html=el.innerHTML;
            const tag=`<p><strong>章节${d.chapterIndex+1}：</strong>${Utils.escapeHtml(d.summary)}</p>`;
            if(!html.includes('章节'+(d.chapterIndex+1))) html+=tag;
            el.innerHTML=html;
        }
    }

    /* ── 工作台按钮绑定 ── */
    _bindWork() {
        document.getElementById('btn-pause').addEventListener('click',()=>{
            if(!this.engine)return;
            if(this.engine._paused){this.engine.resume();document.getElementById('pause-bar').classList.remove('show');this._setDot('active');document.getElementById('btn-pause').textContent='⏸ 暂停';}
            else{this.engine.pause();document.getElementById('pause-bar').classList.add('show');this._setDot('paused');document.getElementById('btn-pause').textContent='▶ 继续';
                const bk=this._getBook(this.currentBookId);if(bk){bk.status='paused';bk.updatedAt=Date.now();this._saveBook(bk);this._saveProgress(null);}
            }
        });
        document.getElementById('btn-resume-bar').addEventListener('click',()=>{
            if(this.engine){this.engine.resume();document.getElementById('pause-bar').classList.remove('show');this._setDot('active');document.getElementById('btn-pause').textContent='⏸ 暂停';
                const bk=this._getBook(this.currentBookId);if(bk){bk.status='translating';bk.updatedAt=Date.now();this._saveBook(bk);}
            }
        });
        document.getElementById('btn-cancel').addEventListener('click',()=>{if(this.engine&&confirm('确定取消翻译？'))this.engine.cancel();});
        document.getElementById('btn-export').addEventListener('click',()=>document.getElementById('modal-export').classList.remove('hidden'));
        document.getElementById('btn-done-export').addEventListener('click',()=>document.getElementById('modal-export').classList.remove('hidden'));
        document.getElementById('btn-done-shelf').addEventListener('click',()=>{this._showPage('shelf');this._renderShelf();});
        // 标签切换
        document.querySelectorAll('.wtab').forEach(tab=>{
            tab.addEventListener('click',()=>{
                document.querySelectorAll('.wtab').forEach(t=>t.classList.remove('active'));
                document.querySelectorAll('.wpanel').forEach(p=>p.classList.remove('active'));
                tab.classList.add('active');
                document.getElementById('panel-'+tab.dataset.tab).classList.add('active');
            });
        });
        // 自动滚动检测
        const tgt=document.getElementById('tgt-list');
        tgt.addEventListener('scroll',()=>{this._autoScroll=tgt.scrollTop+tgt.clientHeight>=tgt.scrollHeight-30;});
        // 术语搜索
        document.getElementById('gl-search').addEventListener('input',e=>{
            if(!this.engine)return;
            const results=this.engine.glossary.search(e.target.value);
            const tmp=new GlossaryManager();tmp.entries=results;
            this._renderGlossary(tmp);
        });
