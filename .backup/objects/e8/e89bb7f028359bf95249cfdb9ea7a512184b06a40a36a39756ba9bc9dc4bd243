    /* ── 弹窗绑定 ── */
    _bindModals() {
        // 设置保存
        document.getElementById('api-provider').addEventListener('change',()=>this._toggleCustomUrl());
        document.getElementById('api-reasoning').addEventListener('change',()=>this._toggleCustomTemp());
        document.getElementById('api-keys').addEventListener('input',()=>this._updateKeyCountHint());

        // 获取模型按钮
        document.getElementById('btn-fetch-models').addEventListener('click', async ()=>{
            const btn = document.getElementById('btn-fetch-models');
            const hint = document.getElementById('model-fetch-hint');
            const sel = document.getElementById('api-model-select');
            const inp = document.getElementById('api-model');

            // 取当前填写的key和base
            const keys = document.getElementById('api-keys').value.split('\n').map(k=>k.trim()).filter(k=>k);
            if(keys.length===0){ hint.style.display='block'; hint.textContent='⚠️ 请先填写至少一个API密钥'; hint.style.color='#c00'; return; }

            const provider = document.getElementById('api-provider').value;
            const urls = { 'deepseek':'https://api.deepseek.com/v1', 'openai':'https://api.openai.com/v1' };
            const baseUrl = provider==='custom' ? document.getElementById('api-base-url').value.replace(/\/+$/,'') : (urls[provider]||urls['deepseek']);

            btn.disabled = true;
            btn.textContent = '⏳ 获取中...';
            hint.style.display = 'block';
            hint.style.color = 'var(--text-dim)';
            hint.textContent = '正在连接API获取模型列表...';

            try {
                const adapter = new LLMAdapter({ apiKey: keys[0], baseUrl, provider });
                const models = await adapter.fetchModels(baseUrl, keys[0]);
                if(!models || models.length===0) throw new Error('返回模型列表为空');

                // 填充select
                sel.innerHTML = '';
                const currentModel = inp.value.trim();
                let hasCurrentModel = false;
                for(const m of models){
                    const opt = document.createElement('option');
                    opt.value = m; opt.textContent = m;
                    if(m === currentModel) hasCurrentModel = true;
                    sel.appendChild(opt);
                }
                if (hasCurrentModel) {
                    sel.value = currentModel;
                } else if (models.length > 0) {
                    sel.value = models[0];
                }
                // 切换：显示select，隐藏input
                sel.style.display = '';
                inp.style.display = 'none';
                // select变化时同步到input
                sel.onchange = ()=>{ inp.value = sel.value; };
                if(sel.value) inp.value = sel.value;

                hint.style.color = '#2a7';
                hint.textContent = hasCurrentModel
                    ? `✅ 获取到 ${models.length} 个模型`
                    : `✅ 获取到 ${models.length} 个模型，已自动选择 ${sel.value}`;
                btn.textContent = '🔄 刷新模型';
            } catch(e) {
                hint.style.color = '#c00';
                hint.textContent = `❌ ${e.message}`;
                // 保持input模式
                sel.style.display = 'none';
                inp.style.display = '';
                btn.textContent = '📡 获取模型';
            } finally {
                btn.disabled = false;
            }
        });

        // select ↔ input 切换：双击select可恢复手动输入
        document.getElementById('api-model-select').addEventListener('dblclick', ()=>{
            document.getElementById('api-model-select').style.display = 'none';
            document.getElementById('api-model').style.display = '';
            document.getElementById('model-fetch-hint').textContent = '已切换回手动输入模式';
            document.getElementById('model-fetch-hint').style.color = 'var(--text-dim)';
            document.getElementById('btn-fetch-models').textContent = '📡 获取模型';
        });

        document.getElementById('btn-save-settings').addEventListener('click',()=>{
            const apiKeys = document.getElementById('api-keys').value.split('\n').map(k=>k.trim()).filter(k=>k);
            if(apiKeys.length===0){alert('请至少填写一个API密钥');return;}
            const reasoning = document.getElementById('api-reasoning').value;
            let temperature;
            if(reasoning==='custom'){
                temperature = parseFloat(document.getElementById('api-temp').value)||0.3;
            } else {
                temperature = this._reasoningToTemp(reasoning) || 0.3;
            }
            // 模型：优先select值（如果可见），否则取input值
            const sel = document.getElementById('api-model-select');
            const inp = document.getElementById('api-model');
            const provider = document.getElementById('api-provider').value;
            const rawModel = (sel.style.display !== 'none' && sel.value) ? sel.value : inp.value;
            const model = this._getEffectiveModel(provider, rawModel);
            if(!model){alert('请填写模型名，或点击“获取模型”选择一个可用模型');return;}
            this.settings={
                provider:provider,
                apiKeys,
                baseUrl:document.getElementById('api-base-url').value.replace(/\/+$/,''),
                model:model,
                reasoning,
                temperature,
                maxTokens:parseInt(document.getElementById('api-max-tokens').value)||1024
            };
            Utils.saveLocal('settings',this.settings);
            document.getElementById('modal-settings').classList.add('hidden');
        });
        // 添加术语
        document.getElementById('btn-add-term').addEventListener('click',()=>document.getElementById('modal-add-term').classList.remove('hidden'));
        document.getElementById('btn-confirm-term').addEventListener('click',()=>{
            const src=document.getElementById('term-src').value.trim(),tgt=document.getElementById('term-tgt').value.trim(),cat=document.getElementById('term-cat').value;
            if(!src||!tgt){alert('请填写原文和译文');return;}
            if(this.engine){this.engine.glossary.addOrUpdate({original:src,translation:tgt,category:cat,source:'manual'});this._renderGlossary(this.engine.glossary);}
            document.getElementById('term-src').value='';document.getElementById('term-tgt').value='';
            document.getElementById('modal-add-term').classList.add('hidden');
        });
        // 导入术语
        document.getElementById('btn-import-gl').addEventListener('click',()=>{
            const input=document.createElement('input');input.type='file';input.accept='.json';
            input.addEventListener('change',()=>{
                if(!input.files[0])return;
                const r=new FileReader();r.onload=()=>{
                    try{const data=JSON.parse(r.result);if(this.engine){if(data.entries)this.engine.glossary.fromJSON(data);else if(Array.isArray(data))this.engine.glossary.addBatch(data);this._renderGlossary(this.engine.glossary);}}catch(e){alert('JSON格式错误');}
                };r.readAsText(input.files[0]);
            });input.click();
        });
        // 导出
        document.querySelectorAll('.export-item').forEach(item=>{
            item.addEventListener('click',()=>{
                const fmt=item.dataset.fmt;
                const book=this._getBook(this.currentBookId);
                const results=book?book.results:this.translationResults;
                if(!results||results.length===0){alert('没有可导出的内容');return;}
                const name=book?book.fileName:'export';
                if(fmt==='txt'){
                    const txt=results.map(ch=>ch.title+'\n\n'+ch.sentences.map(s=>s.translation).join('\n')).join('\n\n---\n\n');
                    Utils.downloadFile(txt,name+'_译文.txt');
                }else if(fmt==='bilingual'){
                    const txt=results.map(ch=>ch.title+'\n\n'+ch.sentences.map(s=>'[原] '+s.original+'\n[译] '+s.translation).join('\n\n')).join('\n\n---\n\n');
                    Utils.downloadFile(txt,name+'_双语.txt');
                }else if(fmt==='json'){
                    Utils.downloadFile(JSON.stringify(book||{results},null,2),name+'_完整.json','application/json');
                }else if(fmt==='glossary'){
                    const gl=book&&book.glossary?book.glossary:(this.engine?this.engine.glossary.toJSON():{entries:[]});
                    Utils.downloadFile(JSON.stringify(gl,null,2),name+'_术语表.json','application/json');
                }
                document.getElementById('modal-export').classList.add('hidden');
            });
        });
        // 点击背景关闭弹窗
        document.querySelectorAll('.modal-bg').forEach(bg=>{
            bg.addEventListener('click',e=>{if(e.target===bg)bg.classList.add('hidden');});
        });
    }
