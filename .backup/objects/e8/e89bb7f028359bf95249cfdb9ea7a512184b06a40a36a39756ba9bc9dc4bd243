    _processText(text) {
        const splitter = new TextSplitter();
        this.chapters = splitter.parse(text);
        this._showParsedConfig(this.chapters, text);
    }
    _showParsedConfig(chapters, rawText) {
        const totalSent = chapters.reduce((s,c)=>s+c.sentences.length,0);
        // 估算总字符：如果有原始文本用它，否则从sentences拼接
        const totalChars = rawText ? rawText.length : chapters.reduce((s,c)=>s+c.sentences.reduce((a,b)=>a+b.length,0),0);
        const previewText = rawText ? rawText.slice(0,500) : chapters.slice(0,2).map(c=>c.title+'\n'+c.sentences.slice(0,3).join(' ')).join('\n\n');
        document.getElementById('cfg-filename').textContent = this.fileName;
        document.getElementById('cfg-chars').textContent = Utils.formatNumber(totalChars);
        document.getElementById('cfg-sentences').textContent = totalSent;
        document.getElementById('cfg-chapters').textContent = chapters.length;
        document.getElementById('cfg-tokens').textContent = Utils.formatNumber(totalSent * 800);
        document.getElementById('cfg-preview').textContent = previewText.slice(0,500) + (previewText.length>500?'...':'');
        this._showPage('config');
    }
    _cloneResults(results) {
        return JSON.parse(JSON.stringify(results || []));
    }
    _getResultMap(results) {
        const map = {};
        (results || []).forEach((ch, idx) => {
            if (!ch) return;
            const key = typeof ch.chapterIndex === 'number' ? ch.chapterIndex : idx;
            map[key] = ch;
        });
        return map;
    }
    _countResultSentences(results) {
        return (results || []).reduce((sum, ch) => sum + (((ch && ch.sentences) ? ch.sentences.length : 0)), 0);
    }
    _buildResumePlan(book) {
        const resultMap = this._getResultMap(book.results || []);
        const remaining = [];
        const chapterMap = [];
        let completed = 0;

        for (let chIdx = 0; chIdx < book.chapters.length; chIdx++) {
            const sourceChapter = book.chapters[chIdx] || { title:'', sentences:[] };
            const sourceSentences = sourceChapter.sentences || [];
            const translatedCount = Math.min(sourceSentences.length, ((resultMap[chIdx] && resultMap[chIdx].sentences) ? resultMap[chIdx].sentences.length : 0));
            completed += translatedCount;

            if (translatedCount < sourceSentences.length) {
                remaining.push({ title: sourceChapter.title, sentences: sourceSentences.slice(translatedCount) });
                chapterMap.push({ originalChapterIndex: chIdx, startSentenceIndex: translatedCount });
            }
        }

        return { completed, remaining, chapterMap };
    }
    _getSentenceOffset(chapterIndex) {
        let offset = 0;
        for (let i = 0; i < chapterIndex; i++) {
            offset += ((this.chapters[i] && this.chapters[i].sentences) ? this.chapters[i].sentences.length : 0);
        }
        return offset;
    }
    _resolveGlobalPosition(engineChapterIndex, engineSentenceIndex) {
        const meta = this._engineChapterMap && this._engineChapterMap[engineChapterIndex];
        const chapterIndex = meta ? meta.originalChapterIndex : engineChapterIndex;
        const sentenceIndex = (meta ? meta.startSentenceIndex : 0) + engineSentenceIndex;
        return {
            chapterIndex,
            sentenceIndex,
            flatIndex: this._getSentenceOffset(chapterIndex) + sentenceIndex
        };
    }
    _ensureResultChapter(chapterIndex) {
        if (!this.translationResults[chapterIndex]) {
            this.translationResults[chapterIndex] = {
                chapterIndex: chapterIndex,
                title: (this.chapters[chapterIndex] && this.chapters[chapterIndex].title) || ('第' + (chapterIndex + 1) + '章'),
                sentences: [],
                summary: ''
            };
        }
        return this.translationResults[chapterIndex];
    }
    _storeSentenceResult(chapterIndex, sentenceIndex, original, translation, failed) {
        const chapter = this._ensureResultChapter(chapterIndex);
        chapter.sentences[sentenceIndex] = { original: original, translation: translation, failed: !!failed };
    }
    _mergeEngineResults(results) {
        (results || []).forEach((ch, idx) => {
            const meta = this._engineChapterMap && this._engineChapterMap[idx];
            const chapterIndex = meta ? meta.originalChapterIndex : idx;
            const startSentenceIndex = meta ? meta.startSentenceIndex : 0;
            const target = this._ensureResultChapter(chapterIndex);
            target.chapterIndex = chapterIndex;
            target.title = ch.title || target.title;
            if (ch.summary) target.summary = ch.summary;
            (ch.sentences || []).forEach((sent, sentIdx) => {
                target.sentences[startSentenceIndex + sentIdx] = sent;
            });
        });
    }
    _materializeResults() {
        return (this.translationResults || []).filter(Boolean).map(ch => ({
            chapterIndex: ch.chapterIndex,
            title: ch.title,
            sentences: (ch.sentences || []).filter(Boolean),
            summary: ch.summary || ''
        }));
    }
    _restoreEngineChapterSummaries(chapterSummaries) {
        const shifted = {};
        const offset = this._summaryChapterOffset || 0;
        Object.entries(chapterSummaries || {}).forEach(([key, value]) => {
            const idx = Number(key);
            if (!Number.isFinite(idx)) return;
            shifted[idx - offset] = value;
        });
        return shifted;
    }
    _getPersistedChapterSummaries() {
        const source = (this.engine && this.engine.chapterSummaries) ? this.engine.chapterSummaries : {};
        const shifted = {};
        const offset = this._summaryChapterOffset || 0;
        Object.entries(source || {}).forEach(([key, value]) => {
            const idx = Number(key);
            if (!Number.isFinite(idx)) return;
            shifted[idx + offset] = value;
        });
        return shifted;
    }
    _renderWorkRows() {
        const srcList = document.getElementById('src-list');
        const tgtList = document.getElementById('tgt-list');
        const prevAutoScroll = this._autoScroll;
        srcList.innerHTML = '';
        tgtList.innerHTML = '';
        this._workRows = [];
        this._autoScroll = false;
        let flatIndex = 0;

        for (let chIdx = 0; chIdx < this.chapters.length; chIdx++) {
            const sourceChapter = this.chapters[chIdx] || { sentences:[] };
            const translatedChapter = this.translationResults[chIdx] || { sentences:[] };
            const translatedSentences = translatedChapter.sentences || [];
            for (let sentIdx = 0; sentIdx < sourceChapter.sentences.length; sentIdx++) {
                const source = sourceChapter.sentences[sentIdx];
                const existing = translatedSentences[sentIdx];
                this._addSentRow(source, existing ? existing.translation : '', existing ? existing.failed : false, flatIndex);
                flatIndex += 1;
            }
        }

        this._autoScroll = prevAutoScroll;
        srcList.scrollTop = 0;
        tgtList.scrollTop = 0;
    }

    /* ── 配置绑定 ── */
    _bindConfig() {
        document.getElementById('btn-start-translate').addEventListener('click', () => this._startTranslation());
    }
    _startTranslation() {
        if(!this.settings.apiKeys||this.settings.apiKeys.length===0){ alert('请先在设置中填写API密钥'); this._openSettingsModal(); return; }
        if(!this.chapters || this.chapters.length===0){ alert('没有可翻译的内容'); return; }
        const model = this._ensureSettingsModel();
        if(!model){ alert('请先填写模型名，或点击“获取模型”选择一个可用模型'); this._openSettingsModal(); return; }
        const bookId = Utils.uid();
        this.currentBookId = bookId;
        this.translationResults = [];
        const totalSent = this.chapters.reduce((s,c)=>s+c.sentences.length,0);
        const book = {
            id: bookId, fileName: this.fileName,
            targetLang: document.getElementById('cfg-lang').value,
            chapters: this.chapters, results: [], glossary: null, styleProfile: null,
            globalSummary:'', chapterSummaries:{}, tokensIn:0, tokensOut:0,
            completed:0, total:totalSent, status:'translating',
            createdAt: Date.now(), updatedAt: Date.now()
        };
        this._saveBook(book);
        this._launchEngine(book);
    }

    _resumeBook(book) {
        if (this.engine && this.currentBookId === book.id && !this.engine._cancelled) {
            this._showPage('work');
            return;
        }
        this.currentBookId = book.id;
        this.fileName = book.fileName;
        this.chapters = book.chapters;
        this.translationResults = this._cloneResults(book.results || []);
        book.status = 'translating';
        book.updatedAt = Date.now();
        this._saveBook(book);
        this._launchEngine(book);
    }

    _launchEngine(book) {
document.getElementById('work-title').textContent = book.fileName;
document.getElementById('done-banner').classList.add('hidden');
document.getElementById('pause-bar').classList.remove('show');
document.getElementById('btn-pause').textContent = '⏸ 暂停';
document.getElementById('btn-pause').disabled = false;
this._setDot('active');
this._showPage('work');

        const total = book.total || this.chapters.reduce((sum, ch) => sum + (((ch && ch.sentences) ? ch.sentences.length : 0)), 0);
        const resumePlan = this._buildResumePlan(book);
        this._engineChapterMap = resumePlan.chapterMap;
        this._progressOffset = resumePlan.completed;
        this._summaryChapterOffset = resumePlan.chapterMap.length > 0 ? resumePlan.chapterMap[0].originalChapterIndex : 0;

        document.getElementById('gl-count').textContent = '0';
        document.getElementById('gl-body').innerHTML = '';
        if (book.glossary) {
            const glossary = new GlossaryManager();
            glossary.fromJSON(book.glossary);
            this._renderGlossary(glossary);
        }
        document.getElementById('style-content').innerHTML = '';
        if (book.styleProfile) this._renderStyle(book.styleProfile);
        document.getElementById('summary-content').innerHTML = '';
        if (book.globalSummary) this._renderSummary({ type:'global', summary: book.globalSummary });
        Object.keys(book.chapterSummaries || {})
            .sort((a, b) => Number(a) - Number(b))
            .forEach(key => this._renderSummary({ type:'chapter', chapterIndex: Number(key), summary: book.chapterSummaries[key] }));

        this._renderWorkRows();

        const pct = total > 0 ? Math.round(resumePlan.completed / total * 100) : 0;
        document.getElementById('progress-bar').style.width = pct + '%';
        document.getElementById('prog-label').textContent = resumePlan.completed + '/' + total;
        document.getElementById('prog-pct').textContent = pct + '%';
        document.getElementById('ws-phase').textContent = resumePlan.remaining.length > 0 ? '准备中' : '完成';
        document.getElementById('ws-tokens').textContent = Utils.formatNumber((book.tokensIn || 0) + (book.tokensOut || 0)) + ' tokens';
        document.getElementById('ws-detail').textContent = resumePlan.completed > 0 ? `已恢复 ${resumePlan.completed} 句` : `待翻译 ${total} 句`;

        const focusIndex = Math.min(resumePlan.completed, this._workRows.length - 1);
        if (focusIndex >= 0 && this._workRows[focusIndex]) {
            this._workRows[focusIndex].src.scrollIntoView({ block:'nearest' });
            this._workRows[focusIndex].tgt.scrollIntoView({ block:'nearest' });
        }

        const s = this.settings;
        const cfg = {
            api:{ apiKeys:s.apiKeys, model:this._ensureSettingsModel(), baseUrl:s.baseUrl, provider:s.provider },
            targetLang: book.targetLang,
            windowSize: parseInt(document.getElementById('cfg-window').value)||8,
            temperature: parseFloat(s.temperature)||0.3,
            autoGlossary: document.getElementById('cfg-glossary').checked,
            autoStyle: document.getElementById('cfg-style').checked,
        };
        const engine = new TranslationEngine(cfg);
        const runId = ++this._engineRunId;
        this.engine = engine;
        if(book.glossary) engine.glossary.fromJSON(book.glossary);
        if(book.styleProfile) engine.styleProfile = book.styleProfile;
        if(book.globalSummary) engine.globalSummary = book.globalSummary;
        engine.chapterSummaries = this._restoreEngineChapterSummaries(book.chapterSummaries || {});
        engine.tokensInput = book.tokensIn||0;
        engine.tokensOutput = book.tokensOut||0;
        engine.completedSentences = 0;
        engine.totalSentences = total;

        // 初始化边翻边读
        this._liveChIdx = 0;
        this._initLiveReader();

        if (resumePlan.remaining.length === 0) {
            this.translationResults = this._cloneResults(book.results || []);
            this._onComplete();
            return;
        }

        engine.translateBook(resumePlan.remaining, (ev,d) => {
            if (runId !== this._engineRunId || this.engine !== engine) return;
            this._onProgress(ev,d);
        })
            .then(results => {
                if (runId !== this._engineRunId || this.engine !== engine) return;
                this._mergeEngineResults(results);
                this.translationResults = this._cloneResults(this._materializeResults());
                this._onComplete();
            })
            .catch(err => {
                if (runId !== this._engineRunId || this.engine !== engine) return;
                if(err.message==='CANCELLED'){ this._onCancelled(); }
                else { console.error(err); alert('翻译错误: '+err.message); }
            });
    }

    /* ── 进度回调 ── */
    _onProgress(ev, d) {
        const book = this._getBook(this.currentBookId);
        if(!book) return;
        switch(ev) {
            case 'phase':
                document.getElementById('ws-phase').textContent = d.message||d.phase;
                break;
            case 'sentenceComplete': {
                const pos = this._resolveGlobalPosition(d.chapterIndex, d.sentenceIndex);
                const total = book.total || this.chapters.reduce((sum, ch) => sum + (((ch && ch.sentences) ? ch.sentences.length : 0)), 0);
                const completed = Math.min(total, (this._progressOffset || 0) + (typeof d.completed === 'number' ? d.completed : (this.engine ? this.engine.completedSentences : 0)));
                const percent = total > 0 ? Math.round(completed / total * 100) : 0;
                const failed = !!d.failed;
                this._storeSentenceResult(pos.chapterIndex, pos.sentenceIndex, d.original, d.translation, failed);
                this._addSentRow(d.original, d.translation, failed, pos.flatIndex);
                document.getElementById('progress-bar').style.width = percent+'%';
                document.getElementById('prog-label').textContent = completed+'/'+total;
                document.getElementById('prog-pct').textContent = percent+'%';
                document.getElementById('ws-tokens').textContent = Utils.formatNumber((d.tokensIn||0)+(d.tokensOut||0))+' tokens';
                document.getElementById('ws-detail').textContent = `Ch${pos.chapterIndex+1} #${pos.sentenceIndex+1}`;
                this._saveProgress(d);
                this._updateLiveReaderOnProgress();
                break;
            }
            case 'chapterComplete':
                if (typeof d.chapterIndex === 'number' && this.engine && this.engine.chapterSummaries) {
                    const meta = this._engineChapterMap && this._engineChapterMap[d.chapterIndex];
                    const chapterIndex = meta ? meta.originalChapterIndex : d.chapterIndex;
                    const chapter = this._ensureResultChapter(chapterIndex);
                    if (this.engine.chapterSummaries[d.chapterIndex] !== undefined) {
                        chapter.summary = this.engine.chapterSummaries[d.chapterIndex];
                    }
                }
                this._saveProgress(null);
                break;
            case 'glossaryUpdate':
                this._renderGlossary(d.glossary);
                this._saveProgress(null);
                break;
            case 'styleAnalyzed':
                this._renderStyle(d.style);
                this._saveProgress(null);
                break;
            case 'summaryUpdate':
                if(d.type === 'chapter' && typeof d.chapterIndex === 'number'){
                    const meta = this._engineChapterMap && this._engineChapterMap[d.chapterIndex];
                    const chapterIndex = meta ? meta.originalChapterIndex : d.chapterIndex;
                    this._ensureResultChapter(chapterIndex).summary = d.summary;
                    d = Object.assign({}, d, { chapterIndex: chapterIndex });
                }
                this._renderSummary(d);
                this._saveProgress(null);
                break;
            case 'autoPaused':
                document.getElementById('pause-bar').classList.add('show');
                this._setDot('paused');
                document.getElementById('ws-phase').textContent = d.message||'已暂停';
                book.status='paused';
                book.updatedAt=Date.now();
                this._saveBook(book);
                this._saveProgress(null);
                break;
            case 'apiCall':
                this._updateApiLog(d);
                break;
            case 'keySwitch':
                document.getElementById('ws-detail').textContent = `密钥切换 #${d.to+1}/${d.total} (${d.reason})`;
                break;
            case 'error':
                this._setDot('error');
                document.getElementById('ws-detail').textContent = d.message||'';
                break;
        }
    }
    _saveProgress(d) {
        const book = this._getBook(this.currentBookId);
        if(!book||!this.engine) return;
        const total = book.total || this.chapters.reduce((sum, ch) => sum + (((ch && ch.sentences) ? ch.sentences.length : 0)), 0);
        book.total = total;
        book.completed = Math.min(total, (this._progressOffset || 0) + (this.engine.completedSentences || 0));
        book.tokensIn = this.engine.tokensInput;
        book.tokensOut = this.engine.tokensOutput;
        document.getElementById('ws-tokens').textContent = Utils.formatNumber((this.engine.tokensInput || 0) + (this.engine.tokensOutput || 0)) + ' tokens';
        book.results = this._materializeResults();
        book.glossary = this.engine.glossary.toJSON();
        book.styleProfile = this.engine.styleProfile;
        book.globalSummary = this.engine.globalSummary;
        book.chapterSummaries = this._getPersistedChapterSummaries();
        book.updatedAt = Date.now();
        this._saveBook(book);
    }
    _onComplete() {
        const book = this._getBook(this.currentBookId);
        const total = (book && book.total) || this.chapters.reduce((sum, ch) => sum + (((ch && ch.sentences) ? ch.sentences.length : 0)), 0);
        const finalResults = this._materializeResults();
        this.translationResults = this._cloneResults(finalResults);
        if(book){
            book.status='completed';
            book.total=total;
            book.results=finalResults;
            book.completed=total;
            book.updatedAt=Date.now();
            book.glossary=this.engine.glossary.toJSON();
            book.styleProfile=this.engine.styleProfile;
            book.globalSummary=this.engine.globalSummary;
            book.chapterSummaries=this._getPersistedChapterSummaries();
            book.tokensIn=this.engine.tokensInput;
            book.tokensOut=this.engine.tokensOutput;
            this._saveBook(book);
        }
        this._setDot('');
        document.getElementById('ws-phase').textContent='完成';
        document.getElementById('progress-bar').style.width='100%';
        document.getElementById('prog-label').textContent=total+'/'+total;
        document.getElementById('prog-pct').textContent='100%';
        const banner=document.getElementById('done-banner');
        banner.classList.remove('hidden');
        document.getElementById('done-summary').textContent=`共翻译 ${total} 句，消耗 ${Utils.formatNumber(this.engine.tokensInput+this.engine.tokensOutput)} tokens`;
        this._bindOptimize();
    }

    _bindOptimize() {
        const btnOptimize = document.getElementById('btn-optimize');
        const btnCancelOpt = document.getElementById('btn-cancel-optimize');
        const optBar = document.getElementById('optimize-bar');
        if (!btnOptimize) return;

        btnOptimize.onclick = async () => {
            if (!this.translationResults || this.translationResults.length === 0) {
                alert('没有可优化的翻译结果');
                return;
            }
            btnOptimize.disabled = true;
            btnOptimize.textContent = '优化中...';
            optBar.classList.add('show');
            optBar.querySelector('.optimize-fill').style.width = '0%';
            this._optimizing = true;

            try {
                await this.engine.optimizeTranslation(this.translationResults, (done, total) => {
                    if (!this._optimizing) return;
                    const pct = Math.round(done / total * 100);
                    optBar.querySelector('.optimize-fill').style.width = pct + '%';
                    optBar.querySelector('.optimize-label').textContent = `优化中 ${done}/${total}`;
                });
                if (this._optimizing) {
                    this._saveProgress(null);
                    this._renderLiveContent();
                    alert('优化完成！');
                }
            } catch (e) {
                console.error('优化失败', e);
                alert('优化失败: ' + e.message);
            } finally {
                this._optimizing = false;
                btnOptimize.disabled = false;
                btnOptimize.textContent = '✨ 优化翻译';
                optBar.classList.remove('show');
            }
        };

        if (btnCancelOpt) {
            btnCancelOpt.onclick = () => {
                this._optimizing = false;
            };
        }
    }
    
    async _startReaderOptimize() {
        const book = this._rdBook;
        if (!book || book.status !== 'done') {
            alert('仅翻译完成的书籍可优化');
            return;
        }
        const results = Utils.loadLocal(`results-${book.id}`, []);
        if (!results || results.length === 0) {
            alert('没有可优化的翻译结果');
            return;
        }
        
        const btn = document.getElementById('btn-rd-optimize');
        const origText = btn.querySelector('span:last-child').textContent;
        btn.disabled = true;
        btn.querySelector('span:last-child').textContent = '优化中...';
        this._optimizing = true;
        
        // 初始化引擎（如果需要）
        if (!this.engine) {
            const cfg = Utils.loadLocal('api-config', {});
            this.engine = new TranslationEngine({
                api: cfg,
                targetLang: book.targetLang || '简体中文',
                novelType: book.novelType || '通用'
            });
        }
        // 恢复术语表和摘要
        this.engine.glossary.entries = Utils.loadLocal(`glossary-${book.id}`, []);
        this.engine.chapterSummaries = Utils.loadLocal(`summaries-${book.id}`, {});
        
        try {
            const optimized = await this.engine.optimizeTranslation(results, (done, total) => {
                if (!this._optimizing) return;
                btn.querySelector('span:last-child').textContent = `${Math.round(done/total*100)}%`;
            });
            if (this._optimizing && optimized) {
                Utils.saveLocal(`results-${book.id}`, optimized);
                this._renderChContent(); // 刷新当前章节
                alert('优化完成！');
            }
        } catch (e) {
            console.error('优化失败', e);
            alert('优化失败: ' + e.message);
        } finally {
            this._optimizing = false;
            btn.disabled = false;
            btn.querySelector('span:last-child').textContent = origText;
        }
    }
    
    _onCancelled() {
        this._saveProgress(null);
        const book = this._getBook(this.currentBookId);
        if(book){ book.status='cancelled'; book.updatedAt=Date.now(); this._saveBook(book); }
        this._setDot('');
        document.getElementById('pause-bar').classList.remove('show');
        document.getElementById('ws-phase').textContent='已取消';
        document.getElementById('ws-detail').textContent='可点击“继续”恢复未完成任务';
        document.getElementById('btn-pause').textContent='▶ 继续';
        document.getElementById('btn-pause').disabled=false;
        this.engine = null;
    }

    /* ── 工作台UI工具 ── */
    _addSentRow(src, tgt, failed, rowIndex) {
        const srcList=document.getElementById('src-list'), tgtList=document.getElementById('tgt-list');
        let row = typeof rowIndex === 'number' ? this._workRows[rowIndex] : null;
        if (!row) {
            const s=document.createElement('div');
            const t=document.createElement('div');
            s.className='sent-row';
            t.className='sent-row';
            srcList.appendChild(s);
            tgtList.appendChild(t);
            row = { src:s, tgt:t };
            if (typeof rowIndex === 'number') this._workRows[rowIndex] = row;
            else this._workRows.push(row);
        }
        row.src.textContent = src || '';
        row.tgt.textContent = tgt || '';
        row.tgt.className = 'sent-row'+(failed?' failed':'');
        if(this._autoScroll){
            if (typeof rowIndex === 'number') {
                row.src.scrollIntoView({ block:'nearest' });
                row.tgt.scrollIntoView({ block:'nearest' });
            } else {
                srcList.scrollTop=srcList.scrollHeight;
                tgtList.scrollTop=tgtList.scrollHeight;
            }
        }
    }
    _setDot(cls) {
        const dot=document.getElementById('ws-dot');
        dot.className='ws-dot'; if(cls) dot.classList.add(cls);
    }
    _renderGlossary(gm) {
        document.getElementById('gl-count').textContent=gm.entries.length;
        const body=document.getElementById('gl-body');
        body.innerHTML=gm.entries.slice(0,100).map(e=>{
            const catCls='gl-cat gl-cat-'+e.category;
            const catLabel={character:'👤角色',location:'📍地点',item:'🗡️物品',organization:'🏛️组织',concept:'💡概念',other:'📌其他'}[e.category]||e.category;
            return `<tr><td>${Utils.escapeHtml(e.original)}</td><td>${Utils.escapeHtml(e.translation)}</td><td><span class="${catCls}">${catLabel}</span></td><td>${e.locked?'🔒':''}</td></tr>`;
        }).join('');
    }
    _renderStyle(style) {
        if(!style) return;
        const el=document.getElementById('style-content');
        el.innerHTML=`<p><strong>文风摘要：</strong>${Utils.escapeHtml(style.style_summary||'')}</p>
            <p><strong>语体：</strong>${Utils.escapeHtml(style.register||'')}</p>
            <p><strong>叙事语气：</strong>${Utils.escapeHtml(style.narrative_tone||'')}</p>
            <p><strong>翻译指导：</strong></p><ul>${(style.translation_guidelines||[]).map(g=>'<li>'+Utils.escapeHtml(g)+'</li>').join('')}</ul>`;
    }
    _renderSummary(d) {
        const el=document.getElementById('summary-content');
        if(d.type==='global') el.innerHTML=`<p><strong>全局摘要：</strong>${Utils.escapeHtml(d.summary)}</p>`+(el.innerHTML.includes('章节')?el.innerHTML.slice(el.innerHTML.indexOf('<p><strong>章节')):'');
        else if(d.type==='chapter') {
            let html=el.innerHTML;
            const tag=`<p><strong>章节${d.chapterIndex+1}：</strong>${Utils.escapeHtml(d.summary)}</p>`;
            if(!html.includes('章节'+(d.chapterIndex+1))) html+=tag;
            el.innerHTML=html;
        }
    }

    _activateWorkTab(tabName) {
        document.querySelectorAll('.wtab').forEach(t=>t.classList.toggle('active', t.dataset.tab===tabName));
        document.querySelectorAll('.wpanel').forEach(p=>p.classList.toggle('active', p.id===('panel-'+tabName)));
        if(tabName==='reading') this._ensureLiveReaderData();
    }

    /* ── 工作台按钮绑定 ── */
    _bindWork() {
        document.getElementById('btn-pause').addEventListener('click',()=>{
            const bk=this._getBook(this.currentBookId);
            if(this.engine && this.engine._paused){
                this.engine.resume();
                document.getElementById('pause-bar').classList.remove('show');
                this._setDot('active');
                document.getElementById('btn-pause').textContent='⏸ 暂停';
                document.getElementById('btn-pause').disabled=false;
                if(bk){bk.status='translating';bk.updatedAt=Date.now();this._saveBook(bk);}
            } else if(this.engine){
                this.engine.pause();
                document.getElementById('pause-bar').classList.add('show');
                this._setDot('paused');
                document.getElementById('btn-pause').textContent='▶ 继续';
                if(bk){bk.status='paused';bk.updatedAt=Date.now();this._saveBook(bk);this._saveProgress(null);}
            } else if(bk && (bk.status==='paused'||bk.status==='translating')){
                this._resumeBook(bk);
            }
        });
        document.getElementById('btn-resume-bar').addEventListener('click',()=>{
const bk=this._getBook(this.currentBookId);
if(this.engine && this.engine._paused){
    // 引擎存在且暂停中，直接resume
    this.engine.resume();
    document.getElementById('pause-bar').classList.remove('show');
    this._setDot('active');
    document.getElementById('btn-pause').textContent='⏸ 暂停';
    if(bk){bk.status='translating';bk.updatedAt=Date.now();this._saveBook(bk);}
} else if(bk && (bk.status==='paused'||bk.status==='translating')){
    // 引擎不存在或已结束，重新启动继续翻译
    this._resumeBook(bk);
}
});
document.getElementById('btn-cancel').addEventListener('click',()=>{
if(!confirm('确定取消翻译？')) return;
if(this.engine) this.engine.cancel();
const bk=this._getBook(this.currentBookId);
if(bk){
    bk.status='cancelled';
    bk.updatedAt=Date.now();
    this._saveBook(bk);
}
document.getElementById('pause-bar').classList.remove('show');
this._setDot('');
document.getElementById('ws-phase').textContent='已取消';
document.getElementById('btn-pause').disabled=true;
});
        document.getElementById('btn-export').addEventListener('click',()=>document.getElementById('modal-export').classList.remove('hidden'));
        document.getElementById('btn-done-export').addEventListener('click',()=>document.getElementById('modal-export').classList.remove('hidden'));
        document.getElementById('btn-done-shelf').addEventListener('click',()=>{this._showPage('shelf');this._renderShelf();});
        // 标签切换
        document.querySelectorAll('.wtab').forEach(tab=>{
            tab.addEventListener('click',()=>{
                document.querySelectorAll('.wtab').forEach(t=>t.classList.remove('active'));
                document.querySelectorAll('.wpanel').forEach(p=>p.classList.remove('active'));
                tab.classList.add('active');
                document.getElementById('panel-'+tab.dataset.tab).classList.add('active');
                // 切换到阅读时确保数据加载
                if(tab.dataset.tab==='reading'){
                    this._ensureLiveReaderData();
                }
            });
        });
        // 自动滚动检测
        const tgt=document.getElementById('tgt-list');
        tgt.addEventListener('scroll',()=>{this._autoScroll=tgt.scrollTop+tgt.clientHeight>=tgt.scrollHeight-30;});
        // 术语搜索
        document.getElementById('gl-search').addEventListener('input',e=>{
            if(!this.engine)return;
            const results=this.engine.glossary.search(e.target.value);
            const tmp=new GlossaryManager();tmp.entries=results;
            this._renderGlossary(tmp);
        });

        // 边翻边读
        this._liveMode = 'translated';
        this._liveChIdx = 0;
        document.querySelectorAll('.live-mode-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.live-mode-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                this._liveMode = btn.dataset.lmode;
                this._renderLiveContent();
            });
        });
        document.getElementById('live-chapter-select').addEventListener('change', e => {
            this._liveChIdx = parseInt(e.target.value) || 0;
            this._renderLiveContent();
        });
        document.getElementById('btn-live-prev').addEventListener('click', () => {
            if (this._liveChIdx > 0) {
                this._liveChIdx--;
                document.getElementById('live-chapter-select').value = this._liveChIdx;
                this._renderLiveContent();
            }
        });
        document.getElementById('btn-live-next').addEventListener('click', () => {
            const total = this.chapters ? this.chapters.length : 0;
            if (this._liveChIdx < total - 1) {
                this._liveChIdx++;
                document.getElementById('live-chapter-select').value = this._liveChIdx;
                this._renderLiveContent();
            }
        });
        document.getElementById('btn-live-to-work').addEventListener('click', () => {
            document.querySelectorAll('.wtab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.wpanel').forEach(p => p.classList.remove('active'));
            document.querySelector('.wtab[data-tab="translation"]').classList.add('active');
            document.getElementById('panel-translation').classList.add('active');
        });
    }

    /* ── 边翻边读渲染 ── */
    _ensureLiveReaderData() {
        // 如果chapters没加载，从当前书籍加载
        if (!this.chapters || this.chapters.length === 0) {
            const book = this._getBook(this.currentBookId);
            if (book) {
                this.chapters = Utils.loadLocal(`chapters-${book.id}`, []);
                this.translationResults = Utils.loadLocal(`results-${book.id}`, []);
            }
        }
        this._initLiveReader();
    }
    
    _initLiveReader() {
        if (!this.chapters || this.chapters.length === 0) return;
        const sel = document.getElementById('live-chapter-select');
        sel.innerHTML = this.chapters.map((ch, i) => 
            `<option value="${i}">${Utils.escapeHtml(ch.title || ('第' + (i + 1) + '章'))}</option>`
        ).join('');
        sel.value = this._liveChIdx || 0;
        this._renderLiveContent();
    }

    _renderLiveContent() {
        if (!this.chapters || this.chapters.length === 0) return;
        const chIdx = this._liveChIdx || 0;
        const chapter = this.chapters[chIdx];
        const translatedChapter = this.translationResults[chIdx] || { sentences: [] };
        const translatedSentences = translatedChapter.sentences || [];

        document.getElementById('live-chapter-title').textContent = chapter.title || ('第' + (chIdx + 1) + '章');
        document.getElementById('live-ch-indicator').textContent = (chIdx + 1) + '/' + this.chapters.length;

        const mode = this._liveMode || 'translated';
        let html = '';
        for (let i = 0; i < chapter.sentences.length; i++) {
            const src = chapter.sentences[i];
            const translated = translatedSentences[i];
            const tgt = translated ? translated.translation : null;

            if (mode === 'translated') {
                if (tgt) {
                    html += `<div class="live-para"><div class="live-tgt">${Utils.escapeHtml(tgt)}</div></div>`;
                } else {
                    html += `<div class="live-para"><div class="live-pending">${Utils.escapeHtml(src)}</div></div>`;
                }
            } else if (mode === 'bilingual') {
                if (tgt) {
                    html += `<div class="live-para"><div class="live-tgt">${Utils.escapeHtml(tgt)}</div><div class="live-src">${Utils.escapeHtml(src)}</div></div>`;
                } else {
                    html += `<div class="live-para"><div class="live-pending">${Utils.escapeHtml(src)}</div></div>`;
                }
            } else {
                html += `<div class="live-para"><div class="live-tgt">${Utils.escapeHtml(src)}</div></div>`;
            }
        }
        document.getElementById('live-content').innerHTML = html;

        // 更新进度显示
        const totalSent = this.chapters.reduce((s, c) => s + c.sentences.length, 0);
        const completed = this._countResultSentences(this.translationResults);
        const pct = totalSent > 0 ? Math.round(completed / totalSent * 100) : 0;
        document.getElementById('live-progress-text').textContent = pct + '%';
    }

    _updateLiveReaderOnProgress() {
        // 如果当前在阅读面板且有实时更新需要渲染
        const panel = document.getElementById('panel-reading');
        if (panel && panel.classList.contains('active')) {
            this._renderLiveContent();
        }
    }
    
    _updateApiLog(d) {
        const logEl = document.getElementById('live-api-log');
        const statusEl = document.getElementById('live-api-status');
        if (!logEl || !statusEl) return;
        
        logEl.style.display = 'block';
        const time = new Date().toLocaleTimeString();
        
        if (d.status === 'requesting') {
            statusEl.innerHTML = `<span style="color:var(--accent)">[${time}] 🔄 正在请求API... (${d.batch}句)</span>`;
        } else if (d.status === 'received') {
            const preview = Utils.escapeHtml(d.content || '');
            statusEl.innerHTML = `<span style="color:var(--text-secondary)">[${time}] ✅ 收到响应:</span><br><code style="font-size:0.7rem;word-break:break-all;color:var(--text-dim)">${preview}</code>`;
            logEl.scrollTop = logEl.scrollHeight;
        }
    }

    /* ── 沉浸式阅读器 ── */
    _openReader(book) {
        this.currentBookId = book.id;
        this._rdBook = book;
        this._rdChIdx = 0;
        const p = Utils.loadLocal('rd-prefs', {fs:18,lh:1.8,theme:'light',mode:'translated'});
        this._rdPrefs = p;
        this._rdMode = p.mode||'translated';
        const pg = document.getElementById('page-reader');
        pg.setAttribute('data-theme', p.theme||'light');
        pg.style.setProperty('--rd-fs', p.fs+'px');
        pg.style.setProperty('--rd-lh', p.lh);
        document.getElementById('reader-title').textContent = book.fileName;
        document.getElementById('rd-font-val').textContent = p.fs;
        document.getElementById('rd-lh-val').textContent = p.lh;
        document.querySelectorAll('.rd-mode-btn').forEach(b=>b.classList.toggle('active',b.dataset.rmode===this._rdMode));
        document.querySelectorAll('.rd-theme-dot').forEach(b=>b.classList.toggle('active',b.dataset.rtheme===(p.theme||'light')));
        this._updateThemeLabel();
        this._applyFont(p.font || 'serif');
        this._renderToc();
        this._goChapter(0);
        this._showPage('reader');
        // 关闭面板
        document.getElementById('rd-display-panel').classList.add('hidden');
        document.getElementById('rd-toc-overlay').classList.add('hidden');
        // 显示进度徽章
        this._updateReaderProgressBadge(book);
        // 如果是翻译中/暂停的书，需要恢复引擎状态
        if (book.status === 'translating' || book.status === 'paused') {
            this._prepareReaderEngine(book);
        }
        // 默认隐藏顶栏底栏，实现全屏沉浸式阅读
        document.getElementById('rd-topbar').classList.add('hid');
        document.getElementById('rd-bottombar').classList.add('hid');
    }
    _updateReaderProgressBadge(book) {
        const badge = document.getElementById('rd-progress-badge');
        const liveBtn = document.getElementById('btn-reader-live');
        if (!badge) return;
        const pct = book.total > 0 ? Math.round(book.completed / book.total * 100) : 0;
        const isComplete = book.status === 'completed' || pct >= 100;
        badge.textContent = isComplete ? '已完成' : pct + '%';
        badge.classList.toggle('complete', isComplete);
        badge.classList.toggle('hidden', false);
        // 翻译中/暂停时显示实况按钮
        if (liveBtn) {
            liveBtn.style.display = (book.status === 'translating' || book.status === 'paused') ? '' : 'none';
        }
    }
    _prepareReaderEngine(book) {
        // 加载数据以便切换到实况时使用
        this.chapters = book.chapters || [];
        this.translationResults = this._cloneResults(book.results || []);
        this.fileName = book.fileName;
    }
    _fontMap = {
        serif:"'Noto Serif SC',Georgia,serif",
        sans:"'Noto Sans SC','PingFang SC','Microsoft YaHei',sans-serif",
        wenkai:"'LXGW WenKai Screen',cursive",
        xiaowei:"'ZCOOL XiaoWei',serif",
        kuaile:"'ZCOOL KuaiLe',cursive",
        qingke:"'ZCOOL QingKe HuangYou',cursive",
        liujian:"'Liu Jian Mao Cao',cursive",
        zhimang:"'Zhi Mang Xing',cursive",
        mashanzheng:"'Ma Shan Zheng',cursive",
        longcang:"'Long Cang',cursive",
        system:"system-ui,-apple-system,'Segoe UI','Noto Sans SC',sans-serif",
    };
    _saveRdPrefs(){Utils.saveLocal('rd-prefs',this._rdPrefs);}
    _applyFont(fontKey){
        const ff = this._fontMap[fontKey] || this._fontMap.serif;
        document.getElementById('page-reader').style.setProperty('--rd-ff', ff);
        document.getElementById('rd-content').style.fontFamily = ff;
        document.querySelectorAll('.rd-font-btn').forEach(b=>b.classList.toggle('active',b.dataset.rfont===fontKey));
    }
    _updateThemeLabel(){
        const t=this._rdPrefs.theme||'light';
        const dark=t==='dark'||t==='black';
        document.getElementById('rd-theme-label').textContent=dark?'日间':'夜间';
        document.querySelector('#btn-rd-theme .rd-tool-icon').textContent=dark?'☀️':'🌙';
    }
    _renderToc(){
        const b=this._rdBook; if(!b)return;
        const chapters = this._getReaderChapters(b);
        if(!chapters.length) return;
        document.getElementById('rd-toc-list').innerHTML=chapters.map((ch,i)=>
            `<button class="rd-toc-item${i===this._rdChIdx?' active':''}" data-ch="${i}">${Utils.escapeHtml(ch.title||'第'+(i+1)+'章')}</button>`
        ).join('');
    }
    _getReaderChapters(book) {
        // 如果有完整results则用results，否则用chapters构建
        if (book.results && book.results.length > 0) {
            // 合并chapters和results的数据
            return book.results.map((r, i) => {
                const chap = book.chapters && book.chapters[i];
                const sentences = r.sentences || [];
                // 如果results的sentences不完整，用chapters补充
                if (chap && chap.sentences && sentences.length < chap.sentences.length) {
                    const merged = [];
                    for (let j = 0; j < chap.sentences.length; j++) {
                        merged.push(sentences[j] || { original: chap.sentences[j], translation: '' });
                    }
                    return { title: r.title || chap.title, sentences: merged };
                }
                return r;
            });
        }
        if (book.chapters && book.chapters.length > 0) {
            return book.chapters.map(ch => ({
                title: ch.title,
                sentences: (ch.sentences || []).map(s => ({ original: s, translation: '' }))
            }));
        }
        return [];
    }
    _goChapter(idx){
        const b=this._rdBook; if(!b)return;
        const chapters = this._getReaderChapters(b);
        const total=chapters.length;
        if(idx<0||idx>=total)return;
        this._rdChIdx=idx;
        const ch=chapters[idx];
        document.getElementById('rd-chapter-title').textContent=ch.title||'第'+(idx+1)+'章';
        document.getElementById('rd-ch-ind').textContent=(idx+1)+'/'+total;
        document.getElementById('rd-progress-fill').style.width=Math.round((idx+1)/total*100)+'%';
        this._renderChContent(ch);
        document.getElementById('rd-content').scrollTop=0;
        this._renderToc();
    }
    _renderChContent(ch){
        const body=document.getElementById('reader-body');
        const m=this._rdMode; let h='';
        for(const s of ch.sentences){
            const hasTrans = s.translation && s.translation.trim();
            const noteHtml = s.note ? `<div class="reader-note">📝 ${Utils.escapeHtml(s.note)}</div>` : '';
            if(m==='bilingual') {
                if(hasTrans) h+=`<div class="reader-para"><div class="reader-tgt">${Utils.escapeHtml(s.translation)}</div>${noteHtml}<div class="reader-src">${Utils.escapeHtml(s.original)}</div></div>`;
                else h+=`<div class="reader-para"><div class="reader-pending">${Utils.escapeHtml(s.original)}</div></div>`;
            } else if(m==='translated') {
                if(hasTrans) h+=`<div class="reader-para"><div class="reader-tgt">${Utils.escapeHtml(s.translation)}</div>${noteHtml}</div>`;
                else h+=`<div class="reader-para"><div class="reader-pending">${Utils.escapeHtml(s.original)}</div></div>`;
            } else {
                h+=`<div class="reader-para"><div class="reader-src" style="opacity:1;color:var(--rd-text)">${Utils.escapeHtml(s.original)}</div></div>`;
            }
        }
        body.innerHTML=h;
    }
    _bindReader() {
