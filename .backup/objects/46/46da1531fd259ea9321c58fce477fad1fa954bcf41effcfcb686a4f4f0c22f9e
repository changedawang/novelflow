    _applyFont(fontKey){
        const ff = this._fontMap[fontKey] || this._fontMap.serif;
        document.getElementById('page-reader').style.setProperty('--rd-ff', ff);
        document.getElementById('rd-content').style.fontFamily = ff;
        document.querySelectorAll('.rd-font-btn').forEach(b=>b.classList.toggle('active',b.dataset.rfont===fontKey));
    }
    _updateThemeLabel(){
        const t=this._rdPrefs.theme||'light';
        const dark=t==='dark'||t==='black';
        document.getElementById('rd-theme-label').textContent=dark?'日间':'夜间';
        document.querySelector('#btn-rd-theme .rd-tool-icon').textContent=dark?'☀️':'🌙';
    }
    _renderToc(){
        const b=this._rdBook; if(!b)return;
        const chapters = this._getReaderChapters(b);
        if(!chapters.length) return;
        document.getElementById('rd-toc-list').innerHTML=chapters.map((ch,i)=>
            `<button class="rd-toc-item${i===this._rdChIdx?' active':''}" data-ch="${i}">${Utils.escapeHtml(ch.title||'第'+(i+1)+'章')}</button>`
        ).join('');
    }
    _getReaderChapters(book) {
        if (book.results && book.results.length > 0) {
            const baseChapters = book.chapters || [];
            const total = Math.max(baseChapters.length, book.results.length);
            return Array.from({ length: total }, (_, i) => {
                const chap = baseChapters[i];
                const resultChapter = book.results[i] || {};
                const sentences = Array.isArray(resultChapter.sentences) ? resultChapter.sentences : [];

                if (chap && Array.isArray(chap.sentences) && sentences.length < chap.sentences.length) {
                    const merged = [];
                    for (let j = 0; j < chap.sentences.length; j++) {
                        merged.push(sentences[j] || { original: chap.sentences[j], translation: '' });
                    }
                    return {
                        title: resultChapter.title || chap.title || ('第' + (i + 1) + '章'),
                        sentences: merged
                    };
                }

                return {
                    title: resultChapter.title || (chap && chap.title) || ('第' + (i + 1) + '章'),
                    sentences: sentences
                };
            });
        }

        if (book.chapters && book.chapters.length > 0) {
            return book.chapters.map(ch => ({
                title: ch.title,
                sentences: (ch.sentences || []).map(s => ({ original: s, translation: '' }))
            }));
        }

        return [];
    }
    _goChapter(idx){
        const b=this._rdBook; if(!b)return;
        const chapters = this._getReaderChapters(b);
        const total=chapters.length;
        if(idx<0||idx>=total)return;
        this._rdChIdx=idx;
        const ch=chapters[idx];
        document.getElementById('rd-chapter-title').textContent=ch.title||'第'+(idx+1)+'章';
        document.getElementById('rd-ch-ind').textContent=(idx+1)+'/'+total;
        document.getElementById('rd-progress-fill').style.width=Math.round((idx+1)/total*100)+'%';
        this._renderChContent(ch);
// 恢复滚动位置或重置
const rdContent = document.getElementById('rd-content');
if(this._rdScrollTop && this._rdScrollTop > 0) {
    setTimeout(() => { rdContent.scrollTop = this._rdScrollTop; this._rdScrollTop = 0; }, 50);
} else {
    rdContent.scrollTop = 0;
}
this._renderToc();
// 保存阅读进度
this._saveReadingProgress();
    }
    _renderChContent(ch){
const body=document.getElementById('reader-body');
const m=this._rdMode; let h='';
for(let i=0; i<ch.sentences.length; i++){
const s = ch.sentences[i];
const hasTrans = s.translation && s.translation.trim();
const noteHtml = s.note ? `<div class="reader-note">📝 ${Utils.escapeHtml(s.note)}</div>` : '';
const actionsHtml = `<div class="reader-actions" data-idx="${i}">
    <button class="ra-btn ra-ask" title="问AI">💬</button>
    ${hasTrans ? `<button class="ra-btn ra-retrans" title="重新翻译">🔄</button>` : ''}
</div>`;
if(m==='bilingual') {
    if(hasTrans) h+=`<div class="reader-para" data-idx="${i}"><div class="reader-tgt">${Utils.escapeHtml(s.translation)}</div>${noteHtml}<div class="reader-src">${Utils.escapeHtml(s.original)}</div>${actionsHtml}</div>`;
    else h+=`<div class="reader-para" data-idx="${i}"><div class="reader-pending">${Utils.escapeHtml(s.original)}</div>${actionsHtml}</div>`;
} else if(m==='translated') {
    if(hasTrans) h+=`<div class="reader-para" data-idx="${i}"><div class="reader-tgt">${Utils.escapeHtml(s.translation)}</div>${noteHtml}${actionsHtml}</div>`;
    else h+=`<div class="reader-para" data-idx="${i}"><div class="reader-pending">${Utils.escapeHtml(s.original)}</div>${actionsHtml}</div>`;
} else {
    h+=`<div class="reader-para" data-idx="${i}"><div class="reader-src" style="opacity:1;color:var(--rd-text)">${Utils.escapeHtml(s.original)}</div>${actionsHtml}</div>`;
}
}
body.innerHTML=h;
this._bindReaderActions();
}

