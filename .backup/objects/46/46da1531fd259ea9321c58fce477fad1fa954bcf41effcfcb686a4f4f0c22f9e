        const books = this._getBooks();
        const exportData = {
            version: 1,
            exportedAt: new Date().toISOString(),
            settings: this.settings,
            books: books,
            bookData: {}
        };
        // 导出每本书的详细数据
        for(const book of books) {
            exportData.bookData[book.id] = {
                chapters: Utils.loadLocal(`chapters-${book.id}`, []),
                results: Utils.loadLocal(`results-${book.id}`, []),
                progress: Utils.loadLocal(`rd-progress-${book.id}`, null)
            };
        }
        exportData.rdPrefs = Utils.loadLocal('rd-prefs', {});
        const json = JSON.stringify(exportData, null, 2);
        const filename = `NovelFlow_backup_${new Date().toISOString().slice(0,10)}.json`;
        Utils.downloadFile(json, filename, 'application/json');
        alert('✅ 数据导出成功！');
    }

    _importAllData() {
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = '.json';
        input.addEventListener('change', () => {
            if(!input.files[0]) return;
            const reader = new FileReader();
            reader.onload = () => {
                try {
                    const data = JSON.parse(reader.result);
                    if(!data.version || !data.books) {
                        alert('❌ 无效的备份文件');
                        return;
                    }
                    if(!confirm(`确定导入？将覆盖当前数据！\n包含 ${data.books.length} 本书籍`)) return;
                    // 导入设置
                    if(data.settings) {
                        Utils.saveLocal('settings', data.settings);
                        this.settings = data.settings;
                    }
                    // 导入书籍列表
                    Utils.saveLocal('books', data.books);
                    // 导入每本书的数据
                    if(data.bookData) {
                        for(const bookId in data.bookData) {
                            const bd = data.bookData[bookId];
                            if(bd.chapters) Utils.saveLocal(`chapters-${bookId}`, bd.chapters);
                            if(bd.results) Utils.saveLocal(`results-${bookId}`, bd.results);
                            if(bd.progress) Utils.saveLocal(`rd-progress-${bookId}`, bd.progress);
                        }
                    }
                    if(data.rdPrefs) Utils.saveLocal('rd-prefs', data.rdPrefs);
                    alert('✅ 数据导入成功！页面将刷新...');
                    location.reload();
                } catch(e) {
                    console.error('导入失败:', e);
                    alert('❌ 导入失败：' + e.message);
                }
            };
            reader.readAsText(input.files[0]);
        });
        input.click();
    }
} /* end UIController */
