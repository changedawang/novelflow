async _openAskAIModal(sentIdx){
const chapters = this._getReaderChapters(this._rdBook);
const ch = chapters[this._rdChIdx];
if(!ch || !ch.sentences[sentIdx]) return;
const s = ch.sentences[sentIdx];
const quote = s.translation || s.original;

const question = prompt(`引用内容：\n"${quote}"\n\n请输入你的问题：`);
if(!question || !question.trim()) return;

// 构建上下文
const contextSents = ch.sentences.slice(Math.max(0,sentIdx-3), sentIdx+4).map(x=>x.translation||x.original).join('\n');
const prompt_text = `【引用段落】\n${quote}\n\n【上下文】\n${contextSents}\n\n【用户问题】\n${question}\n\n请结合上下文和你的知识，简洁回答用户问题。`;

try {
    const adapter = this._createLLMAdapter();
    const res = await adapter.chat([{role:'user', content:prompt_text}], {temperature:0.5, maxTokens:500});
    alert(`💬 AI回答：\n\n${res.content}`);
} catch(e) {
    alert('请求失败：' + e.message);
}
}

async _retranslateSentence(sentIdx){
if(!confirm('确定重新翻译这句话？')) return;
const chapters = this._getReaderChapters(this._rdBook);
const ch = chapters[this._rdChIdx];
if(!ch || !ch.sentences[sentIdx]) return;
const s = ch.sentences[sentIdx];
const original = s.original;

try {
    const adapter = this._createLLMAdapter();
    const prompt_text = `将以下句子翻译为${this._rdBook.targetLang || '简体中文'}，只输出译文：\n${original}`;
    const res = await adapter.chat([{role:'user', content:prompt_text}], {temperature:0.3, maxTokens:200});
    const newTrans = res.content.trim();
    
    // 更新数据
    const results = Utils.loadLocal(`results-${this._rdBook.id}`, []);
    if(results[this._rdChIdx] && results[this._rdChIdx].sentences[sentIdx]) {
        results[this._rdChIdx].sentences[sentIdx].translation = newTrans;
        Utils.saveLocal(`results-${this._rdBook.id}`, results);
        // 刷新显示
        this._rdBook.results = results;
        this._goChapter(this._rdChIdx);
        alert('✅ 重新翻译完成');
    }
} catch(e) {
    alert('翻译失败：' + e.message);
}
}

_createLLMAdapter(){
const s = this.settings;
const urls = {'deepseek':'https://api.deepseek.com/v1','openai':'https://api.openai.com/v1'};
const baseUrl = s.provider==='custom' ? s.baseUrl : (urls[s.provider]||urls['deepseek']);
return new LLMAdapter({apiKey:s.apiKeys[0], baseUrl, provider:s.provider, model:s.model});
}
