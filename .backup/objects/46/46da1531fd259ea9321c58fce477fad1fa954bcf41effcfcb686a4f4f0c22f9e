/* NovelFlow — UI Controller v4 书架版 */
class UIController {

    constructor() {
        this.pages = { shelf:'page-shelf', upload:'page-upload', config:'page-config', work:'page-work', reader:'page-reader' };
        this.currentPage = 'shelf';
        this.engine = null;
        this.chapters = null;
        this.fileName = '';
        this.currentBookId = null;
        this.translationResults = [];
        this._autoScroll = true;
        this._workRows = [];
        this._engineChapterMap = [];
        this._progressOffset = 0;
        this._summaryChapterOffset = 0;
        this._engineRunId = 0;
        this._isOptimizeMode = false;
        this._optimizing = false;
        this._optimizePaused = false;
        this._optimizeQueue = [];
        this._optimizeCurrentIdx = 0;
        this._optimizeBookId = null;
        this._optimizeResumeResolve = null;
        this._optimizeReturnChIdx = null;
        this._autoOptimizeQueue = [];
        this._autoOptimizeRunning = false;
        this._autoOptimizeEngine = null;
        this._autoOptimizeCurrent = null;
        this._logCount = 0;
        this._init();
    }

    /* ── 初始化 ── */
_init() {
this._loadSettings();
this._ensureSampleBook();
this._bindNav();
this._bindUpload();
this._bindConfig();
this._bindWork();
this._bindReader();
this._bindModals();
this._renderShelf();
// 页面加载时恢复翻译中的任务
this._autoResumeTranslation();
// 页面隐藏/关闭时保存进度
this._bindVisibilityChange();
}

/* ── 自动恢复翻译 ── */
_autoResumeTranslation() {
const books = this._getBooks();
const translatingBook = books.find(b => b.status === 'translating');
if (translatingBook) {
// 有未完成的翻译任务，询问是否恢复
setTimeout(() => {
    if (confirm(`发现未完成的翻译任务：${translatingBook.fileName}\n是否继续翻译？`)) {
        this._resumeBook(translatingBook);
    }
}, 500);
}
}

/* ── 页面可见性监听 ── */
_bindVisibilityChange() {
// 页面隐藏时保存进度
document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
        this._saveCurrentProgress();
    }
});
// 页面关闭前保存
window.addEventListener('beforeunload', () => {
    this._saveCurrentProgress();
});
// 页面重新可见时，如果有翻译任务且引擎停止了，自动恢复
document.addEventListener('visibilitychange', () => {
    if (!document.hidden && this.currentBookId) {
        const book = this._getBook(this.currentBookId);
        if (book && book.status === 'translating' && (!this.engine || this.engine._cancelled)) {
            this._resumeBook(book);
        }
    }
});
}

_saveCurrentProgress() {
// 保存翻译进度
if (this.engine && this.currentBookId) {
    this._saveProgress(null);
}
// 保存阅读进度
if (this._rdBook) {
    this._saveReadingProgress();
}
}

    /* ── 页面切换 ── */
    _showPage(name) {
        Object.values(this.pages).forEach(id => document.getElementById(id).classList.add('hidden'));
        document.getElementById(this.pages[name]).classList.remove('hidden');
        this.currentPage = name;
    }

    /* ── localStorage 书籍数据 ── */
    _getBooks() { return Utils.loadLocal('books', []); }
    _saveBooks(books) { Utils.saveLocal('books', books); }
    _getBook(id) { return this._getBooks().find(b => b.id === id); }
    _saveBook(book) {
        const books = this._getBooks();
        const idx = books.findIndex(b => b.id === book.id);
        if (idx >= 0) books[idx] = book; else books.unshift(book);
        this._saveBooks(books);
    }
    _deleteBook(id) { this._saveBooks(this._getBooks().filter(b => b.id !== id)); }

    /* ── 书架渲染 ── */
    _renderShelf() {
        const books = this._getBooks();
        const grid = document.getElementById('shelf-grid');
        const empty = document.getElementById('shelf-empty');
        if (books.length === 0) { empty.classList.remove('hidden'); grid.innerHTML = ''; return; }
        empty.classList.add('hidden');
        const emojis = ['📕','📗','📘','📙','📓','📔','📒'];
        grid.innerHTML = books.map((b, i) => {
            const pct = b.total > 0 ? Math.round(b.completed / b.total * 100) : 0;
            const emoji = emojis[i % emojis.length];
            const status = b.status || 'completed';
            const statusLabel = {translating:'翻译中',paused:'已暂停',completed:'已完成',cancelled:'已取消'}[status] || status;
            const date = b.updatedAt ? new Date(b.updatedAt).toLocaleDateString() : '';
            return `<div class="book-card" data-id="${b.id}">
                <button class="book-delete" data-del="${b.id}" title="删除">✕</button>
                <div class="book-card-inner">
                    <div class="book-emoji">${emoji}</div>
                    <div class="book-title">${Utils.escapeHtml(b.fileName || '未命名')}</div>
                    <div class="book-lang">→ ${Utils.escapeHtml(b.targetLang || '简体中文')}</div>
                    <div class="book-progress">
                        <div class="book-progress-bar"><div class="book-progress-fill ${pct>=100?'complete':''}" style="width:${pct}%"></div></div>
                        <div class="book-meta">
                            <span class="book-status s-${status}">${statusLabel} ${pct}%</span>
                            <span class="book-date">${date}</span>
                        </div>
                    </div>
                </div>
            </div>`;
        }).join('');
        grid.querySelectorAll('.book-card').forEach(card => {
            card.addEventListener('click', e => {
                if (e.target.classList.contains('book-delete')) return;
                this._openBook(card.dataset.id);
            });
        });
        grid.querySelectorAll('.book-delete').forEach(btn => {
            btn.addEventListener('click', e => {
                e.stopPropagation();
                if (confirm('确定删除这本书？')) { this._deleteBook(btn.dataset.del); this._renderShelf(); }
            });
        });
    }

    _openBook(id) {
const book = this._getBook(id);
if (!book) return;
// 总是先进入阅读器，翻译中的书可通过右上角按钮切换到实况
this._openReader(book);
}

    /* ── 导航绑定 ── */
    _bindNav() {
        document.getElementById('btn-new-book').addEventListener('click', () => this._showPage('upload'));
        document.getElementById('btn-back-shelf').addEventListener('click', () => { this._showPage('shelf'); this._renderShelf(); });
        document.getElementById('btn-back-upload').addEventListener('click', () => this._showPage('upload'));
        document.getElementById('btn-back-shelf2').addEventListener('click', () => { this._showPage('shelf'); this._renderShelf(); });
        document.getElementById('btn-settings').addEventListener('click', () => this._openSettingsModal());
    }

    /* ── 设置 ── */
    _getDefaultModel(provider) {
        return provider === 'deepseek' ? 'deepseek-chat' : (provider === 'openai' ? 'gpt-4o-mini' : '');
    }
    _sanitizeModelValue(model) {
        const value = model === undefined || model === null ? '' : String(model).trim();
        if (!value) return '';
        const lower = value.toLowerCase();
        return (lower === 'undefined' || lower === '' || lower === 'nan') ? '' : value;
    }
    _getEffectiveModel(provider, model) {
        return this._sanitizeModelValue(model) || this._getDefaultModel(provider);
    }
    _ensureSettingsModel() {
        const provider = (this.settings && this.settings.provider) || 'deepseek';
        const model = this._getEffectiveModel(provider, this.settings ? this.settings.model : '');
        if (this.settings && this.settings.model !== model) {
            this.settings.model = model;
            Utils.saveLocal('settings', this.settings);
        }
        return model;
    }
    _loadSettings() {
        const raw = Utils.loadLocal('settings', {
            provider:'deepseek',
            apiKeys:[],
            baseUrl:'',
            model:'deepseek-chat',
            reasoning:'balanced',
            temperature:0.3,
            maxTokens:1024,
            batchSize:30,
            autoOptimize:false,
            translationReasoningEffort:'medium',
            optimizeReasoningEffort:'high',
            enableReasoningTrace:true,
            streamReasoningTrace:true
        });
        // 兼容旧版单key
        if (raw.apiKey && (!raw.apiKeys || raw.apiKeys.length === 0)) {
            raw.apiKeys = [raw.apiKey]; delete raw.apiKey;
        }
        raw.provider = raw.provider || 'deepseek';
        raw.model = this._getEffectiveModel(raw.provider, raw.model);
        if (!raw.reasoning) raw.reasoning = 'balanced';
        if (!raw.batchSize) raw.batchSize = 30;
        if (!['low', 'medium', 'high'].includes(String(raw.translationReasoningEffort || '').toLowerCase())) raw.translationReasoningEffort = 'medium';
        if (!['low', 'medium', 'high'].includes(String(raw.optimizeReasoningEffort || '').toLowerCase())) raw.optimizeReasoningEffort = 'high';
        if (raw.enableReasoningTrace === undefined) raw.enableReasoningTrace = true;
        if (raw.streamReasoningTrace === undefined) raw.streamReasoningTrace = raw.enableReasoningTrace !== false;
        this.settings = raw;
    }
    _openSettingsModal() {
        const s = this.settings;
        const provider = s.provider || 'deepseek';
        const modelInput = document.getElementById('api-model');
        const modelSelect = document.getElementById('api-model-select');
        document.getElementById('api-provider').value = provider;
        const keysTA = document.getElementById('api-keys');
        keysTA.value = (s.apiKeys || []).join('\n');
        this._updateKeyCountHint();
        document.getElementById('api-base-url').value = s.baseUrl || '';
        modelInput.value = this._sanitizeModelValue(s.model) || this._getDefaultModel(provider);
        modelInput.style.display = '';
        modelSelect.style.display = 'none';
        modelSelect.innerHTML = '';
        document.getElementById('btn-fetch-models').textContent = '📡 获取模型';
        document.getElementById('model-fetch-hint').style.display = 'none';
        document.getElementById('api-reasoning').value = s.reasoning || 'balanced';
        document.getElementById('api-temp').value = s.temperature || 0.3;
        document.getElementById('api-max-tokens').value = s.maxTokens || 1024;
        document.getElementById('batch-size').value = s.batchSize || 30;
        document.getElementById('batch-size-val').textContent = s.batchSize || 30;
        document.getElementById('auto-optimize').checked = !!s.autoOptimize;
        document.getElementById('api-translate-reasoning-effort').value = s.translationReasoningEffort || 'medium';
        document.getElementById('api-optimize-reasoning-effort').value = s.optimizeReasoningEffort || 'high';
        document.getElementById('api-show-reasoning').checked = s.enableReasoningTrace !== false;
        this._toggleCustomUrl();
        this._toggleCustomTemp();
        document.getElementById('modal-settings').classList.remove('hidden');
    }
    _toggleCustomTemp() {
        const r = document.getElementById('api-reasoning').value;
        document.getElementById('custom-temp-group').style.display = r === 'custom' ? '' : 'none';
    }
    _updateKeyCountHint() {
        const keys = document.getElementById('api-keys').value.split('\n').filter(k => k.trim());
        document.getElementById('key-count-hint').textContent = keys.length + ' 个密钥';
    }
    _reasoningToTemp(reasoning) {
        const map = { precise:0.1, balanced:0.3, creative:0.6, wild:0.9 };
        return map[reasoning] !== undefined ? map[reasoning] : null;
    }
    _toggleCustomUrl() {
        const p = document.getElementById('api-provider').value;
        document.getElementById('custom-url-group').classList.toggle('hidden', p !== 'custom');
    }

    /* ── 上传绑定 ── */
    _bindUpload() {
        const area = document.getElementById('upload-area');
        const input = document.getElementById('file-input');
        document.getElementById('btn-choose-file').addEventListener('click', e => { e.stopPropagation(); input.click(); });
        area.addEventListener('click', () => input.click());
        area.addEventListener('dragover', e => { e.preventDefault(); area.classList.add('dragover'); });
        area.addEventListener('dragleave', () => area.classList.remove('dragover'));
        area.addEventListener('drop', e => { e.preventDefault(); area.classList.remove('dragover'); if(e.dataTransfer.files[0]) this._handleFile(e.dataTransfer.files[0]); });
        input.addEventListener('change', () => { if(input.files[0]) this._handleFile(input.files[0]); input.value=''; });
        document.getElementById('btn-demo').addEventListener('click', e => { e.stopPropagation(); this._loadDemo(); });
    }
    async _handleFile(file) {
        const hint = document.getElementById('upload-format-hint');
        const ext = file.name.split('.').pop().toLowerCase();
        const formatNames = { epub:'EPUB电子书', html:'HTML网页', htm:'HTML网页', md:'Markdown', markdown:'Markdown', docx:'Word文档', txt:'纯文本' };
        hint.textContent = `⏳ 正在解析 ${formatNames[ext] || ext} 文件...`;
        hint.style.color = 'var(--text-dim)';
        try {
            const splitter = new TextSplitter();
            const result = await splitter.parseFile(file);
            this.fileName = result.fileName;
            this.chapters = result.chapters;
            hint.textContent = `✅ ${formatNames[ext]||ext} 解析完成：${result.chapters.length} 章`;
            hint.style.color = '#2a7';
            this._showParsedConfig(result.chapters);
        } catch(e) {
            hint.textContent = `❌ 解析失败：${e.message}`;
            hint.style.color = '#c00';
            console.error('文件解析错误:', e);
        }
    }
