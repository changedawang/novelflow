/**
 * NovelFlow — UI Controller v2
 * 适配现有 TranslationEngine / GlossaryManager / TextSplitter / LLMAdapter / Utils API
 */
class UIController {
    constructor() {
        this.engine = null;
        this.splitter = new TextSplitter();
        this.chapters = [];
        this.fileName = '';
        this.rawText = '';
        this._isPaused = false;

        this._cacheDOM();
        this._bindEvents();
        this._loadSettings();
    }

    _cacheDOM() {
        this.$upload = document.getElementById('phase-upload');
        this.$preview = document.getElementById('phase-preview');
        this.$translate = document.getElementById('phase-translate');
        this.$uploadArea = document.getElementById('upload-area');
        this.$fileInput = document.getElementById('file-input');
        this.$btnChoose = document.getElementById('btn-choose-file');
        this.$btnDemo = document.getElementById('btn-demo');
        this.$fileName = document.getElementById('file-name');
        this.$previewText = document.getElementById('preview-text');
        this.$statChars = document.getElementById('stat-chars');
        this.$statSentences = document.getElementById('stat-sentences');
        this.$statChapters = document.getElementById('stat-chapters');
        this.$statTokens = document.getElementById('stat-tokens');
        this.$btnReUpload = document.getElementById('btn-re-upload');
        this.$btnStart = document.getElementById('btn-start');
        this.$targetLang = document.getElementById('target-lang');
        this.$contextWindow = document.getElementById('context-window');
        this.$autoGlossary = document.getElementById('auto-glossary');
        this.$autoStyle = document.getElementById('auto-style');
        this.$statusBar = document.getElementById('status-bar');
        this.$statusPhase = document.getElementById('status-phase');
        this.$statusDetail = document.getElementById('status-detail');
        this.$statusTokens = document.getElementById('status-tokens');
        this.$progressFill = document.getElementById('progress-fill');
        this.$progressLabel = document.getElementById('progress-label');
        this.$progressPercent = document.getElementById('progress-percent');
        this.$btnPause = document.getElementById('btn-pause');
        this.$btnCancel = document.getElementById('btn-cancel');
        this.$sourceList = document.getElementById('source-list');
        this.$targetList = document.getElementById('target-list');
        this.$pauseAlert = document.getElementById('pause-alert');
        this.$btnResumeAlert = document.getElementById('btn-resume-alert');
        this.$completeBanner = document.getElementById('complete-banner');
        this.$completeSummary = document.getElementById('complete-summary');
        this.$btnExportComplete = document.getElementById('btn-export-complete');
        this.$btnNewTask = document.getElementById('btn-new-task');
        this.$glossaryCount = document.getElementById('glossary-count');
        this.$glossaryBody = document.getElementById('glossary-body');
        this.$glossarySearch = document.getElementById('glossary-search');
        this.$styleContent = document.getElementById('style-content');
        this.$summaryContent = document.getElementById('summary-content');
        this.$btnSettings = document.getElementById('btn-settings');
        this.$btnExport = document.getElementById('btn-export');
        this.$modalSettings = document.getElementById('modal-settings');
        this.$modalAddTerm = document.getElementById('modal-add-term');
        this.$modalExport = document.getElementById('modal-export');
        this.$apiProvider = document.getElementById('api-provider');
        this.$apiKey = document.getElementById('api-key');
        this.$apiBaseUrl = document.getElementById('api-base-url');
        this.$customUrlGroup = document.getElementById('custom-url-group');
        this.$apiModel = document.getElementById('api-model');
        this.$apiTemp = document.getElementById('api-temperature');
        this.$apiMaxTokens = document.getElementById('api-max-tokens');
    }

    _bindEvents() {
        this.$btnChoose.onclick = () => this.$fileInput.click();
        this.$fileInput.onchange = (e) => this._handleFile(e.target.files[0]);
        this.$btnDemo.onclick = () => this._loadDemo();

        this.$uploadArea.ondragover = (e) => { e.preventDefault(); this.$uploadArea.classList.add('drag-over'); };
        this.$uploadArea.ondragleave = () => this.$uploadArea.classList.remove('drag-over');
        this.$uploadArea.ondrop = (e) => {
            e.preventDefault();
            this.$uploadArea.classList.remove('drag-over');
            if (e.dataTransfer.files[0]) this._handleFile(e.dataTransfer.files[0]);
        };

        this.$btnReUpload.onclick = () => this._showPhase('upload');
        this.$btnStart.onclick = () => this._startTranslation();
        this.$btnPause.onclick = () => this._togglePause();
        this.$btnCancel.onclick = () => this._cancelTranslation();
        this.$btnResumeAlert.onclick = () => this._togglePause();
        this.$btnExportComplete.onclick = () => this._showModal('export');
        this.$btnNewTask.onclick = () => location.reload();
        this.$btnSettings.onclick = () => this._showModal('settings');
        this.$btnExport.onclick = () => this._showModal('export');

        document.querySelectorAll('.tab').forEach(tab => {
            tab.onclick = () => this._switchTab(tab.dataset.tab);
        });

        this.$apiProvider.onchange = () => {
            this.$customUrlGroup.classList.toggle('hidden', this.$apiProvider.value !== 'custom');
        };
        document.getElementById('btn-save-settings').onclick = () => this._saveSettings();
        document.getElementById('btn-add-term').onclick = () => this._showModal('addTerm');
        document.getElementById('btn-confirm-add-term').onclick = () => this._addTerm();
        this.$glossarySearch.oninput = () => this._renderGlossary();
        document.getElementById('btn-import-glossary').onclick = () => this._importGlossary();

        document.querySelectorAll('.export-option').forEach(opt => {
            opt.onclick = () => this._doExport(opt.dataset.format);
        });

        document.querySelectorAll('.modal-overlay').forEach(overlay => {
            overlay.addEventListener('click', (e) => {
                if (e.target === overlay) overlay.classList.add('hidden');
            });
        });
    }

    /* ═══ Phase ═══ */
    _showPhase(phase) {
        this.$upload.classList.toggle('hidden', phase !== 'upload');
        this.$preview.classList.toggle('hidden', phase !== 'preview');
        this.$translate.classList.toggle('hidden', phase !== 'translate');
        this.$btnExport.style.display = phase === 'translate' ? '' : 'none';
    }

    /* ═══ File ═══ */
    _handleFile(file) {
        if (!file) return;
        this.fileName = file.name;
        const reader = new FileReader();
        reader.onload = (e) => {
            this.rawText = e.target.result;
            this._analyzeText();
            this._showPhase('preview');
        };
        reader.readAsText(file, 'utf-8');
    }

    _loadDemo() {
        if (typeof DEMO_TEXT === 'undefined') { alert('演示文本未加载'); return; }
        this.fileName = 'demo_novel.txt';
        this.rawText = DEMO_TEXT;
        this._analyzeText();
        this._showPhase('preview');
    }

    _analyzeText() {
        // TextSplitter.parse() → [{title, sentences}]
        this.chapters = this.splitter.parse(this.rawText);
        const totalSentences = this.chapters.reduce((s, ch) => s + ch.sentences.length, 0);
        const estTokens = totalSentences * 1676;

        this.$fileName.textContent = this.fileName;
        this.$statChars.textContent = Utils.formatNumber(this.rawText.length);
        this.$statSentences.textContent = Utils.formatNumber(totalSentences);
        this.$statChapters.textContent = this.chapters.length;
        this.$statTokens.textContent = Utils.formatNumber(estTokens);
        this.$previewText.textContent = this.rawText.slice(0, 500) + (this.rawText.length > 500 ? '...' : '');
    }

    /* ═══ Translation ═══ */
    async _startTranslation() {
        const apiKey = this.$apiKey.value.trim() || Utils.loadLocal('apiKey', '');
        if (!apiKey) {
            this._showModal('settings');
            alert('请先设置 API Key');
            return;
        }
        this._saveSettings();
        this._showPhase('translate');
        this._isPaused = false;
        this.$completeBanner.classList.add('hidden');

        // TranslationEngine 构造函数：constructor(config)
        this.engine = new TranslationEngine({
            api: {
                provider: this.$apiProvider.value,
                apiKey: apiKey,
                model: this.$apiModel.value || undefined,
                baseUrl: this.$apiBaseUrl.value || undefined,
            },
            targetLang: this.$targetLang.value,
            windowSize: parseInt(this.$contextWindow.value) || 8,
            summaryInterval: 20,
            temperature: parseFloat(this.$apiTemp.value) || 0.3,
            autoGlossary: this.$autoGlossary.checked,
            autoStyle: this.$autoStyle.checked,
        });

        this._initTranslationView();

        try {
            // translateBook(chapters, onProgress) — chapters = [{title, sentences}]
            this._translationResults = await this.engine.translateBook(
                this.chapters,
                (event, data) => this._handleProgress(event, data)
            );
            this.$btnExport.disabled = false;
            this._onComplete();
        } catch (e) {
            if (e.message === 'CANCELLED') {
                this.$statusPhase.textContent = '⏹ 已取消';
                this._setStatusBarState('warning');
                this.$btnExport.disabled = false;
            } else {
                this.$statusPhase.textContent = '❌ 翻译出错';
                this.$statusDetail.textContent = e.message;
                this._setStatusBarState('error');
                console.error('翻译错误:', e);
            }
        }
    }

    _initTranslationView() {
        this.$sourceList.innerHTML = '';
        this.$targetList.innerHTML = '';
        let globalIdx = 0;
        for (const chapter of this.chapters) {
            // 章节标题行
            const mkTitle = (text) => {
                const row = document.createElement('div');
                row.className = 'sentence-row';
                row.innerHTML = `<span class="sentence-idx"></span><span class="sentence-text" style="font-weight:700;color:var(--primary)">${Utils.escapeHtml(text)}</span>`;
                return row;
            };
            this.$sourceList.appendChild(mkTitle(chapter.title));
            const titleTrans = mkTitle('—');
            titleTrans.id = 'trans-title-' + this.chapters.indexOf(chapter);
            this.$targetList.appendChild(titleTrans);

            for (let i = 0; i < chapter.sentences.length; i++) {
                globalIdx++;
                const origRow = document.createElement('div');
                origRow.className = 'sentence-row';
                origRow.id = 'orig-' + globalIdx;
                origRow.innerHTML = `<span class="sentence-idx">${globalIdx}</span><span class="sentence-text">${Utils.escapeHtml(chapter.sentences[i])}</span>`;
                this.$sourceList.appendChild(origRow);

                const transRow = document.createElement('div');
                transRow.className = 'sentence-row';
                transRow.id = 'trans-' + globalIdx;
                transRow.innerHTML = `<span class="sentence-idx">${globalIdx}</span><span class="sentence-text pending">等待翻译...</span>`;
                this.$targetList.appendChild(transRow);
            }
        }
    }

    /* ═══ Progress ═══ */
    _handleProgress(event, data) {
        switch (event) {
            case 'phase':
                this.$statusPhase.textContent = data.message || data.phase;
                this._setStatusBarState('normal');
                break;

            case 'styleAnalyzed':
                this._renderStyle(data.style);
                break;

            case 'glossaryUpdate':
                this._renderGlossary();
                break;

            case 'error':
                this._showErrorToast(data.message);
                this.$statusDetail.textContent = data.message;
                this._setStatusBarState('warning');
                break;

            case 'autoPaused':
                this._isPaused = true;
                this._setStatusBarState('error');
                this.$statusPhase.textContent = '⚠️ 自动暂停';
                this.$statusDetail.textContent = data.message;
                this.$btnPause.textContent = '▶ 继续';
                this.$btnPause.classList.remove('btn-outline');
                this.$btnPause.classList.add('btn-primary');
                this.$pauseAlert.classList.add('visible');
                break;

            case 'sentenceComplete': {
                this.$progressFill.style.width = data.percent + '%';
                this.$progressLabel.textContent = `${data.completed} / ${data.total} 句`;
                this.$progressPercent.textContent = data.percent + '%';
                this.$statusTokens.textContent = `Tokens: ${Utils.formatNumber(data.tokensIn + data.tokensOut)}`;
                this.$statusPhase.textContent = '✍️ 翻译中';
                this.$statusDetail.textContent = `第${data.chapterIndex + 1}章 · 句${data.sentenceIndex + 1}`;
                this._setStatusBarState('normal');
                this._hidePauseAlert();

                let globalIdx = 0;
                for (let c = 0; c < data.chapterIndex; c++) {
                    globalIdx += this.chapters[c].sentences.length;
                }
                globalIdx += data.sentenceIndex + 1;

                const transRow = document.getElementById('trans-' + globalIdx);
                if (transRow) {
                    const textEl = transRow.querySelector('.sentence-text');
                    if (data.translation.startsWith('[翻译失败]')) {
                        textEl.className = 'sentence-text failed';
                    } else {
                        textEl.className = 'sentence-text';
                    }
                    textEl.textContent = data.translation;
                }

                document.querySelectorAll('.sentence-row.current').forEach(r => r.classList.remove('current'));
                const origRow = document.getElementById('orig-' + globalIdx);
                if (origRow) { origRow.classList.add('current'); origRow.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
                if (transRow) { transRow.classList.add('current'); transRow.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
                break;
            }

            case 'summaryUpdate':
                this._renderSummaryFromEngine();
                break;

            case 'chapterComplete':
                break;

            case 'complete':
                break;
        }
    }

    /* ═══ Pause / Cancel ═══ */
    _togglePause() {
        if (!this.engine) return;
        if (this.engine._paused) {
            this.engine.resume();
            this._isPaused = false;
            this.$btnPause.textContent = '⏸ 暂停';
            this.$btnPause.classList.remove('btn-primary');
            this.$btnPause.classList.add('btn-outline');
            this.$statusPhase.textContent = '✍️ 翻译中';
            this._setStatusBarState('normal');
            this._hidePauseAlert();
        } else {
            this.engine.pause();
            this._isPaused = true;
            this.$btnPause.textContent = '▶ 继续';
            this.$btnPause.classList.remove('btn-outline');
            this.$btnPause.classList.add('btn-primary');
            this.$statusPhase.textContent = '⏸ 已暂停';
            this._setStatusBarState('warning');
        }
    }

    _cancelTranslation() {
        if (!this.engine) return;
        if (confirm('确定取消翻译？已完成的部分将保留，可导出。')) {
            this.engine.cancel();
            this._hidePauseAlert();
        }
    }

    _setStatusBarState(state) {
        this.$statusBar.className = 'status-bar';
        if (state !== 'normal') this.$statusBar.classList.add('status-bar--' + state);
    }

    _hidePauseAlert() {
        this.$pauseAlert.classList.remove('visible');
    }

    _showErrorToast(message) {
        const old = document.querySelector('.error-toast');
        if (old) old.remove();
        const toast = document.createElement('div');
        toast.className = 'error-toast';
        toast.textContent = '⚠️ ' + message;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 4000);
    }

    /* ═══ Complete ═══ */
    _onComplete() {
        this._setStatusBarState('success');
        this.$statusPhase.textContent = '✅ 翻译完成';
        this.$progressFill.style.width = '100%';
        this.$progressPercent.textContent = '100%';

        const results = this._translationResults || [];
        const totalSentences = results.reduce((s, ch) => s + ch.sentences.length, 0);
        const tokensTotal = (this.engine.tokensInput || 0) + (this.engine.tokensOutput || 0);
        this.$completeSummary.textContent = `共翻译 ${totalSentences} 句，消耗 ${Utils.formatNumber(tokensTotal)} Tokens`;
        this.$completeBanner.classList.remove('hidden');
    }

    /* ═══ Tabs ═══ */
    _switchTab(tabName) {
        document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.tab === tabName));
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
        document.getElementById('panel-' + tabName).classList.add('active');
    }

    /* ═══ Glossary ═══ */
    _renderGlossary() {
        if (!this.engine) return;
        const query = this.$glossarySearch.value;
        const entries = this.engine.glossary.search(query);
        this.$glossaryCount.textContent = this.engine.glossary.entries.length;

        const catLabel = { character: '角色', location: '地点', item: '物品', organization: '组织', concept: '概念', other: '其他' };

        this.$glossaryBody.innerHTML = entries.map(e => `
            <tr>
                <td><strong>${Utils.escapeHtml(e.original)}</strong></td>
                <td>${Utils.escapeHtml(e.translation)}</td>
                <td><span class="term-category cat-${e.category}">${catLabel[e.category] || '其他'}</span></td>
                <td>
                    <div class="term-actions">
                        <button onclick="app.toggleLockTerm('${e.id}')" title="${e.locked ? '解锁' : '锁定'}" class="${e.locked ? 'term-locked' : ''}">🔒</button>
                        <button onclick="app.deleteTerm('${e.id}')" title="删除">🗑</button>
                    </div>
                </td>
            </tr>
        `).join('');
    }

    editTerm(id) {
        if (!this.engine) return;
        const entry = this.engine.glossary.entries.find(e => e.id === id);
        if (!entry) return;
        const newTrans = prompt(`修改「${entry.original}」的译名:`, entry.translation);
        if (newTrans !== null && newTrans.trim()) {
            this.engine.glossary.edit(id, { translation: newTrans.trim() });
            this._renderGlossary();
        }
    }

    toggleLockTerm(id) {
        if (!this.engine) return;
        this.engine.glossary.toggleLock(id);
        this._renderGlossary();
    }

    deleteTerm(id) {
        if (!this.engine) return;
        if (confirm('确定删除此术语？')) {
            this.engine.glossary.remove(id);
            this._renderGlossary();
        }
    }

    _addTerm() {
        if (!this.engine) { alert('请先开始翻译后再添加术语'); return; }
        const original = document.getElementById('term-source').value.trim();
        const translation = document.getElementById('term-target').value.trim();
        const category = document.getElementById('term-category').value;
        if (!original || !translation) { alert('请填写原文和译文'); return; }
        this.engine.glossary.addOrUpdate({ original, translation, category, source: 'manual' });
        this._renderGlossary();
        this.$modalAddTerm.classList.add('hidden');
        document.getElementById('term-source').value = '';
        document.getElementById('term-target').value = '';
    }

    _importGlossary() {
        if (!this.engine) { alert('请先开始翻译'); return; }
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = '.json';
        input.onchange = (e) => {
            const reader = new FileReader();
            reader.onload = (ev) => {
                try {
                    const data = JSON.parse(ev.target.result);
                    if (data.entries && Array.isArray(data.entries)) {
                        data.entries.forEach(t => this.engine.glossary.addOrUpdate(t));
                    } else if (Array.isArray(data)) {
                        data.forEach(t => this.engine.glossary.addOrUpdate(t));
                    }
                    this._renderGlossary();
                } catch { alert('JSON 格式错误'); }
            };
            reader.readAsText(e.target.files[0]);
        };
        input.click();
    }

    /* ═══ Style ═══ */
    _renderStyle(style) {
        if (!style) return;
        const fields = [
            { label: '语体', key: 'register' },
            { label: '时代感', key: 'era_feel' },
            { label: '叙事语气', key: 'narrative_tone' },
            { label: '句式', key: 'sentence_pattern' },
            { label: '用词', key: 'vocabulary' },
            { label: '情感基调', key: 'emotional_tone' },
        ];

        let html = '<div class="style-grid">';
        for (const f of fields) {
            if (style[f.key]) {
                html += `<div class="style-item"><div class="style-item-label">${f.label}</div><div class="style-item-value">${Utils.escapeHtml(style[f.key])}</div></div>`;
            }
        }
        html += '</div>';

        if (style.style_summary) {
            html += `<div class="style-description">📝 ${Utils.escapeHtml(style.style_summary)}</div>`;
        }

        if (style.translation_guidelines && style.translation_guidelines.length > 0) {
            html += '<div style="margin-top:16px"><h4 style="font-size:13px;color:var(--text-secondary);margin-bottom:8px">翻译指导</h4>';
            for (const g of style.translation_guidelines) {
                html += `<div style="padding:6px 12px;background:var(--bg-card);border-left:3px solid var(--primary);margin-bottom:6px;border-radius:0 var(--radius) var(--radius) 0;font-size:13px">${Utils.escapeHtml(g)}</div>`;
            }
            html += '</div>';
        }

        this.$styleContent.innerHTML = html;
    }

    /* ═══ Summary ═══ */
    _renderSummaryFromEngine() {
        if (!this.engine) return;
        let html = '';

        if (this.engine.globalSummary) {
            html += `<div class="summary-section"><h4>🌍 全局摘要</h4><div class="summary-text">${Utils.escapeHtml(this.engine.globalSummary)}</div></div>`;
        }

        const summaries = this.engine.chapterSummaries || {};
        for (const [idx, summary] of Object.entries(summaries)) {
            const title = this.chapters[Number(idx)]?.title || `第${Number(idx) + 1}章`;
            html += `<div class="summary-section"><h4>📖 ${Utils.escapeHtml(title)}</h4><div class="summary-text">${Utils.escapeHtml(summary)}</div></div>`;
        }

        this.$summaryContent.innerHTML = html || '<div class="summary-placeholder">📋 翻译进行中将自动生成摘要...</div>';
    }

    /* ═══ Modal ═══ */
    _showModal(name) {
        const map = { settings: this.$modalSettings, addTerm: this.$modalAddTerm, export: this.$modalExport };
        const m = map[name];
        if (m) m.classList.remove('hidden');
    }

    /* ═══ Settings ═══ */
    _loadSettings() {
        const cfg = Utils.loadLocal('config', {});
        if (cfg.provider) this.$apiProvider.value = cfg.provider;
        if (cfg.apiKey) this.$apiKey.value = cfg.apiKey;
        if (cfg.model) this.$apiModel.value = cfg.model;
        if (cfg.baseUrl) this.$apiBaseUrl.value = cfg.baseUrl;
        if (cfg.temp) this.$apiTemp.value = cfg.temp;
        if (cfg.maxTokens) this.$apiMaxTokens.value = cfg.maxTokens;
        this.$customUrlGroup.classList.toggle('hidden', this.$apiProvider.value !== 'custom');
    }

    _saveSettings() {
        Utils.saveLocal('config', {
            provider: this.$apiProvider.value,
            apiKey: this.$apiKey.value,
            model: this.$apiModel.value,
            baseUrl: this.$apiBaseUrl.value,
            temp: this.$apiTemp.value,
            maxTokens: this.$apiMaxTokens.value,
        });
        this.$modalSettings.classList.add('hidden');
    }

    /* ═══ Export ═══ */
    _doExport(format) {
        // 使用引擎回调方式获取的 _translationResults: [{chapterIndex, title, sentences: [{original, translation, newTerms}]}]
        const results = this._translationResults || [];
        if (!results.length) { alert('没有可导出的翻译结果'); return; }
        const baseName = this.fileName.replace(/\.[^.]+$/, '') || 'translation';

        switch (format) {
            case 'txt': {
                let text = '';
                for (const ch of results) {
                    text += ch.title + '\n\n';
                    for (const s of ch.sentences) {
                        if (s.translation && !s.translation.startsWith('[翻译失败]')) {
                            text += s.translation + '\n';
                        }
                    }
                    text += '\n\n';
                }
                Utils.downloadFile(text.trim(), baseName + '_译文.txt');
                break;
            }
            case 'bilingual': {
                let text = '';
                for (const ch of results) {
                    text += '═══ ' + ch.title + ' ═══\n\n';
                    for (const s of ch.sentences) {
                        text += '[原] ' + s.original + '\n';
                        text += '[译] ' + (s.translation || '(未翻译)') + '\n\n';
                    }
                    text += '\n';
                }
                Utils.downloadFile(text.trim(), baseName + '_双语对照.txt');
                break;
            }
            case 'json': {
                const data = {
                    fileName: this.fileName,
                    targetLang: this.$targetLang.value,
                    exportTime: new Date().toISOString(),
                    results: results,
                    glossary: this.engine?.glossary?.toJSON() || {},
                    style: this.engine?.styleProfile || null,
                    globalSummary: this.engine?.globalSummary || '',
                    chapterSummaries: this.engine?.chapterSummaries || {},
                    stats: {
                        tokensInput: this.engine?.tokensInput || 0,
                        tokensOutput: this.engine?.tokensOutput || 0,
                    },
                };
                Utils.downloadFile(JSON.stringify(data, null, 2), baseName + '_完整数据.json', 'application/json');
                break;
            }
            case 'glossary': {
                const data = this.engine?.glossary?.toJSON() || { entries: [] };
                Utils.downloadFile(JSON.stringify(data, null, 2), baseName + '_术语表.json', 'application/json');
                break;
            }
        }
        this.$modalExport.classList.add('hidden');
    }
}
