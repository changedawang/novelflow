<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NovelFlow — AI 小说翻译引擎</title>
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="css/components.css">
</head>
<body>
    <!-- ═══ Header ═══ -->
    <header class="header">
        <div class="header-left">
            <div class="logo">
                <span class="logo-icon">📖</span>
                <div>
                    <div class="logo-text">NovelFlow</div>
                    <div class="logo-subtitle">AI Novel Translator</div>
                </div>
            </div>
        </div>
        <div class="header-right">
            <button class="btn btn-ghost btn-sm" id="btn-settings" title="设置">⚙️ 设置</button>
            <button class="btn btn-ghost btn-sm" id="btn-export" title="导出" style="display:none">📥 导出</button>
        </div>
    </header>

    <!-- ═══ Main ═══ -->
    <main class="main-content">

        <!-- Phase 1: Upload -->
        <section class="phase phase-upload" id="phase-upload">
            <div class="upload-area" id="upload-area">
                <span class="upload-icon">✨</span>
                <h2>开始翻译你的小说</h2>
                <p>拖拽 TXT 文件到这里，或点击选择文件</p>
                <button class="btn btn-primary btn-lg upload-btn" id="btn-choose-file">选择文件</button>
                <input type="file" id="file-input" accept=".txt" hidden>
                <div class="upload-demo">
                    <button class="btn btn-link" id="btn-demo">🎭 使用内置演示文本体验</button>
                </div>
            </div>
        </section>

        <!-- Phase 2: Preview & Config -->
        <section class="phase phase-preview hidden" id="phase-preview">
            <div class="preview-card">
                <div class="preview-header">
                    <h3>📄 <span id="file-name">未选择文件</span></h3>
                    <button class="btn btn-ghost btn-sm" id="btn-re-upload">重新选择</button>
                </div>

                <div class="preview-stats">
                    <div class="stat">
                        <span class="stat-value" id="stat-chars">0</span>
                        <span class="stat-label">字符</span>
                    </div>
                    <div class="stat">
                        <span class="stat-value" id="stat-sentences">0</span>
                        <span class="stat-label">句子</span>
                    </div>
                    <div class="stat">
                        <span class="stat-value" id="stat-chapters">0</span>
                        <span class="stat-label">章节</span>
                    </div>
                    <div class="stat">
                        <span class="stat-value" id="stat-tokens">0</span>
                        <span class="stat-label">预估 Tokens</span>
                    </div>
                </div>

                <div class="preview-text" id="preview-text">加载中...</div>

                <div class="preview-config">
                    <div class="config-row">
                        <label>目标语言</label>
                        <select id="target-lang">
                            <option value="简体中文" selected>🇨🇳 简体中文</option>
                            <option value="繁體中文">🇭🇰 繁體中文</option>
                            <option value="English">🇺🇸 English</option>
                            <option value="日本語">🇯🇵 日本語</option>
                            <option value="한국어">🇰🇷 한국어</option>
                            <option value="Français">🇫🇷 Français</option>
                            <option value="Deutsch">🇩🇪 Deutsch</option>
                            <option value="Español">🇪🇸 Español</option>
                            <option value="Português">🇧🇷 Português</option>
                            <option value="Italiano">🇮🇹 Italiano</option>
                            <option value="Русский">🇷🇺 Русский</option>
                            <option value="العربية">🇸🇦 العربية</option>
                            <option value="ภาษาไทย">🇹🇭 ภาษาไทย</option>
                            <option value="Tiếng Việt">🇻🇳 Tiếng Việt</option>
                            <option value="Bahasa Indonesia">🇮🇩 Bahasa Indonesia</option>
                        </select>
                    </div>

                    <details class="advanced-config">
                        <summary>⚡ 高级选项</summary>
                        <div class="config-row">
                            <label>上下文窗口</label>
                            <input type="number" id="context-window" value="8" min="2" max="20">
                            <span class="config-hint">前N句作为上下文</span>
                        </div>
                        <div class="config-row">
                            <label>自动提取术语</label>
                            <input type="checkbox" id="auto-glossary" checked>
                        </div>
                        <div class="config-row">
                            <label>分析文风</label>
                            <input type="checkbox" id="auto-style" checked>
                        </div>
                    </details>
                </div>

                <div class="preview-actions">
                    <button class="btn btn-primary btn-lg" id="btn-start">🚀 开始翻译</button>
                </div>
            </div>
        </section>

        <!-- Phase 3: Translation -->
        <section class="phase phase-translate hidden" id="phase-translate">

            <!-- 暂停提示 -->
            <div class="pause-alert" id="pause-alert">
                <span class="pause-alert-text">⚠️ 翻译已暂停 — API 连续出错，请检查后继续</span>
                <button class="btn btn-sm btn-primary" id="btn-resume-alert">✅ 检查后继续</button>
            </div>

            <!-- 完成横幅 -->
            <div class="complete-banner hidden" id="complete-banner">
                <h3>🎉 翻译完成</h3>
                <p id="complete-summary">已完成全部句子的翻译</p>
                <div class="complete-actions">
                    <button class="btn btn-primary" id="btn-export-complete">📥 导出结果</button>
                    <button class="btn btn-outline" id="btn-new-task">📄 新建任务</button>
                </div>
            </div>

            <!-- 状态栏 -->
            <div class="status-bar" id="status-bar">
                <div class="status-left">
                    <span class="status-phase" id="status-phase">准备中</span>
                    <span class="status-detail" id="status-detail"></span>
                </div>
                <div class="status-right">
                    <span class="status-tokens" id="status-tokens">Tokens: 0</span>
                    <button class="btn btn-outline btn-sm" id="btn-pause">⏸ 暂停</button>
                    <button class="btn btn-danger btn-sm" id="btn-cancel">✖ 取消</button>
                </div>
            </div>

            <!-- 进度条 -->
            <div class="progress-container">
                <div class="progress-bar">
                    <div class="progress-fill" id="progress-fill" style="width:0%"></div>
                </div>
                <div class="progress-text">
                    <span id="progress-label">0 / 0 句</span>
                    <span id="progress-percent">0%</span>
                </div>
            </div>

            <!-- 标签页 -->
            <div class="tabs" id="tabs">
                <button class="tab active" data-tab="translation">📝 翻译对照</button>
                <button class="tab" data-tab="glossary">📚 术语表 <span class="badge" id="glossary-count">0</span></button>
                <button class="tab" data-tab="style">🎨 文风</button>
                <button class="tab" data-tab="summary">📋 摘要</button>
            </div>

            <!-- Tab: 翻译对照 -->
            <div class="tab-panel active" id="panel-translation">
                <div class="translation-view">
                    <div class="translation-col col-original">
                        <div class="col-header">原文 · Source</div>
                        <div class="col-content" id="source-list"></div>
                    </div>
                    <div class="translation-col col-translated">
                        <div class="col-header">译文 · Translation</div>
                        <div class="col-content" id="target-list"></div>
                    </div>
                </div>
            </div>

            <!-- Tab: 术语表 -->
            <div class="tab-panel" id="panel-glossary">
                <div class="glossary-toolbar">
                    <input type="text" class="glossary-search" id="glossary-search" placeholder="🔍 搜索术语...">
                    <button class="btn btn-outline btn-sm" id="btn-add-term">+ 添加</button>
                    <button class="btn btn-ghost btn-sm" id="btn-import-glossary">📂 导入</button>
                </div>
                <div class="glossary-table-wrap">
                    <table class="glossary-table">
                        <thead>
                            <tr>
                                <th>原文</th>
                                <th>译文</th>
                                <th>类别</th>
                                <th style="width:80px">操作</th>
                            </tr>
                        </thead>
                        <tbody id="glossary-body"></tbody>
                    </table>
                </div>
            </div>

            <!-- Tab: 文风 -->
            <div class="tab-panel" id="panel-style">
                <div class="style-card" id="style-content">
                    <div class="style-placeholder">🎨 翻译开始后将自动分析原文文风...</div>
                </div>
            </div>

            <!-- Tab: 摘要 -->
            <div class="tab-panel" id="panel-summary">
                <div class="summary-card" id="summary-content">
                    <div class="summary-placeholder">📋 翻译进行中将自动生成摘要...</div>
                </div>
            </div>
        </section>
    </main>

    <!-- ═══ Modal: 设置 ═══ -->
    <div class="modal-overlay hidden" id="modal-settings">
        <div class="modal">
            <div class="modal-header">
                <h3>⚙️ API 设置</h3>
                <button class="btn btn-ghost btn-sm" onclick="document.getElementById('modal-settings').classList.add('hidden')">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>API 提供商</label>
                    <select id="api-provider">
                        <option value="deepseek">DeepSeek</option>
                        <option value="openai">OpenAI</option>
                        <option value="custom">自定义（兼容 OpenAI）</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>API Key</label>
                    <input type="password" id="api-key" placeholder="sk-...">
                </div>
                <div class="form-group hidden" id="custom-url-group">
                    <label>Base URL</label>
                    <input type="text" id="api-base-url" placeholder="https://your-api.com/v1">
                </div>
                <div class="form-group">
                    <label>模型</label>
                    <input type="text" id="api-model" placeholder="deepseek-chat">
                    <div class="form-hint">留空则使用提供商默认模型</div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Temperature</label>
                        <input type="number" id="api-temperature" value="0.3" step="0.1" min="0" max="2">
                    </div>
                    <div class="form-group">
                        <label>Max Tokens</label>
                        <input type="number" id="api-max-tokens" value="1024" step="128" min="128">
                    </div>
                </div>
                <hr>
                <p>💡 API Key 仅保存在本地浏览器中，不会上传到任何服务器。</p>
                <div class="form-actions">
                    <button class="btn btn-outline" onclick="document.getElementById('modal-settings').classList.add('hidden')">取消</button>
                    <button class="btn btn-primary" id="btn-save-settings">保存设置</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══ Modal: 添加术语 ═══ -->
    <div class="modal-overlay hidden" id="modal-add-term">
        <div class="modal modal-sm">
            <div class="modal-header">
                <h3>📝 添加术语</h3>
                <button class="btn btn-ghost btn-sm" onclick="document.getElementById('modal-add-term').classList.add('hidden')">✕</button>
            </div>
            <div class="modal-body add-term-form">
                <div class="form-group">
                    <label>原文</label>
                    <input type="text" id="term-source" placeholder="Frodo Baggins">
                </div>
                <div class="form-group">
                    <label>译文</label>
                    <input type="text" id="term-target" placeholder="弗罗多·巴金斯">
                </div>
                <div class="form-group">
                    <label>类别</label>
                    <select id="term-category">
                        <option value="character">👤 角色</option>
                        <option value="location">📍 地点</option>
                        <option value="item">🗡️ 物品</option>
                        <option value="organization">🏛️ 组织</option>
                        <option value="concept">💡 概念</option>
                        <option value="other">📌 其他</option>
                    </select>
                </div>
                <div class="form-actions">
                    <button class="btn btn-outline" onclick="document.getElementById('modal-add-term').classList.add('hidden')">取消</button>
                    <button class="btn btn-primary" id="btn-confirm-add-term">添加</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══ Modal: 导出 ═══ -->
    <div class="modal-overlay hidden" id="modal-export">
        <div class="modal">
            <div class="modal-header">
                <h3>📥 导出翻译结果</h3>
                <button class="btn btn-ghost btn-sm" onclick="document.getElementById('modal-export').classList.add('hidden')">✕</button>
            </div>
            <div class="modal-body">
                <div class="export-options">
                    <div class="export-option" data-format="txt">
                        <span class="export-icon">📄</span>
                        <div class="export-info">
                            <h4>纯译文 TXT</h4>
                            <p>仅包含翻译后的文本，可直接阅读</p>
                        </div>
                    </div>
                    <div class="export-option" data-format="bilingual">
                        <span class="export-icon">📑</span>
                        <div class="export-info">
                            <h4>双语对照 TXT</h4>
                            <p>原文与译文逐句对照</p>
                        </div>
                    </div>
                    <div class="export-option" data-format="json">
                        <span class="export-icon">📦</span>
                        <div class="export-info">
                            <h4>完整数据 JSON</h4>
                            <p>含翻译、术语表、文风、摘要、Token 统计</p>
                        </div>
                    </div>
                    <div class="export-option" data-format="glossary">
                        <span class="export-icon">📚</span>
                        <div class="export-info">
                            <h4>术语表 JSON</h4>
                            <p>可导入复用的术语表数据</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══ Scripts ═══ -->
    <script src="js/utils.js"></script>
    <script src="js/llm-adapter.js"></script>
    <script src="js/text-splitter.js"></script>
    <script src="js/glossary-manager.js"></script>
    <script src="js/translation-engine.js"></script>
    <script src="js/ui-controller.js"></script>
    <script src="js/app.js"></script>
</body>
</html>