/* NovelFlow — UI Controller v4 书架版 */
class UIController {
    constructor() {
        this.pages = { shelf:'page-shelf', upload:'page-upload', config:'page-config', work:'page-work', reader:'page-reader' };
        this.currentPage = 'shelf';
        this.engine = null;
        this.chapters = null;
        this.fileName = '';
        this.currentBookId = null;
        this.translationResults = [];
        this._autoScroll = true;
        this._init();
    }

    /* ── 初始化 ── */
    _init() {
        this._loadSettings();
        this._bindNav();
        this._bindUpload();
        this._bindConfig();
        this._bindWork();
        this._bindReader();
        this._bindModals();
        this._renderShelf();
    }

    /* ── 页面切换 ── */
    _showPage(name) {
        Object.values(this.pages).forEach(id => document.getElementById(id).classList.add('hidden'));
        document.getElementById(this.pages[name]).classList.remove('hidden');
        this.currentPage = name;
    }

    /* ── localStorage 书籍数据 ── */
    _getBooks() { return Utils.loadLocal('books', []); }
    _saveBooks(books) { Utils.saveLocal('books', books); }
    _getBook(id) { return this._getBooks().find(b => b.id === id); }
    _saveBook(book) {
        const books = this._getBooks();
        const idx = books.findIndex(b => b.id === book.id);
        if (idx >= 0) books[idx] = book; else books.unshift(book);
        this._saveBooks(books);
    }
    _deleteBook(id) { this._saveBooks(this._getBooks().filter(b => b.id !== id)); }

    /* ── 书架渲染 ── */
    _renderShelf() {
        const books = this._getBooks();
        const grid = document.getElementById('shelf-grid');
        const empty = document.getElementById('shelf-empty');
        if (books.length === 0) { empty.classList.remove('hidden'); grid.innerHTML = ''; return; }
        empty.classList.add('hidden');
        const emojis = ['📕','📗','📘','📙','📓','📔','📒'];
        grid.innerHTML = books.map((b, i) => {
            const pct = b.total > 0 ? Math.round(b.completed / b.total * 100) : 0;
            const emoji = emojis[i % emojis.length];
            const status = b.status || 'completed';
            const statusLabel = {translating:'翻译中',paused:'已暂停',completed:'已完成',cancelled:'已取消'}[status] || status;
            const date = b.updatedAt ? new Date(b.updatedAt).toLocaleDateString() : '';
            return `<div class="book-card" data-id="${b.id}">
                <button class="book-delete" data-del="${b.id}" title="删除">✕</button>
                <div class="book-card-inner">
                    <div class="book-emoji">${emoji}</div>
                    <div class="book-title">${Utils.escapeHtml(b.fileName || '未命名')}</div>
                    <div class="book-lang">→ ${Utils.escapeHtml(b.targetLang || '简体中文')}</div>
                    <div class="book-progress">
                        <div class="book-progress-bar"><div class="book-progress-fill ${pct>=100?'complete':''}" style="width:${pct}%"></div></div>
                        <div class="book-meta">
                            <span class="book-status s-${status}">${statusLabel} ${pct}%</span>
                            <span class="book-date">${date}</span>
                        </div>
                    </div>
                </div>
            </div>`;
        }).join('');
        grid.querySelectorAll('.book-card').forEach(card => {
            card.addEventListener('click', e => {
                if (e.target.classList.contains('book-delete')) return;
                this._openBook(card.dataset.id);
            });
        });
        grid.querySelectorAll('.book-delete').forEach(btn => {
            btn.addEventListener('click', e => {
                e.stopPropagation();
                if (confirm('确定删除这本书？')) { this._deleteBook(btn.dataset.del); this._renderShelf(); }
            });
        });
    }

    _openBook(id) {
        const book = this._getBook(id);
        if (!book) return;
        if (book.status === 'completed' || book.status === 'cancelled') {
            this._openReader(book);
        } else {
            this._resumeBook(book);
        }
    }

    /* ── 导航绑定 ── */
    _bindNav() {
        document.getElementById('btn-new-book').addEventListener('click', () => this._showPage('upload'));
        document.getElementById('btn-back-shelf').addEventListener('click', () => { this._showPage('shelf'); this._renderShelf(); });
        document.getElementById('btn-back-upload').addEventListener('click', () => this._showPage('upload'));
        document.getElementById('btn-back-shelf2').addEventListener('click', () => { this._showPage('shelf'); this._renderShelf(); });
        document.getElementById('btn-settings').addEventListener('click', () => this._openSettingsModal());
    }

    /* ── 设置 ── */
    _loadSettings() {
        const raw = Utils.loadLocal('settings', { provider:'deepseek', apiKeys:[], baseUrl:'', model:'deepseek-chat', reasoning:'balanced', temperature:0.3, maxTokens:1024 });
        // 兼容旧版单key
        if (raw.apiKey && (!raw.apiKeys || raw.apiKeys.length === 0)) {
            raw.apiKeys = [raw.apiKey]; delete raw.apiKey;
        }
        if (!raw.reasoning) raw.reasoning = 'balanced';
        this.settings = raw;
    }
    _openSettingsModal() {
        const s = this.settings;
        document.getElementById('api-provider').value = s.provider || 'deepseek';
        const keysTA = document.getElementById('api-keys');
        keysTA.value = (s.apiKeys || []).join('\n');
        this._updateKeyCountHint();
        document.getElementById('api-base-url').value = s.baseUrl || '';
        document.getElementById('api-model').value = s.model || 'deepseek-chat';
        document.getElementById('api-reasoning').value = s.reasoning || 'balanced';
        document.getElementById('api-temp').value = s.temperature || 0.3;
        document.getElementById('api-max-tokens').value = s.maxTokens || 1024;
        this._toggleCustomUrl();
        this._toggleCustomTemp();
        document.getElementById('modal-settings').classList.remove('hidden');
    }
    _toggleCustomTemp() {
        const r = document.getElementById('api-reasoning').value;
        document.getElementById('custom-temp-group').style.display = r === 'custom' ? '' : 'none';
    }
    _updateKeyCountHint() {
        const keys = document.getElementById('api-keys').value.split('\n').filter(k => k.trim());
        document.getElementById('key-count-hint').textContent = keys.length + ' 个密钥';
    }
    _reasoningToTemp(reasoning) {
        const map = { precise:0.1, balanced:0.3, creative:0.6, wild:0.9 };
        return map[reasoning] !== undefined ? map[reasoning] : null;
    }
    _toggleCustomUrl() {
        const p = document.getElementById('api-provider').value;
        document.getElementById('custom-url-group').classList.toggle('hidden', p !== 'custom');
    }

    /* ── 上传绑定 ── */
    _bindUpload() {
        const area = document.getElementById('upload-area');
        const input = document.getElementById('file-input');
        document.getElementById('btn-choose-file').addEventListener('click', e => { e.stopPropagation(); input.click(); });
        area.addEventListener('click', () => input.click());
        area.addEventListener('dragover', e => { e.preventDefault(); area.classList.add('dragover'); });
        area.addEventListener('dragleave', () => area.classList.remove('dragover'));
        area.addEventListener('drop', e => { e.preventDefault(); area.classList.remove('dragover'); if(e.dataTransfer.files[0]) this._handleFile(e.dataTransfer.files[0]); });
        input.addEventListener('change', () => { if(input.files[0]) this._handleFile(input.files[0]); input.value=''; });
        document.getElementById('btn-demo').addEventListener('click', e => { e.stopPropagation(); this._loadDemo(); });
    }
    _handleFile(file) {
        this.fileName = file.name.replace(/\.txt$/i,'');
        const reader = new FileReader();
        reader.onload = () => this._processText(reader.result);
        reader.readAsText(file);
    }
    _loadDemo() {
        this.fileName = 'Demo - The Garden';
        const demo = `Chapter 1\n\nThe old house stood at the edge of the village, its windows dark and silent. Margaret had not visited since her grandmother's passing three winters ago. The garden, once a magnificent tapestry of roses and lavender, had surrendered to wild brambles.\n\n"You'll find it changed," Mrs. Chen had warned her at the station. The old woman's eyes held something—pity, perhaps, or was it fear?\n\nMargaret pushed open the iron gate. It protested with a sound like a wounded animal. The path to the front door was barely visible beneath the overgrowth.\n\nChapter 2\n\nInside, the air was thick with dust and memory. Photographs lined the hallway—faces she recognized and faces she did not. Her grandmother's portrait hung above the fireplace, those piercing blue eyes seeming to follow her across the room.\n\nA floorboard creaked upstairs. Margaret froze. The house was supposed to be empty.\n\n"Hello?" she called, her voice braver than she felt. Silence answered, but it was the wrong kind of silence—too deliberate, too watchful.`;
        this._processText(demo);
    }
    _processText(text) {
        const splitter = new TextSplitter();
        this.chapters = splitter.parse(text);
        const totalSent = this.chapters.reduce((s,c)=>s+c.sentences.length,0);
        const totalChars = text.length;
        document.getElementById('cfg-filename').textContent = this.fileName;
        document.getElementById('cfg-chars').textContent = Utils.formatNumber(totalChars);
        document.getElementById('cfg-sentences').textContent = totalSent;
        document.getElementById('cfg-chapters').textContent = this.chapters.length;
        document.getElementById('cfg-tokens').textContent = Utils.formatNumber(totalSent * 1650);
        document.getElementById('cfg-preview').textContent = text.slice(0,500) + (text.length>500?'...':'');
        this._showPage('config');
    }

    /* ── 配置绑定 ── */
    _bindConfig() {
        document.getElementById('btn-start-translate').addEventListener('click', () => this._startTranslation());
    }
    _startTranslation() {
        if(!this.settings.apiKeys||this.settings.apiKeys.length===0){ alert('请先在设置中填写API密钥'); this._openSettingsModal(); return; }
        if(!this.chapters || this.chapters.length===0){ alert('没有可翻译的内容'); return; }
        const bookId = Utils.uid();
        this.currentBookId = bookId;
        this.translationResults = [];
        const totalSent = this.chapters.reduce((s,c)=>s+c.sentences.length,0);
        const book = {
            id: bookId, fileName: this.fileName,
            targetLang: document.getElementById('cfg-lang').value,
            chapters: this.chapters, results: [], glossary: null, styleProfile: null,
            globalSummary:'', chapterSummaries:{}, tokensIn:0, tokensOut:0,
            completed:0, total:totalSent, status:'translating',
            createdAt: Date.now(), updatedAt: Date.now()
        };
        this._saveBook(book);
        this._launchEngine(book);
    }

    _resumeBook(book) {
        this.currentBookId = book.id;
        this.fileName = book.fileName;
        this.chapters = book.chapters;
        this.translationResults = book.results || [];
        book.status = 'translating';
        book.updatedAt = Date.now();
        this._saveBook(book);
        this._launchEngine(book);
    }

    _launchEngine(book) {
        document.getElementById('work-title').textContent = book.fileName;
        document.getElementById('src-list').innerHTML = '';
        document.getElementById('tgt-list').innerHTML = '';
        document.getElementById('done-banner').classList.add('hidden');
        document.getElementById('pause-bar').classList.remove('show');
        this._setDot('active');
        this._showPage('work');
        // 恢复已翻译的UI
        if(book.results && book.results.length>0){
            for(const ch of book.results){
                for(const s of ch.sentences){
                    this._addSentRow(s.original, s.translation, s.failed);
                }
            }
        }
        const s = this.settings;
        const cfg = {
            api:{ apiKeys:s.apiKeys, model:s.model, baseUrl:s.baseUrl, provider:s.provider },
            targetLang: book.targetLang,
            windowSize: parseInt(document.getElementById('cfg-window').value)||8,
            temperature: parseFloat(s.temperature)||0.3,
            autoGlossary: document.getElementById('cfg-glossary').checked,
            autoStyle: document.getElementById('cfg-style').checked,
        };
        this.engine = new TranslationEngine(cfg);
        // 恢复引擎状态
        if(book.glossary) this.engine.glossary.fromJSON(book.glossary);
        if(book.styleProfile) this.engine.styleProfile = book.styleProfile;
        if(book.globalSummary) this.engine.globalSummary = book.globalSummary;
        if(book.chapterSummaries) this.engine.chapterSummaries = book.chapterSummaries;
        this.engine.tokensInput = book.tokensIn||0;
        this.engine.tokensOutput = book.tokensOut||0;
        this.engine.completedSentences = book.completed||0;

        // 计算剩余章节
        const doneChapters = (book.results||[]).length;
        const remaining = this.chapters.slice(doneChapters);
        this.engine.totalSentences = this.chapters.reduce((s,c)=>s+c.sentences.length,0);

        this.engine.translateBook(remaining, (ev,d) => this._onProgress(ev,d))
            .then(results => {
                this.translationResults = [...(book.results||[]), ...results];
                this._onComplete();
            })
            .catch(err => {
                if(err.message==='CANCELLED'){ this._onCancelled(); }
                else { console.error(err); alert('翻译错误: '+err.message); }
            });
    }

    /* ── 进度回调 ── */
    _onProgress(ev, d) {
        const book = this._getBook(this.currentBookId);
        if(!book) return;
        switch(ev) {
            case 'phase':
                document.getElementById('ws-phase').textContent = d.message||d.phase;
                break;
            case 'sentenceComplete':
                this._addSentRow(d.original, d.translation, false);
                document.getElementById('progress-bar').style.width = d.percent+'%';
                document.getElementById('prog-label').textContent = d.completed+'/'+d.total;
                document.getElementById('prog-pct').textContent = d.percent+'%';
                document.getElementById('ws-tokens').textContent = Utils.formatNumber(d.tokensIn+d.tokensOut)+' tokens';
                document.getElementById('ws-detail').textContent = `Ch${d.chapterIndex+1} #${d.sentenceIndex+1}`;
                // 每5句保存
                if(d.completed % 5 === 0) this._saveProgress(d);
                break;
            case 'chapterComplete':
                this._saveProgress(null);
                break;
            case 'glossaryUpdate':
                this._renderGlossary(d.glossary);
                break;
            case 'styleAnalyzed':
                this._renderStyle(d.style);
                break;
            case 'summaryUpdate':
                this._renderSummary(d);
                break;
            case 'autoPaused':
                document.getElementById('pause-bar').classList.add('show');
                this._setDot('paused');
                document.getElementById('ws-phase').textContent = d.message||'已暂停';
                book.status='paused'; book.updatedAt=Date.now(); this._saveBook(book);
                break;
            case 'error':
                this._setDot('error');
                document.getElementById('ws-detail').textContent = d.message||'';
                break;
        }
    }
    _saveProgress(d) {
        const book = this._getBook(this.currentBookId);
        if(!book||!this.engine) return;
        book.completed = this.engine.completedSentences;
        book.tokensIn = this.engine.tokensInput;
        book.tokensOut = this.engine.tokensOutput;
        book.glossary = this.engine.glossary.toJSON();
        book.styleProfile = this.engine.styleProfile;
        book.globalSummary = this.engine.globalSummary;
        book.chapterSummaries = this.engine.chapterSummaries;
        book.updatedAt = Date.now();
        this._saveBook(book);
    }
    _onComplete() {
        const book = this._getBook(this.currentBookId);
        if(book){
            book.status='completed'; book.results=this.translationResults;
            book.completed=book.total; book.updatedAt=Date.now();
            book.glossary=this.engine.glossary.toJSON();
            book.styleProfile=this.engine.styleProfile;
            book.globalSummary=this.engine.globalSummary;
            book.chapterSummaries=this.engine.chapterSummaries;
            book.tokensIn=this.engine.tokensInput;
            book.tokensOut=this.engine.tokensOutput;
            this._saveBook(book);
        }
        this._setDot('');
        document.getElementById('ws-phase').textContent='完成';
        document.getElementById('progress-bar').style.width='100%';
        document.getElementById('prog-pct').textContent='100%';
        const banner=document.getElementById('done-banner');
        banner.classList.remove('hidden');
        document.getElementById('done-summary').textContent=`共翻译 ${this.engine.completedSentences} 句，消耗 ${Utils.formatNumber(this.engine.tokensInput+this.engine.tokensOutput)} tokens`;
    }
    _onCancelled() {
        const book = this._getBook(this.currentBookId);
        if(book){ book.status='cancelled'; book.updatedAt=Date.now(); this._saveBook(book); }
        this._setDot('');
        document.getElementById('ws-phase').textContent='已取消';
    }

    /* ── 工作台UI工具 ── */
    _addSentRow(src, tgt, failed) {
        const srcList=document.getElementById('src-list'), tgtList=document.getElementById('tgt-list');
        const s=document.createElement('div'); s.className='sent-row'; s.textContent=src;
        const t=document.createElement('div'); t.className='sent-row'+(failed?' failed':''); t.textContent=tgt;
        srcList.appendChild(s); tgtList.appendChild(t);
        if(this._autoScroll){ srcList.scrollTop=srcList.scrollHeight; tgtList.scrollTop=tgtList.scrollHeight; }
    }
    _setDot(cls) {
        const dot=document.getElementById('ws-dot');
        dot.className='ws-dot'; if(cls) dot.classList.add(cls);
    }
    _renderGlossary(gm) {
        document.getElementById('gl-count').textContent=gm.entries.length;
        const body=document.getElementById('gl-body');
        body.innerHTML=gm.entries.slice(0,100).map(e=>{
            const catCls='gl-cat gl-cat-'+e.category;
            const catLabel={character:'👤角色',location:'📍地点',item:'🗡️物品',organization:'🏛️组织',concept:'💡概念',other:'📌其他'}[e.category]||e.category;
            return `<tr><td>${Utils.escapeHtml(e.original)}</td><td>${Utils.escapeHtml(e.translation)}</td><td><span class="${catCls}">${catLabel}</span></td><td>${e.locked?'🔒':''}</td></tr>`;
        }).join('');
    }
    _renderStyle(style) {
        if(!style) return;
        const el=document.getElementById('style-content');
        el.innerHTML=`<p><strong>文风摘要：</strong>${Utils.escapeHtml(style.style_summary||'')}</p>
            <p><strong>语体：</strong>${Utils.escapeHtml(style.register||'')}</p>
            <p><strong>叙事语气：</strong>${Utils.escapeHtml(style.narrative_tone||'')}</p>
            <p><strong>翻译指导：</strong></p><ul>${(style.translation_guidelines||[]).map(g=>'<li>'+Utils.escapeHtml(g)+'</li>').join('')}</ul>`;
    }
    _renderSummary(d) {
        const el=document.getElementById('summary-content');
        if(d.type==='global') el.innerHTML=`<p><strong>全局摘要：</strong>${Utils.escapeHtml(d.summary)}</p>`+(el.innerHTML.includes('章节')?el.innerHTML.slice(el.innerHTML.indexOf('<p><strong>章节')):'');
        else if(d.type==='chapter') {
            let html=el.innerHTML;
            const tag=`<p><strong>章节${d.chapterIndex+1}：</strong>${Utils.escapeHtml(d.summary)}</p>`;
            if(!html.includes('章节'+(d.chapterIndex+1))) html+=tag;
            el.innerHTML=html;
        }
    }

    /* ── 工作台按钮绑定 ── */
    _bindWork() {
        document.getElementById('btn-pause').addEventListener('click',()=>{
            if(!this.engine)return;
            if(this.engine._paused){this.engine.resume();document.getElementById('pause-bar').classList.remove('show');this._setDot('active');document.getElementById('btn-pause').textContent='⏸ 暂停';}
            else{this.engine.pause();document.getElementById('pause-bar').classList.add('show');this._setDot('paused');document.getElementById('btn-pause').textContent='▶ 继续';
                const bk=this._getBook(this.currentBookId);if(bk){bk.status='paused';bk.updatedAt=Date.now();this._saveBook(bk);this._saveProgress(null);}
            }
        });
        document.getElementById('btn-resume-bar').addEventListener('click',()=>{
            if(this.engine){this.engine.resume();document.getElementById('pause-bar').classList.remove('show');this._setDot('active');document.getElementById('btn-pause').textContent='⏸ 暂停';
                const bk=this._getBook(this.currentBookId);if(bk){bk.status='translating';bk.updatedAt=Date.now();this._saveBook(bk);}
            }
        });
        document.getElementById('btn-cancel').addEventListener('click',()=>{if(this.engine&&confirm('确定取消翻译？'))this.engine.cancel();});
        document.getElementById('btn-export').addEventListener('click',()=>document.getElementById('modal-export').classList.remove('hidden'));
        document.getElementById('btn-done-export').addEventListener('click',()=>document.getElementById('modal-export').classList.remove('hidden'));
        document.getElementById('btn-done-shelf').addEventListener('click',()=>{this._showPage('shelf');this._renderShelf();});
        // 标签切换
        document.querySelectorAll('.wtab').forEach(tab=>{
            tab.addEventListener('click',()=>{
                document.querySelectorAll('.wtab').forEach(t=>t.classList.remove('active'));
                document.querySelectorAll('.wpanel').forEach(p=>p.classList.remove('active'));
                tab.classList.add('active');
                document.getElementById('panel-'+tab.dataset.tab).classList.add('active');
            });
        });
        // 自动滚动检测
        const tgt=document.getElementById('tgt-list');
        tgt.addEventListener('scroll',()=>{this._autoScroll=tgt.scrollTop+tgt.clientHeight>=tgt.scrollHeight-30;});
        // 术语搜索
        document.getElementById('gl-search').addEventListener('input',e=>{
            if(!this.engine)return;
            const results=this.engine.glossary.search(e.target.value);
            const tmp=new GlossaryManager();tmp.entries=results;
            this._renderGlossary(tmp);
        });
    }

    /* ── 阅读器 ── */
    _openReader(book) {
        this.currentBookId=book.id;
        document.getElementById('reader-title').textContent=book.fileName;
        this._renderReaderContent(book,'bilingual');
        document.querySelectorAll('.rm-btn').forEach(b=>b.classList.remove('active'));
        document.querySelector('.rm-btn[data-mode="bilingual"]').classList.add('active');
        this._showPage('reader');
    }
    _renderReaderContent(book, mode) {
        const body=document.getElementById('reader-body');
        if(!book.results||book.results.length===0){body.innerHTML='<div class="panel-empty">暂无翻译内容</div>';return;}
        let html='';
        for(const ch of book.results){
            html+=`<div class="reader-chapter">${Utils.escapeHtml(ch.title)}</div>`;
            for(const s of ch.sentences){
                if(mode==='bilingual') html+=`<div class="reader-para"><div class="reader-src">${Utils.escapeHtml(s.original)}</div><div class="reader-tgt">${Utils.escapeHtml(s.translation)}</div></div>`;
                else if(mode==='translated') html+=`<div class="reader-para"><div class="reader-tgt">${Utils.escapeHtml(s.translation)}</div></div>`;
                else html+=`<div class="reader-para"><div class="reader-src">${Utils.escapeHtml(s.original)}</div></div>`;
            }
        }
        body.innerHTML=html;
    }
    _bindReader() {
        document.getElementById('btn-reader-back').addEventListener('click',()=>{this._showPage('shelf');this._renderShelf();});
        document.getElementById('btn-reader-export').addEventListener('click',()=>document.getElementById('modal-export').classList.remove('hidden'));
        document.getElementById('btn-reader-delete').addEventListener('click',()=>{
            if(confirm('确定删除这本书？')){this._deleteBook(this.currentBookId);this._showPage('shelf');this._renderShelf();}
        });
        document.querySelectorAll('.rm-btn').forEach(btn=>{
            btn.addEventListener('click',()=>{
                document.querySelectorAll('.rm-btn').forEach(b=>b.classList.remove('active'));
                btn.classList.add('active');
                const book=this._getBook(this.currentBookId);
                if(book) this._renderReaderContent(book,btn.dataset.mode);
            });
        });
    }

    /* ── 弹窗绑定 ── */
    _bindModals() {
        // 设置保存
        document.getElementById('api-provider').addEventListener('change',()=>this._toggleCustomUrl());
        document.getElementById('api-reasoning').addEventListener('change',()=>this._toggleCustomTemp());
        document.getElementById('api-keys').addEventListener('input',()=>this._updateKeyCountHint());
        document.getElementById('btn-save-settings').addEventListener('click',()=>{
            const apiKeys = document.getElementById('api-keys').value.split('\n').map(k=>k.trim()).filter(k=>k);
            if(apiKeys.length===0){alert('请至少填写一个API密钥');return;}
            const reasoning = document.getElementById('api-reasoning').value;
            let temperature;
            if(reasoning==='custom'){
                temperature = parseFloat(document.getElementById('api-temp').value)||0.3;
            } else {
                temperature = this._reasoningToTemp(reasoning) || 0.3;
            }
            this.settings={
                provider:document.getElementById('api-provider').value,
                apiKeys,
                baseUrl:document.getElementById('api-base-url').value,
                model:document.getElementById('api-model').value,
                reasoning,
                temperature,
                maxTokens:parseInt(document.getElementById('api-max-tokens').value)||1024
            };
            Utils.saveLocal('settings',this.settings);
            document.getElementById('modal-settings').classList.add('hidden');
        });
        // 添加术语
        document.getElementById('btn-add-term').addEventListener('click',()=>document.getElementById('modal-add-term').classList.remove('hidden'));
        document.getElementById('btn-confirm-term').addEventListener('click',()=>{
            const src=document.getElementById('term-src').value.trim(),tgt=document.getElementById('term-tgt').value.trim(),cat=document.getElementById('term-cat').value;
            if(!src||!tgt){alert('请填写原文和译文');return;}
            if(this.engine){this.engine.glossary.addOrUpdate({original:src,translation:tgt,category:cat,source:'manual'});this._renderGlossary(this.engine.glossary);}
            document.getElementById('term-src').value='';document.getElementById('term-tgt').value='';
            document.getElementById('modal-add-term').classList.add('hidden');
        });
        // 导入术语
        document.getElementById('btn-import-gl').addEventListener('click',()=>{
            const input=document.createElement('input');input.type='file';input.accept='.json';
            input.addEventListener('change',()=>{
                if(!input.files[0])return;
                const r=new FileReader();r.onload=()=>{
                    try{const data=JSON.parse(r.result);if(this.engine){if(data.entries)this.engine.glossary.fromJSON(data);else if(Array.isArray(data))this.engine.glossary.addBatch(data);this._renderGlossary(this.engine.glossary);}}catch(e){alert('JSON格式错误');}
                };r.readAsText(input.files[0]);
            });input.click();
        });
        // 导出
        document.querySelectorAll('.export-item').forEach(item=>{
            item.addEventListener('click',()=>{
                const fmt=item.dataset.fmt;
                const book=this._getBook(this.currentBookId);
                const results=book?book.results:this.translationResults;
                if(!results||results.length===0){alert('没有可导出的内容');return;}
                const name=book?book.fileName:'export';
                if(fmt==='txt'){
                    const txt=results.map(ch=>ch.title+'\n\n'+ch.sentences.map(s=>s.translation).join('\n')).join('\n\n---\n\n');
                    Utils.downloadFile(txt,name+'_译文.txt');
                }else if(fmt==='bilingual'){
                    const txt=results.map(ch=>ch.title+'\n\n'+ch.sentences.map(s=>'[原] '+s.original+'\n[译] '+s.translation).join('\n\n')).join('\n\n---\n\n');
                    Utils.downloadFile(txt,name+'_双语.txt');
                }else if(fmt==='json'){
                    Utils.downloadFile(JSON.stringify(book||{results},null,2),name+'_完整.json','application/json');
                }else if(fmt==='glossary'){
                    const gl=book&&book.glossary?book.glossary:(this.engine?this.engine.glossary.toJSON():{entries:[]});
                    Utils.downloadFile(JSON.stringify(gl,null,2),name+'_术语表.json','application/json');
                }
                document.getElementById('modal-export').classList.add('hidden');
            });
        });
        // 点击背景关闭弹窗
        document.querySelectorAll('.modal-bg').forEach(bg=>{
            bg.addEventListener('click',e=>{if(e.target===bg)bg.classList.add('hidden');});
        });
    }
} /* end UIController */
