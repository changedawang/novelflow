/* NovelFlow — 组件样式 */

/* ═══ 1. 书架页 ═══ */
.shelf-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--sp-lg)}
.shelf-header h2{font-family:var(--font-heading);font-size:1.4rem;color:var(--text-primary)}
.shelf-empty{text-align:center;padding:var(--sp-xl) var(--sp-md);color:var(--text-dim)}
.shelf-empty-icon{font-size:3rem;margin-bottom:var(--sp-sm);opacity:.5}
.shelf-empty p{margin:4px 0}.shelf-empty .sub{font-size:.85rem}
.shelf-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:var(--sp-md)}

.book-card{position:relative;border-radius:var(--r-md);overflow:hidden;cursor:pointer;transition:all .3s var(--ease);box-shadow:var(--shadow-book);background:linear-gradient(135deg,var(--paper-lightest) 0%,var(--paper-light) 40%,var(--paper-base) 100%);border:1px solid var(--border-mid)}
.book-card:hover{transform:translateY(-4px) scale(1.02);box-shadow:0 12px 40px rgba(58,46,31,.22)}
.book-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:6px;background:linear-gradient(180deg,var(--accent),var(--accent-hover));border-radius:var(--r-md) 0 0 var(--r-md)}
.book-card-inner{padding:20px 16px 16px 20px;display:flex;flex-direction:column;min-height:200px}
.book-emoji{font-size:2.2rem;margin-bottom:10px}
.book-title{font-family:var(--font-heading);font-size:.95rem;font-weight:700;color:var(--text-primary);line-height:1.4;margin-bottom:6px;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
.book-lang{font-family:var(--font-ui);font-size:.7rem;color:var(--text-dim);margin-bottom:auto;padding-bottom:12px}
.book-progress{margin-top:auto}
.book-progress-bar{height:4px;background:var(--paper-mid);border-radius:2px;overflow:hidden;margin-bottom:6px}
.book-progress-fill{height:100%;border-radius:2px;transition:width .5s var(--ease);background:linear-gradient(90deg,var(--accent),var(--accent-hover))}
.book-progress-fill.complete{background:linear-gradient(90deg,var(--success),#6a8a57)}
.book-meta{display:flex;justify-content:space-between;align-items:center}
.book-status{font-family:var(--font-ui);font-size:.7rem;font-weight:600;padding:2px 8px;border-radius:10px;letter-spacing:.3px}
.book-status.s-translating{background:var(--accent-light);color:var(--accent)}
.book-status.s-paused{background:rgba(184,134,11,.15);color:var(--warning)}
.book-status.s-completed{background:rgba(90,114,71,.15);color:var(--success)}
.book-status.s-cancelled{background:rgba(160,65,58,.1);color:var(--danger)}
.book-date{font-family:var(--font-ui);font-size:.65rem;color:var(--text-dim)}
.book-delete{position:absolute;top:8px;right:8px;width:24px;height:24px;border-radius:50%;background:rgba(160,65,58,.8);color:#fff;border:none;font-size:.7rem;cursor:pointer;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .2s}
.book-card:hover .book-delete{opacity:1}

/* ═══ 2. 上传页 ═══ */
.upload-card{max-width:520px;margin:var(--sp-xl) auto}
.upload-area{text-align:center;padding:var(--sp-xl) var(--sp-lg);border:2px dashed var(--border-mid);border-radius:var(--r-lg);background:var(--paper-lightest);transition:all .3s var(--ease);cursor:pointer}
.upload-area.dragover{border-color:var(--accent);background:var(--accent-light);box-shadow:0 0 0 4px var(--accent-light)}
.upload-icon{font-size:3rem;display:block;margin-bottom:var(--sp-md)}
.upload-area h3{font-family:var(--font-heading);margin-bottom:8px;color:var(--text-primary)}
.upload-area p{font-family:var(--font-ui);color:var(--text-dim);font-size:.85rem;margin-bottom:var(--sp-md)}
.upload-or{margin-top:var(--sp-md);padding-top:var(--sp-md);border-top:1px solid var(--border-light)}

/* ═══ 3. 配置页 ═══ */
.config-card{max-width:600px;margin:0 auto;background:var(--paper-lightest);border:1px solid var(--border-mid);border-radius:var(--r-lg);padding:var(--sp-lg);box-shadow:var(--shadow-md)}
.config-header h3{font-family:var(--font-heading);font-size:1.15rem;margin-bottom:var(--sp-md)}
.config-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--sp-sm);margin-bottom:var(--sp-md)}
.cstat{text-align:center;padding:12px 8px;background:var(--paper-light);border-radius:var(--r-md);border:1px solid var(--border-light)}
.cstat-val{display:block;font-family:var(--font-mono);font-size:1.3rem;font-weight:700;color:var(--accent)}
.cstat-lbl{display:block;font-family:var(--font-ui);font-size:.7rem;color:var(--text-dim);margin-top:2px;text-transform:uppercase}
.config-preview{max-height:120px;overflow-y:auto;padding:var(--sp-sm);background:var(--paper-light);border-radius:var(--r-sm);border:1px solid var(--border-light);font-size:.8rem;color:var(--text-secondary);line-height:1.6;margin-bottom:var(--sp-md);font-family:var(--font-mono)}
.config-form{margin-bottom:var(--sp-lg)}
.cfg-row{display:flex;align-items:center;gap:var(--sp-sm);margin-bottom:var(--sp-sm)}
.cfg-row label{min-width:90px;flex-shrink:0}
.cfg-row select,.cfg-row input{flex:1}
.cfg-hint{font-family:var(--font-ui);font-size:.72rem;color:var(--text-dim);white-space:nowrap}
.cfg-advanced{margin-top:var(--sp-sm);border:1px solid var(--border-light);border-radius:var(--r-md);padding:var(--sp-sm) var(--sp-md)}
.cfg-advanced summary{font-family:var(--font-ui);font-size:.85rem;font-weight:600;cursor:pointer;color:var(--text-secondary);padding:4px 0}
.cfg-advanced[open]{padding-bottom:var(--sp-md)}
.config-actions{text-align:center}

/* ═══ 4. 翻译工作台 ═══ */
.work-topbar{display:flex;align-items:center;gap:var(--sp-md);margin-bottom:var(--sp-md);padding-bottom:var(--sp-sm);border-bottom:1px solid var(--border-light)}
.work-title{flex:1;font-family:var(--font-heading);font-size:1rem;font-weight:600;color:var(--text-primary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.work-actions{display:flex;gap:6px}
.pause-bar{display:none;align-items:center;justify-content:center;gap:var(--sp-md);padding:10px var(--sp-md);background:rgba(184,134,11,.12);border:1px solid var(--warning);border-radius:var(--r-md);margin-bottom:var(--sp-md);font-family:var(--font-ui);font-size:.85rem;color:var(--warning);font-weight:600}
.pause-bar.show{display:flex}
.work-status{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:var(--sp-sm);margin-bottom:var(--sp-sm);font-family:var(--font-ui);font-size:.82rem}
.ws-left,.ws-right{display:flex;align-items:center;gap:8px}
.ws-dot{width:8px;height:8px;border-radius:50%;background:var(--text-dim);flex-shrink:0}
.ws-dot.active{background:var(--success);box-shadow:0 0 6px var(--success);animation:pulse 1.5s infinite}
.ws-dot.paused{background:var(--warning)}.ws-dot.error{background:var(--danger)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.ws-phase{font-weight:600;color:var(--text-primary)}
.ws-detail{color:var(--text-dim)}
.ws-tokens{font-family:var(--font-mono);font-size:.75rem;color:var(--text-dim);padding:2px 8px;background:var(--paper-light);border-radius:var(--r-sm)}
.progress-wrap{margin-bottom:var(--sp-md)}
.progress-track{height:8px;background:var(--paper-mid);border-radius:4px;overflow:hidden;box-shadow:inset 0 1px 3px rgba(0,0,0,.1)}
.progress-bar{height:100%;width:0%;border-radius:4px;background:linear-gradient(90deg,var(--accent),var(--accent-hover));transition:width .4s var(--ease)}
.progress-info{display:flex;justify-content:space-between;margin-top:4px;font-family:var(--font-mono);font-size:.75rem;color:var(--text-dim)}
.done-banner{text-align:center;padding:var(--sp-lg);background:rgba(90,114,71,.08);border:1px solid var(--success);border-radius:var(--r-lg);margin-bottom:var(--sp-md)}
.done-banner h3{color:var(--success);margin-bottom:8px;font-family:var(--font-heading)}
.done-banner p{font-family:var(--font-ui);font-size:.85rem;color:var(--text-secondary);margin-bottom:var(--sp-md)}
.done-actions{display:flex;justify-content:center;gap:var(--sp-sm)}
.work-tabs{display:flex;gap:2px;border-bottom:2px solid var(--border-mid);margin-bottom:var(--sp-md);overflow-x:auto}
.wtab{font-family:var(--font-ui);font-size:.82rem;padding:8px 16px;border:none;background:transparent;color:var(--text-dim);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;transition:all .2s;white-space:nowrap}
.wtab:hover{color:var(--text-primary)}
.wtab.active{color:var(--accent);border-bottom-color:var(--accent);font-weight:600}
.wtab-badge{font-size:.7rem;background:var(--accent-light);color:var(--accent);padding:1px 6px;border-radius:8px;margin-left:4px}
.wpanel{display:none}.wpanel.active{display:block}
.trans-view{display:grid;grid-template-columns:1fr 1fr;gap:2px;border:1px solid var(--border-light);border-radius:var(--r-md);overflow:hidden;background:var(--border-light)}
.trans-col{background:var(--paper-lightest)}
.trans-col-head{font-family:var(--font-ui);font-size:.75rem;font-weight:600;color:var(--text-dim);text-transform:uppercase;padding:8px 12px;background:var(--paper-light);border-bottom:1px solid var(--border-light);letter-spacing:.5px}
.trans-col-body{padding:8px;max-height:50vh;overflow-y:auto}
.sent-row{padding:6px 8px;border-radius:var(--r-sm);font-size:.85rem;line-height:1.6;margin-bottom:2px;transition:background .2s}
.sent-row:hover{background:var(--accent-light)}
.sent-row.current{background:rgba(139,69,19,.08);border-left:3px solid var(--accent);padding-left:5px}
.sent-row.failed{color:var(--danger);opacity:.7}
.sent-row-main{white-space:pre-wrap}
.sent-row-note{font-size:.78em;color:#6b5b4f;background:linear-gradient(135deg,rgba(139,69,19,.08),rgba(139,69,19,.04));border-left:3px solid rgba(139,69,19,.4);padding:6px 10px;margin:6px 0 0 0;border-radius:0 6px 6px 0;line-height:1.5}
.gl-toolbar{display:flex;gap:var(--sp-sm);margin-bottom:var(--sp-md);flex-wrap:wrap}
.gl-toolbar input{flex:1;min-width:120px}
.gl-table{width:100%;border-collapse:collapse;font-family:var(--font-ui);font-size:.82rem}
.gl-table th{text-align:left;padding:8px;color:var(--text-dim);font-size:.72rem;text-transform:uppercase;border-bottom:2px solid var(--border-mid);letter-spacing:.5px}
.gl-table td{padding:6px 8px;border-bottom:1px solid var(--border-light)}
.gl-table tr:hover td{background:var(--accent-light)}
.gl-cat{font-size:.7rem;padding:2px 6px;border-radius:8px;font-weight:600}
.gl-cat-character{background:rgba(139,69,19,.1);color:var(--cat-char)}
.gl-cat-location{background:rgba(90,114,71,.1);color:var(--cat-loc)}
.gl-cat-item{background:rgba(184,134,11,.1);color:var(--cat-item)}
.gl-cat-organization{background:rgba(74,107,138,.1);color:var(--cat-org)}
.gl-cat-concept{background:rgba(123,94,167,.1);color:var(--cat-concept)}
.gl-cat-other{background:rgba(154,138,110,.1);color:var(--cat-other)}
.panel-content{padding:var(--sp-md);background:var(--paper-lightest);border:1px solid var(--border-light);border-radius:var(--r-md);min-height:100px;font-family:var(--font-ui);font-size:.85rem;line-height:1.7;color:var(--text-secondary)}
.panel-empty{text-align:center;color:var(--text-dim);padding:var(--sp-lg)}

/* ═══ 5. 沉浸式阅读器 ═══ */
.page-reader{position:fixed;inset:0;z-index:300;display:flex;flex-direction:column;overflow:hidden;background:var(--rd-bg,#f5f0e8);color:var(--rd-text,#2c2417)}
.rd-topbar{position:fixed;top:0;left:0;right:0;display:flex;align-items:center;gap:8px;padding:6px 12px;background:var(--rd-bar,rgba(245,240,232,.95));border-bottom:1px solid var(--rd-border,rgba(0,0,0,.08));backdrop-filter:blur(10px);z-index:310;transition:transform .3s,opacity .3s;min-height:44px}
.rd-topbar.hid{transform:translateY(-100%);opacity:0;pointer-events:none}
.rd-back{background:none;border:none;font-size:1.2rem;cursor:pointer;color:var(--rd-text,#2c2417);padding:4px 6px}
.rd-title{flex:1;font-family:var(--font-heading);font-size:.9rem;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--rd-text,#2c2417)}
.rd-top-actions{display:flex;gap:4px;align-items:center}
.rd-progress-badge{background:linear-gradient(135deg,#4a7c59,#3d6b4a);color:#fff;font-size:.68rem;font-weight:600;padding:2px 7px;border-radius:10px;font-family:var(--font-mono)}
.rd-progress-badge.complete{background:linear-gradient(135deg,#2e7d32,#1b5e20)}
.rd-icon-btn{background:none;border:none;font-size:1rem;cursor:pointer;padding:5px;border-radius:var(--r-sm)}
.rd-icon-btn:hover{background:var(--rd-hover,rgba(0,0,0,.06))}
.rd-content{position:absolute;inset:0;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:16px 16px 24px;max-width:720px;margin:0 auto;width:100%}
.rd-chapter-title{font-family:var(--font-heading);font-size:1.1rem;font-weight:700;text-align:center;padding:8px 0;color:var(--rd-text,#2c2417);border-bottom:1px solid var(--rd-border,rgba(0,0,0,.08));margin-bottom:10px}
.rd-body{font-family:var(--rd-ff,'Noto Serif SC',Georgia,serif);font-size:var(--rd-fs,18px);line-height:var(--rd-lh,1.8);letter-spacing:.02em;text-align:justify;word-break:break-all}
.rd-body .reader-para{text-indent:2em;margin-bottom:1.2em}
.rd-body .reader-tgt{color:var(--rd-text,#2c2417)}
.rd-body .reader-src{color:var(--rd-dim,#8a7e6e);font-size:.85em;font-style:italic;text-indent:2em;margin-top:4px;opacity:.7}
.rd-body .reader-pending{color:var(--rd-dim,#8a7e6e);font-style:italic;opacity:.5}
.rd-body .reader-note{font-size:.78em;color:#6b5b4f;background:linear-gradient(135deg,rgba(139,69,19,.08),rgba(139,69,19,.04));border-left:3px solid rgba(139,69,19,.4);padding:6px 10px;margin:6px 0 4px 1em;border-radius:0 6px 6px 0;text-indent:0;line-height:1.5}
.rd-body .reader-para{position:relative}
.rd-body .reader-actions{position:absolute;right:0;top:0;display:flex;gap:4px;opacity:0;transition:opacity .2s;padding:4px}
.rd-body .reader-para:hover .reader-actions{opacity:1}
.ra-btn{width:28px;height:28px;border:none;border-radius:50%;background:var(--rd-hover,rgba(0,0,0,.06));cursor:pointer;font-size:.85rem;display:flex;align-items:center;justify-content:center;transition:all .2s}
.ra-btn:hover{background:var(--accent,#8b4513);transform:scale(1.1)}
.ra-btn:active{transform:scale(.95)}
.rd-progress-line{height:2px;background:var(--rd-border,rgba(0,0,0,.06));flex-shrink:0}
.rd-progress-fill{height:100%;background:var(--accent,#8b4513);width:0%;transition:width .3s}
.rd-bottombar{position:fixed;bottom:0;left:0;right:0;background:var(--rd-bar,rgba(245,240,232,.95));border-top:1px solid var(--rd-border,rgba(0,0,0,.08));backdrop-filter:blur(10px);padding-bottom:env(safe-area-inset-bottom);z-index:310;flex-shrink:0;transition:transform .3s,opacity .3s}
.rd-bottombar.hid{transform:translateY(100%);opacity:0;pointer-events:none}
.rd-nav-row{display:flex;align-items:center;justify-content:space-between;padding:6px 12px;border-bottom:1px solid var(--rd-border,rgba(0,0,0,.05))}
.rd-nav-btn{background:none;border:1px solid var(--rd-border,rgba(0,0,0,.1));font-family:var(--font-ui);font-size:.8rem;color:var(--rd-dim,#8a7e6e);cursor:pointer;padding:6px 18px;border-radius:16px;transition:all .25s;letter-spacing:.3px}
.rd-nav-btn:hover,.rd-nav-btn:active{background:var(--accent,#8b4513);color:#fff;border-color:var(--accent,#8b4513);box-shadow:0 2px 10px rgba(139,69,19,.25)}
.rd-nav-btn:active{transform:scale(.95)}
.rd-ch-ind{font-family:var(--font-mono);font-size:.78rem;color:var(--rd-dim,#8a7e6e);background:var(--rd-hover,rgba(0,0,0,.04));padding:4px 12px;border-radius:12px}
.rd-toolbar{display:flex;justify-content:space-around;padding:8px 0 10px}
.rd-tool{display:flex;flex-direction:column;align-items:center;gap:3px;background:none;border:none;cursor:pointer;padding:8px 14px;border-radius:12px;color:var(--rd-dim,#8a7e6e);min-width:60px;transition:all .25s}
.rd-tool:hover{background:var(--rd-hover,rgba(0,0,0,.05));color:var(--rd-text,#2c2417);transform:translateY(-1px)}
.rd-tool:active{transform:translateY(0) scale(.96)}
.rd-tool-icon{font-size:1.3rem;line-height:1}
.rd-tool span:last-child{font-family:var(--font-ui);font-size:.7rem;letter-spacing:.3px;font-weight:500}
.rd-toc-overlay{position:fixed;inset:0;z-index:350;background:rgba(0,0,0,.4);transition:opacity .25s}
.rd-toc-overlay.hidden{opacity:0;pointer-events:none}
.rd-toc-panel{width:280px;max-width:80vw;background:var(--rd-bar,#f5f0e8);height:100%;overflow-y:auto;box-shadow:4px 0 20px rgba(0,0,0,.2);transition:transform .3s var(--ease)}
.rd-toc-overlay.hidden .rd-toc-panel{transform:translateX(-100%)}
.rd-toc-head{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid var(--rd-border,rgba(0,0,0,.08))}
.rd-toc-head h3{font-family:var(--font-heading);font-size:1rem;color:var(--rd-text,#2c2417)}
.rd-toc-close{background:none;border:none;font-size:1.2rem;cursor:pointer;color:var(--rd-dim,#8a7e6e);padding:4px 8px}
.rd-toc-item{display:block;width:100%;text-align:left;background:none;border:none;padding:12px 20px;font-family:var(--font-ui);font-size:.9rem;color:var(--rd-text,#2c2417);cursor:pointer;transition:background .15s;border-left:3px solid transparent}
.rd-toc-item:hover{background:var(--rd-hover,rgba(0,0,0,.04))}
.rd-toc-item.active{background:rgba(139,69,19,.1);color:var(--accent,#8b4513);font-weight:600;border-left-color:var(--accent,#8b4513)}
.rd-display-panel{position:fixed;bottom:100px;left:50%;transform:translateX(-50%);z-index:320;background:var(--rd-bar,#f5f0e8);border:1px solid var(--rd-border,rgba(0,0,0,.1));border-radius:var(--r-lg);padding:12px 16px;width:340px;max-width:92vw;max-height:60vh;overflow-y:auto;box-shadow:0 -4px 20px rgba(0,0,0,.15);transition:opacity .2s,transform .2s}
.rd-display-panel.hidden{opacity:0;pointer-events:none;transform:translateX(-50%) translateY(10px)}
.rd-dp-row{display:flex;align-items:flex-start;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--rd-border,rgba(0,0,0,.05));gap:10px}
.rd-dp-row:last-child{border-bottom:none}
.rd-dp-row-fonts{flex-direction:column;align-items:stretch}
.rd-dp-row-fonts .rd-dp-label{margin-bottom:8px}
.rd-dp-row-fonts .rd-dp-fonts{display:flex;flex-wrap:wrap;gap:6px}
.rd-dp-label{font-family:var(--font-ui);font-size:.8rem;color:var(--rd-dim,#8a7e6e);min-width:36px;flex-shrink:0}
.rd-dp-btns{display:flex;align-items:center;gap:8px}
.rd-dp-btn{font-family:var(--font-ui);font-size:.82rem;padding:6px 14px;border:1px solid var(--rd-border,rgba(0,0,0,.12));border-radius:var(--r-md);background:var(--rd-bg,#f5f0e8);color:var(--rd-text,#2c2417);cursor:pointer;transition:all .15s}
.rd-dp-btn:hover{border-color:var(--accent)}
.rd-dp-val{font-family:var(--font-mono);font-size:.82rem;min-width:30px;text-align:center;color:var(--rd-text,#2c2417)}
.rd-mode-btn{font-family:var(--font-ui);font-size:.78rem;padding:6px 12px;border:1px solid var(--rd-border,rgba(0,0,0,.12));border-radius:var(--r-md);background:transparent;color:var(--rd-dim,#8a7e6e);cursor:pointer;transition:all .2s}
.rd-mode-btn:hover{border-color:var(--accent,#8b4513);color:var(--rd-text,#2c2417)}
.rd-mode-btn.active{background:var(--accent,#8b4513);color:#fff;border-color:var(--accent,#8b4513);box-shadow:0 2px 8px rgba(139,69,19,.3)}
.rd-theme-dot{width:28px;height:28px;border-radius:50%;border:2px solid var(--rd-border,rgba(0,0,0,.12));cursor:pointer;flex-shrink:0;transition:all .2s}
.rd-theme-dot.active{border-color:var(--accent,#8b4513);box-shadow:0 0 0 2px var(--accent,#8b4513)}
.rd-theme-dot:hover{transform:scale(1.15)}
/* 字体选择按钮 */
.rd-dp-fonts{flex-wrap:wrap;gap:6px!important}
.rd-font-btn{font-size:.82rem;padding:6px 10px;border:1px solid var(--rd-border,rgba(0,0,0,.12));border-radius:var(--r-md);background:transparent;color:var(--rd-dim,#8a7e6e);cursor:pointer;transition:all .2s;white-space:nowrap}
.rd-font-btn:hover{border-color:var(--accent,#8b4513);color:var(--rd-text,#2c2417)}
.rd-font-btn.active{background:var(--accent,#8b4513);color:#fff;border-color:var(--accent,#8b4513);box-shadow:0 2px 8px rgba(139,69,19,.3)}
.page-reader[data-theme="light"]{--rd-bg:#f5f0e8;--rd-text:#2c2417;--rd-dim:#8a7e6e;--rd-bar:rgba(245,240,232,.96);--rd-border:rgba(0,0,0,.08);--rd-hover:rgba(0,0,0,.04)}
.page-reader[data-theme="warm"]{--rd-bg:#f5ecd7;--rd-text:#3d3222;--rd-dim:#8c7e5e;--rd-bar:rgba(245,236,215,.96);--rd-border:rgba(0,0,0,.07);--rd-hover:rgba(0,0,0,.04)}
.page-reader[data-theme="green"]{--rd-bg:#e0eed3;--rd-text:#2a3a1e;--rd-dim:#6a7d5a;--rd-bar:rgba(224,238,211,.96);--rd-border:rgba(0,0,0,.06);--rd-hover:rgba(0,0,0,.04)}
.page-reader[data-theme="dark"]{--rd-bg:#1a1a1a;--rd-text:#c8c2b8;--rd-dim:#6e6a62;--rd-bar:rgba(30,30,30,.96);--rd-border:rgba(255,255,255,.08);--rd-hover:rgba(255,255,255,.06)}
.page-reader[data-theme="black"]{--rd-bg:#000;--rd-text:#999;--rd-dim:#555;--rd-bar:rgba(10,10,10,.96);--rd-border:rgba(255,255,255,.06);--rd-hover:rgba(255,255,255,.05)}

/* ═══ 6. 弹窗 ═══ */
.modal-bg{position:fixed;inset:0;z-index:200;background:rgba(58,46,31,.5);display:flex;align-items:center;justify-content:center;padding:var(--sp-md);backdrop-filter:blur(4px)}
.modal-card{background:var(--paper-lightest);border:1px solid var(--border-mid);border-radius:var(--r-lg);width:100%;max-width:480px;max-height:90vh;overflow-y:auto;box-shadow:var(--shadow-lg)}
.modal-sm{max-width:380px}
.modal-head{display:flex;align-items:center;justify-content:space-between;padding:var(--sp-md) var(--sp-lg);border-bottom:1px solid var(--border-light)}
.modal-head h3{font-family:var(--font-heading);font-size:1rem}
.modal-close{background:none;border:none;font-size:1.2rem;cursor:pointer;color:var(--text-dim);padding:4px}
.modal-close:hover{color:var(--text-primary)}
.modal-body{padding:var(--sp-lg)}
.fg{margin-bottom:var(--sp-md)}
.fg label{display:block;margin-bottom:4px}
.fg-row{display:grid;grid-template-columns:1fr 1fr;gap:var(--sp-md)}
.modal-note{font-family:var(--font-ui);font-size:.78rem;color:var(--text-dim);text-align:center}
.modal-actions{display:flex;justify-content:flex-end;gap:var(--sp-sm);margin-top:var(--sp-md)}
.export-list{display:flex;flex-direction:column;gap:var(--sp-sm)}
.export-item{display:flex;align-items:center;gap:var(--sp-md);padding:12px var(--sp-md);border:1px solid var(--border-light);border-radius:var(--r-md);cursor:pointer;transition:all .2s}
.export-item:hover{border-color:var(--accent);background:var(--accent-light)}
.export-item span:first-child{font-size:1.5rem}
.export-item strong{font-size:.9rem;display:block}
.export-item p{font-size:.75rem;color:var(--text-dim);margin:2px 0 0}

/* ═══ 边翻边读面板 ═══ */
.live-reader{display:flex;flex-direction:column;height:100%;min-height:400px}
.live-reader-toolbar{display:flex;flex-wrap:wrap;align-items:center;gap:var(--sp-sm);padding:var(--sp-sm);background:var(--paper-light);border-radius:var(--r-md);margin-bottom:var(--sp-sm)}
.live-chapter-sel{flex:1;min-width:120px;max-width:200px;padding:6px 10px;border-radius:var(--r-sm);border:1px solid var(--border-mid);font-family:var(--font-ui);font-size:.85rem;background:var(--paper-lightest)}
.live-reader-modes{display:flex;gap:4px}
.live-mode-btn{padding:6px 12px;border:1px solid var(--border-mid);border-radius:var(--r-sm);background:var(--paper-lightest);font-family:var(--font-ui);font-size:.8rem;cursor:pointer;transition:all .2s}
.live-mode-btn.active{background:var(--accent);color:#fff;border-color:var(--accent)}
.live-reader-progress{margin-left:auto;display:flex;align-items:center;gap:var(--sp-sm);font-family:var(--font-ui);font-size:.85rem;color:var(--text-dim)}
.live-reader-body{flex:1;overflow-y:auto;padding:var(--sp-md);background:var(--paper-lightest);border:1px solid var(--border-light);border-radius:var(--r-md);line-height:1.8}
.live-chapter-title{font-family:var(--font-heading);font-size:1.1rem;font-weight:700;color:var(--text-primary);margin-bottom:var(--sp-md);padding-bottom:var(--sp-sm);border-bottom:1px solid var(--border-light)}
.live-content{font-family:var(--font-serif);font-size:.95rem;color:var(--text-primary)}
.live-para{margin-bottom:var(--sp-md)}
.live-tgt{color:var(--text-primary)}
.live-src{color:var(--text-dim);font-size:.85rem;margin-top:4px;padding-left:var(--sp-sm);border-left:2px solid var(--border-light)}
.live-pending{color:var(--text-dim);opacity:.5;font-style:italic}
.live-note{font-size:.78em;color:#6b5b4f;background:linear-gradient(135deg,rgba(139,69,19,.08),rgba(139,69,19,.04));border-left:3px solid rgba(139,69,19,.4);padding:6px 10px;margin:6px 0 4px 1em;border-radius:0 6px 6px 0;line-height:1.5}
.live-api-log{padding:10px 14px!important;background:var(--paper-light)!important;border-bottom:1px solid var(--border-mid)!important;font-size:.8rem!important;color:var(--text-secondary)!important;max-height:150px!important;overflow-y:auto!important;font-family:var(--font-mono)!important;line-height:1.5!important}
.live-api-log code{display:block;margin-top:4px;padding:6px 8px;background:var(--paper-lightest);border-radius:var(--r-sm);word-break:break-all;max-height:80px;overflow-y:auto}
.live-reader-nav{display:flex;align-items:center;justify-content:center;gap:var(--sp-md);padding:var(--sp-sm);margin-top:var(--sp-sm)}

/* ═══ 优化翻译进度 ═══ */
.optimize-bar{display:flex;align-items:center;gap:var(--sp-md);padding:var(--sp-sm) var(--sp-md);background:linear-gradient(90deg,rgba(139,90,43,.1),rgba(139,90,43,.05));border:1px solid var(--accent);border-radius:var(--r-md);margin-bottom:var(--sp-sm)}
.optimize-bar.hidden{display:none}
.optimize-info{display:flex;flex-direction:column;gap:2px}
.optimize-phase{font-family:var(--font-ui);font-size:.85rem;font-weight:600;color:var(--accent)}
.optimize-detail{font-family:var(--font-ui);font-size:.75rem;color:var(--text-dim)}
.optimize-progress{flex:1;display:flex;align-items:center;gap:var(--sp-sm)}
.optimize-progress .progress-track{flex:1;height:6px}
#optimize-pct{font-family:var(--font-mono);font-size:.8rem;color:var(--accent);min-width:40px}

/* ══ Logs Panel ══ */
.logs-toolbar{display:flex;align-items:center;gap:16px;padding:8px 12px;background:var(--paper-dim);border-bottom:1px solid var(--border-light);font-size:.85rem}
.logs-toolbar label{display:flex;align-items:center;gap:4px;color:var(--text-secondary);cursor:pointer}
.log-stats{margin-left:auto;color:var(--text-dim);font-size:.75rem}
.logs-container{height:calc(100% - 45px);overflow-y:auto;padding:8px;font-family:'Consolas','Monaco',monospace;font-size:.75rem;background:#1e1e1e;color:#d4d4d4}
.log-entry{padding:6px 8px;margin-bottom:4px;border-radius:4px;background:#252526;border-left:3px solid var(--accent);word-break:break-all}
.log-entry.log-request{border-left-color:#569cd6}
.log-entry.log-response{border-left-color:#4ec9b0}
.log-entry.log-error{border-left-color:#f44747;background:#3a1d1d}
.log-entry.log-info{border-left-color:#dcdcaa}
.log-time{color:#808080;margin-right:8px}
.log-type{font-weight:bold;margin-right:8px}
.log-type.req{color:#569cd6}
.log-type.res{color:#4ec9b0}
.log-type.err{color:#f44747}
.log-type.info{color:#dcdcaa}
.log-content{white-space:pre-wrap;margin-top:4px;padding:4px 8px;background:#1e1e1e;border-radius:3px;max-height:200px;overflow-y:auto}
.log-meta{color:#6a9955;font-size:.7rem;margin-top:4px}

@media(max-width:640px){
    .trans-view{grid-template-columns:1fr}
    .config-stats{grid-template-columns:repeat(2,1fr)}
    .shelf-grid{grid-template-columns:repeat(auto-fill,minmax(150px,1fr))}
    .fg-row{grid-template-columns:1fr}
    .live-reader-toolbar{flex-direction:column;align-items:stretch}
    .live-chapter-sel{max-width:none}
    .live-reader-progress{margin-left:0;justify-content:center}
}
