/* ============================================
   NovelFlow — 文本分割器
   智能分句、章节检测
   ============================================ */

class TextSplitter {
    constructor() {
        // 章节检测正则
        this.chapterPatterns = [
            /^(Chapter|CHAPTER)\s+(\d+|[IVXLC]+)/i,
            /^(Part|PART)\s+(\d+|[IVXLC]+|One|Two|Three|Four|Five)/i,
            /^第[一二三四五六七八九十百千零\d]+[章节回卷部篇]/,
            /^(Prologue|PROLOGUE|Epilogue|EPILOGUE)/i,
            /^(BOOK|Book)\s+(\d+|[IVXLC]+)/i,
        ];
    }

    /**
     * 解析全文 → 章节列表
     * 返回: [{ title, sentences: [string] }]
     */
    parse(text) {
        const lines = text.split(/\r?\n/);
        const chapters = this._detectChapters(lines);

        if (chapters.length === 0) {
            // 没检测到章节，整体作为一章
            const allText = text.trim();
            const sentences = this._splitSentences(allText);
            return [{ title: '全文', sentences }];
        }

        // 为每个章节提取句子
        for (const ch of chapters) {
            const chText = lines.slice(ch._startLine, ch._endLine + 1).join('\n').trim();
            // 去掉标题行
            const bodyStart = chText.indexOf('\n');
            const body = bodyStart > 0 ? chText.slice(bodyStart).trim() : chText;
            ch.sentences = this._splitSentences(body);
            delete ch._startLine;
            delete ch._endLine;
        }

        // 过滤空章节
        return chapters.filter(ch => ch.sentences.length > 0);
    }

    /**
     * 检测章节边界
     */
    _detectChapters(lines) {
        const chapters = [];
        let currentStart = -1;
        let currentTitle = '';

        for (let i = 0; i < lines.length; i++) {
            const line = lines[i].trim();
            if (!line) continue;

            let isChapter = false;
            for (const pattern of this.chapterPatterns) {
                if (pattern.test(line)) {
                    isChapter = true;
                    break;
                }
            }

            if (isChapter) {
                // 保存上一章
                if (currentStart >= 0) {
                    chapters.push({
                        title: currentTitle,
                        _startLine: currentStart,
                        _endLine: i - 1,
                    });
                }
                currentStart = i;
                currentTitle = line;
            }
        }

        // 最后一章
        if (currentStart >= 0) {
            chapters.push({
                title: currentTitle,
                _startLine: currentStart,
                _endLine: lines.length - 1,
            });
        }

        return chapters;
    }

    /**
     * 智能分句
     * 处理：英文句号/问号/感叹号、对话引号、缩写（Mr. Mrs. Dr. etc.）
     */
    _splitSentences(text) {
        if (!text.trim()) return [];

        // 先按段落分
        const paragraphs = text.split(/\n\s*\n/).filter(p => p.trim());
        const sentences = [];

        for (const para of paragraphs) {
            const cleaned = para.replace(/\s+/g, ' ').trim();
            if (!cleaned) continue;

            // 使用改进的分句正则
            // 避免在缩写（Mr. Mrs. Dr. St. etc.）后断句
            const abbrevs = '(?:Mr|Mrs|Ms|Dr|Prof|St|Jr|Sr|Inc|Ltd|Corp|vs|etc|al|eg|ie|cf)';
            const sentenceEnders = new RegExp(
                `(?<!${abbrevs})\\.(?=\\s+[A-Z"'"\\(])|[!?]+(?=\\s)|(?<=[。！？」』])`,
                'g'
            );

            let lastIdx = 0;
            let match;
            const regex = new RegExp(sentenceEnders.source, 'g');

            while ((match = regex.exec(cleaned)) !== null) {
                const endIdx = match.index + match[0].length;
                const sent = cleaned.slice(lastIdx, endIdx).trim();
                if (sent.length > 0) {
                    sentences.push(sent);
                }
                lastIdx = endIdx;
            }

            // 剩余部分
            const remaining = cleaned.slice(lastIdx).trim();
            if (remaining.length > 0) {
                // 如果剩余部分太长，按句号简单分割
                if (remaining.length > 300) {
                    const parts = remaining.split(/(?<=[.!?])\s+/);
                    for (const p of parts) {
                        if (p.trim()) sentences.push(p.trim());
                    }
                } else {
                    sentences.push(remaining);
                }
            }
        }

        // 合并过短的句子（< 10字符的非对话句）
        const merged = [];
        for (let i = 0; i < sentences.length; i++) {
            const s = sentences[i];
            if (s.length < 10 && !s.startsWith('"') && !s.startsWith('"') && merged.length > 0) {
                merged[merged.length - 1] += ' ' + s;
            } else {
                merged.push(s);
            }
        }

        return merged;
    }
}
