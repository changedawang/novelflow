/* ============================================
   NovelFlow — 组件样式 v2
   ============================================ */

/* ── 上传区域 ── */
.phase-upload {
    display: flex; align-items: center; justify-content: center;
    min-height: calc(100vh - 104px);
}
.upload-area {
    text-align: center;
    padding: 64px 48px;
    border: 1.5px dashed var(--border);
    border-radius: var(--radius-xl);
    background: var(--bg-card);
    max-width: 540px;
    width: 100%;
    transition: all var(--transition-slow);
    position: relative;
}
.upload-area::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: var(--radius-xl);
    background: linear-gradient(135deg, var(--primary-bg), transparent, var(--accent-bg));
    z-index: -1;
    opacity: 0;
    transition: opacity var(--transition-slow);
}
.upload-area:hover::before, .upload-area.drag-over::before { opacity: 1; }
.upload-area.drag-over {
    border-color: var(--primary);
    background: var(--primary-bg);
    transform: scale(1.01);
}
.upload-icon {
    font-size: 56px;
    margin-bottom: 20px;
    display: block;
    filter: drop-shadow(0 4px 12px rgba(108,140,255,0.2));
}
.upload-area h2 {
    font-size: 22px;
    font-weight: 600;
    margin-bottom: 8px;
    letter-spacing: -0.3px;
}
.upload-area > p { color: var(--text-muted); margin-bottom: 28px; font-size: 14px; }
.upload-btn { margin-bottom: 20px; }
.upload-demo { margin-top: 4px; }

/* ── 预览卡片 ── */
.phase-preview {
    display: flex; justify-content: center;
    padding-top: 16px;
}
.preview-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    max-width: 700px;
    width: 100%;
    overflow: hidden;
    box-shadow: var(--shadow);
}
.preview-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 24px;
    border-bottom: 1px solid var(--border-subtle);
}
.preview-header h3 { font-size: 15px; font-weight: 600; }

.preview-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-bottom: 1px solid var(--border-subtle);
}
.stat {
    display: flex; flex-direction: column; align-items: center;
    padding: 18px 8px;
    position: relative;
}
.stat + .stat::before {
    content: '';
    position: absolute;
    left: 0; top: 20%; height: 60%;
    width: 1px;
    background: var(--border-subtle);
}
.stat-value {
    font-size: 22px;
    font-weight: 700;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}
.stat-label { font-size: 11px; color: var(--text-muted); margin-top: 4px; letter-spacing: 0.5px; text-transform: uppercase; }

.preview-text {
    padding: 16px 24px;
    max-height: 100px;
    overflow-y: auto;
    font-size: 12px;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border-subtle);
    font-family: var(--font-mono);
    line-height: 1.8;
    white-space: pre-wrap;
    background: var(--bg-deep);
}

.preview-config { padding: 20px 24px; }
.config-row {
    display: flex; align-items: center; gap: 14px;
    margin-bottom: 12px;
}
.config-row label {
    min-width: 96px;
    font-size: 13px;
    color: var(--text-secondary);
    flex-shrink: 0;
    font-weight: 500;
}
.config-row input, .config-row select { flex: 1; }
.config-row input[type="number"] { max-width: 80px; }
.config-hint { font-size: 11px; color: var(--text-muted); }

.advanced-config {
    margin-top: 12px;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius);
    overflow: hidden;
}
.advanced-config summary {
    padding: 12px 18px;
    cursor: pointer;
    color: var(--text-secondary);
    font-size: 13px;
    font-weight: 500;
    user-select: none;
    transition: color var(--transition);
}
.advanced-config summary:hover { color: var(--text); }
.advanced-config[open] summary { border-bottom: 1px solid var(--border-subtle); }
.advanced-config .config-row { padding: 0 18px; }
.advanced-config .config-row:first-of-type { margin-top: 12px; }
.advanced-config .config-row:last-of-type { margin-bottom: 16px; }

.preview-actions {
    padding: 20px 24px;
    text-align: center;
    border-top: 1px solid var(--border-subtle);
    background: linear-gradient(180deg, transparent, rgba(108,140,255,0.03));
}

/* ── 状态栏 ── */
.status-bar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 18px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    margin-bottom: 14px;
    flex-wrap: wrap;
    gap: 10px;
    transition: all var(--transition);
}
.status-left, .status-right { display: flex; align-items: center; gap: 12px; }
.status-phase {
    font-weight: 600;
    font-size: 13px;
    display: flex;
    align-items: center;
    gap: 6px;
}
.status-phase::before {
    content: '';
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--success);
    animation: pulse 2s ease-in-out infinite;
}
.status-detail { font-size: 12px; color: var(--text-muted); }
.status-tokens {
    font-size: 12px;
    color: var(--text-muted);
    font-family: var(--font-mono);
    background: var(--bg-deep);
    padding: 3px 10px;
    border-radius: var(--radius-sm);
}

@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
}

.status-bar--warning {
    border-color: rgba(251,191,36,0.3);
    background: linear-gradient(90deg, rgba(251,191,36,0.06), var(--bg-card));
}
.status-bar--warning .status-phase::before { background: var(--warning); }
.status-bar--error {
    border-color: rgba(248,113,113,0.3);
    background: linear-gradient(90deg, rgba(248,113,113,0.06), var(--bg-card));
    animation: pulseError 2s ease-in-out infinite;
}
.status-bar--error .status-phase::before { background: var(--danger); animation: none; }
.status-bar--success {
    border-color: rgba(52,211,153,0.3);
    background: linear-gradient(90deg, rgba(52,211,153,0.06), var(--bg-card));
}
.status-bar--success .status-phase::before { background: var(--success); animation: none; }

@keyframes pulseError {
    0%, 100% { border-color: rgba(248,113,113,0.3); }
    50% { border-color: rgba(248,113,113,0.6); }
}

/* ── 进度条 ── */
.progress-container { margin-bottom: 14px; }
.progress-bar {
    height: 5px;
    background: var(--bg-hover);
    border-radius: 3px;
    overflow: hidden;
}
.progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--primary), var(--accent));
    border-radius: 3px;
    transition: width 0.4s ease;
    position: relative;
}
.progress-fill::after {
    content: '';
    position: absolute;
    right: 0; top: 0; bottom: 0;
    width: 60px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15));
    animation: shimmer 1.5s ease-in-out infinite;
}
@keyframes shimmer {
    0% { opacity: 0; }
    50% { opacity: 1; }
    100% { opacity: 0; }
}
.progress-text {
    display: flex; justify-content: space-between;
    padding: 6px 2px 0;
    font-size: 12px;
    color: var(--text-muted);
    font-family: var(--font-mono);
}

/* ── 标签页 ── */
.tabs {
    display: flex;
    gap: 2px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    padding: 6px 6px 0;
    overflow-x: auto;
}
.tab {
    padding: 11px 18px;
    background: transparent;
    border: none;
    border-radius: var(--radius) var(--radius) 0 0;
    color: var(--text-muted);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    font-family: var(--font);
    transition: all var(--transition);
    white-space: nowrap;
    position: relative;
}
.tab:hover { color: var(--text-secondary); background: var(--bg-hover); }
.tab.active {
    color: var(--primary);
    background: var(--bg);
}
.tab.active::after {
    content: '';
    position: absolute;
    bottom: 0; left: 16px; right: 16px;
    height: 2px;
    background: linear-gradient(90deg, var(--primary), var(--accent));
    border-radius: 1px 1px 0 0;
}

.tab-panel {
    display: none;
    background: var(--bg);
    border: 1px solid var(--border);
    border-top: none;
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    min-height: 400px;
}
.tab-panel.active { display: block; }

/* ── 翻译对照视图 ── */
.translation-view {
    display: flex;
    height: calc(100vh - 340px);
    min-height: 400px;
}
.translation-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}
.translation-col + .translation-col { border-left: 1px solid var(--border-subtle); }
.col-header {
    padding: 12px 20px;
    font-size: 11px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    border-bottom: 1px solid var(--border-subtle);
    background: var(--bg-card);
}
.col-content {
    flex: 1;
    overflow-y: auto;
    padding: 6px 0;
}

.sentence-row {
    display: flex;
    align-items: flex-start;
    padding: 8px 20px;
    gap: 10px;
    transition: background var(--transition);
    cursor: default;
    border-left: 2px solid transparent;
}
.sentence-row:hover { background: rgba(255,255,255,0.02); }
.sentence-row.current {
    background: var(--primary-bg);
    border-left-color: var(--primary);
}
.sentence-idx {
    min-width: 30px;
    font-size: 11px;
    color: var(--text-muted);
    font-family: var(--font-mono);
    text-align: right;
    padding-top: 3px;
    flex-shrink: 0;
    opacity: 0.6;
}
.sentence-text {
    flex: 1;
    font-size: 14px;
    line-height: 1.8;
    word-break: break-word;
}
.col-translated .sentence-text {
    font-family: var(--font-serif);
}
.sentence-text.pending { color: var(--text-muted); font-style: italic; opacity: 0.5; }
.sentence-text.failed { color: var(--danger); font-style: italic; opacity: 0.7; }

/* ── 术语表 ── */
.glossary-toolbar {
    display: flex; gap: 10px;
    padding: 14px 20px;
    border-bottom: 1px solid var(--border-subtle);
    background: var(--bg-card);
}
.glossary-search { flex: 1; }
.glossary-table-wrap {
    overflow-y: auto;
    max-height: calc(100vh - 420px);
}
.glossary-table {
    width: 100%;
    border-collapse: collapse;
}
.glossary-table th {
    padding: 12px 20px;
    text-align: left;
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
    border-bottom: 1px solid var(--border-subtle);
    position: sticky; top: 0;
    background: var(--bg-card);
}
.glossary-table td {
    padding: 10px 20px;
    font-size: 13px;
    border-bottom: 1px solid var(--border-subtle);
}
.glossary-table tr:hover td { background: rgba(255,255,255,0.02); }

.term-category {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.3px;
}
.cat-character { background: rgba(255,126,179,0.12); color: var(--cat-char); }
.cat-location { background: rgba(126,232,208,0.12); color: var(--cat-loc); }
.cat-item { background: rgba(126,200,232,0.12); color: var(--cat-item); }
.cat-organization { background: rgba(168,216,168,0.12); color: var(--cat-org); }
.cat-concept { background: rgba(255,224,138,0.12); color: var(--cat-concept); }
.cat-other { background: var(--bg-hover); color: var(--text-muted); }

.term-actions { display: flex; gap: 2px; }
.term-actions button {
    background: none; border: none;
    color: var(--text-muted);
    cursor: pointer; font-size: 14px;
    padding: 4px 6px;
    border-radius: var(--radius-sm);
    transition: all var(--transition);
}
.term-actions button:hover { background: var(--bg-hover); color: var(--text); }
.term-locked { color: var(--warning) !important; }

/* ── 文风面板 ── */
.style-card { padding: 24px; }
.style-placeholder { color: var(--text-muted); text-align: center; padding: 48px; font-size: 14px; }
.style-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 10px;
    margin-bottom: 20px;
}
.style-item {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius);
    padding: 14px;
    transition: border-color var(--transition);
}
.style-item:hover { border-color: var(--border); }
.style-item-label {
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 6px;
}
.style-item-value {
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
}
.style-description {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius);
    padding: 20px;
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 2;
    color: var(--text-secondary);
}

/* ── 摘要面板 ── */
.summary-card { padding: 24px; }
.summary-placeholder { color: var(--text-muted); text-align: center; padding: 48px; font-size: 14px; }
.summary-section { margin-bottom: 20px; }
.summary-section h4 {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 10px;
}
.summary-text {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius);
    padding: 16px;
    font-size: 13px;
    line-height: 1.9;
    color: var(--text-secondary);
    font-family: var(--font-serif);
}

/* ── 暂停提示条 ── */
.pause-alert {
    display: none;
    align-items: center;
    justify-content: space-between;
    padding: 10px 18px;
    margin-bottom: 10px;
    border-radius: var(--radius);
    background: var(--danger-bg);
    border: 1px solid rgba(248,113,113,0.25);
    animation: slideDown 0.3s ease;
    gap: 12px;
}
.pause-alert.visible { display: flex; }
.pause-alert-text { font-size: 13px; color: var(--danger); font-weight: 500; }
@keyframes slideDown {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
}

/* ── 错误 Toast ── */
.error-toast {
    position: fixed;
    bottom: 24px;
    left: 50%; transform: translateX(-50%);
    background: var(--bg-card-elevated);
    border: 1px solid rgba(248,113,113,0.3);
    color: var(--danger);
    padding: 10px 20px;
    border-radius: var(--radius);
    font-size: 13px;
    z-index: 2000;
    box-shadow: var(--shadow-lg);
    animation: toastIn 0.3s ease;
    max-width: 90vw;
}
@keyframes toastIn {
    from { opacity: 0; transform: translate(-50%, 10px); }
    to { opacity: 1; transform: translate(-50%, 0); }
}

/* ── 导出面板 ── */
.export-options { display: flex; flex-direction: column; gap: 10px; }
.export-option {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 18px;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius);
    cursor: pointer;
    transition: all var(--transition);
}
.export-option:hover {
    border-color: var(--primary);
    background: var(--primary-bg);
}
.export-icon { font-size: 22px; flex-shrink: 0; }
.export-info h4 { font-size: 14px; font-weight: 500; margin-bottom: 2px; }
.export-info p { font-size: 12px; color: var(--text-muted); }

/* ── 设置表单 ── */
.form-group { margin-bottom: 16px; }
.form-group label {
    display: block;
    font-size: 12px;
    color: var(--text-secondary);
    margin-bottom: 6px;
    font-weight: 500;
}
.form-group .form-hint {
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 4px;
}
.form-row { display: flex; gap: 12px; }
.form-row .form-group { flex: 1; }
.form-actions {
    display: flex; gap: 10px;
    justify-content: flex-end;
    padding-top: 12px;
    border-top: 1px solid var(--border-subtle);
    margin-top: 8px;
}

/* ── 完成横幅 ── */
.complete-banner {
    text-align: center;
    padding: 28px;
    background: linear-gradient(135deg, rgba(52,211,153,0.06), rgba(108,140,255,0.06));
    border: 1px solid rgba(52,211,153,0.2);
    border-radius: var(--radius-lg);
    margin-bottom: 14px;
}
.complete-banner h3 {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 6px;
    background: linear-gradient(135deg, var(--success), var(--primary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}
.complete-banner p { color: var(--text-secondary); font-size: 13px; }
.complete-actions { display: flex; gap: 10px; justify-content: center; margin-top: 16px; }
