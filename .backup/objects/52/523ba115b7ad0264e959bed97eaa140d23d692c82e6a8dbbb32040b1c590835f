/* NovelFlow — 现代高级极简主题 */
:root {
    --paper-lightest: #ffffff;
    --paper-light: #faf9f7;
    --paper-base: #f5f4f0;
    --paper-mid: #ebebe9;
    --paper-dark: #d6d6d4;
    --paper-darker: #adadab;
    --paper-darkest: #828280;
    --text-primary: #1d1d1f;
    --text-secondary: #424245;
    --text-dim: #86868b;
    --text-on-accent: #ffffff;
    --accent: #2c6e49;
    --accent-hover: #4c956c;
    --accent-light: rgba(44,110,73,0.1);
    --accent-glow: rgba(44,110,73,0.25);
    --success: #34c759;
    --warning: #f5a623;
    --danger: #ff3b30;
    --info: #007aff;
    --cat-char: #2c6e49;--cat-loc: #4a90e2;--cat-item: #f5a623;--cat-org: #d0021b;--cat-concept: #9013fe;--cat-other: #8b572a;
    --border-light: rgba(0,0,0,0.06);
    --border-mid: rgba(0,0,0,0.12);
    --border-strong: rgba(0,0,0,0.2);
    --shadow-sm: 0 2px 8px rgba(0,0,0,0.04);
    --shadow-md: 0 8px 24px rgba(0,0,0,0.08);
    --shadow-lg: 0 16px 48px rgba(0,0,0,0.12);
    --shadow-book: 0 4px 16px rgba(0,0,0,0.05), 0 1px 4px rgba(0,0,0,0.03);
    --r-sm: 8px;
    --r-md: 14px;
    --r-lg: 20px;
    --font-body: 'Noto Serif SC', 'LXGW WenKai Screen', Georgia, serif;
    --font-heading: 'Noto Serif SC', 'LXGW WenKai Screen', Georgia, serif;
    --font-mono: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
    --font-ui: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    --sp-xs: 6px;--sp-sm: 12px;--sp-md: 20px;--sp-lg: 32px;--sp-xl: 48px;
    --ease: cubic-bezier(0.25, 1, 0.5, 1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:16px;-webkit-text-size-adjust:100%;scroll-behavior:smooth}
body{font-family:var(--font-ui);color:var(--text-primary);line-height:1.6;min-height:100vh;
    background-color:var(--paper-light);
}
.topbar{position:sticky;top:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:12px 20px;background:linear-gradient(180deg,var(--paper-lightest),var(--paper-light));border-bottom:1px solid var(--border-mid);box-shadow:var(--shadow-sm)}
.topbar-left{display:flex;align-items:center;gap:10px}
.topbar-logo{font-size:1.5rem}
.topbar-title{font-family:var(--font-heading);font-size:1.25rem;font-weight:700;color:var(--accent);letter-spacing:.5px}
.topbar-sub{font-family:var(--font-ui);font-size:.75rem;color:var(--text-dim);padding-left:6px;border-left:1px solid var(--border-light)}
.topbar-right{display:flex;gap:8px}
.tb-btn{background:transparent;border:1px solid var(--border-light);border-radius:var(--r-md);width:36px;height:36px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;cursor:pointer;transition:all .2s var(--ease)}
.tb-btn:hover{background:var(--accent-light);border-color:var(--accent)}
.app-container{max-width:960px;margin:0 auto;padding:var(--sp-lg) var(--sp-md);min-height:calc(100vh - 60px)}
.page{animation:fadeIn .35s var(--ease)}.hidden{display:none!important}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.btn-paper{font-family:var(--font-ui);display:inline-flex;align-items:center;gap:6px;padding:8px 18px;border:1px solid var(--border-mid);border-radius:var(--r-md);background:linear-gradient(180deg,var(--paper-lightest),var(--paper-light));color:var(--text-primary);font-size:.875rem;font-weight:500;cursor:pointer;transition:all .2s var(--ease);box-shadow:var(--shadow-sm)}
.btn-paper:hover{border-color:var(--accent);box-shadow:var(--shadow-md);transform:translateY(-1px)}
.btn-paper:active{transform:translateY(0);box-shadow:var(--shadow-sm)}
.btn-paper.btn-accent{background:linear-gradient(135deg,var(--accent),var(--accent-hover));color:var(--text-on-accent);border-color:var(--accent)}
.btn-paper.btn-accent:hover{filter:brightness(1.1);box-shadow:0 4px 16px var(--accent-glow)}
.btn-paper.btn-danger{color:var(--danger);border-color:var(--danger)}
.btn-paper.btn-danger:hover{background:var(--danger);color:var(--text-on-accent)}
.btn-paper.btn-sm{padding:5px 12px;font-size:.8rem}
.btn-paper.btn-lg{padding:12px 28px;font-size:1rem}
.btn-link{background:none;border:none;color:var(--accent);font-family:var(--font-ui);font-size:.875rem;cursor:pointer;padding:4px 0;transition:color .2s}
.btn-link:hover{color:var(--accent-hover);text-decoration:underline}
.page-back{margin-bottom:var(--sp-md)}
select,input[type="text"],input[type="password"],input[type="number"]{font-family:var(--font-ui);padding:8px 12px;border:1px solid var(--border-mid);border-radius:var(--r-sm);background:var(--paper-lightest);color:var(--text-primary);font-size:.875rem;outline:none;transition:border-color .2s;width:100%}
select:focus,input:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-light)}
input[type="checkbox"]{accent-color:var(--accent);width:18px;height:18px;cursor:pointer}
label{font-family:var(--font-ui);font-size:.8rem;font-weight:600;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.5px}
::-webkit-scrollbar{width:6px}::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--paper-dark);border-radius:3px}
@media(max-width:640px){.app-container{padding:var(--sp-md) var(--sp-sm)}.topbar{padding:10px 12px}.topbar-sub{display:none}}
