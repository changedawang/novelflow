<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NovelFlow — AI 小说翻译书架</title>
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="css/components.css">
    <!-- 免费中文字体 -->
    <link href="https://cdn.jsdelivr.net/npm/lxgw-wenkai-screen-webfont@1.7.0/style.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;700&family=Noto+Sans+SC:wght@400;500;700&family=Ma+Shan+Zheng&family=ZCOOL+XiaoWei&family=ZCOOL+KuaiLe&family=ZCOOL+QingKe+HuangYou&family=Liu+Jian+Mao+Cao&family=Zhi+Mang+Xing&family=Long+Cang&display=swap" rel="stylesheet">
</head>
<body>
    <!-- ═══ 顶栏 ═══ -->
    <header class="topbar">
        <div class="topbar-left">
            <span class="topbar-logo">📖</span>
            <span class="topbar-title">NovelFlow</span>
            <span class="topbar-sub">AI翻译书架</span>
        </div>
        <div class="topbar-right">
            <button class="tb-btn" id="btn-settings" title="API设置">⚙️</button>
        </div>
    </header>

    <!-- ═══ 页面容器 ═══ -->
    <div class="app-container">

        <!-- ══ 页面1: 书架 ══ -->
        <section class="page page-shelf" id="page-shelf">
            <div class="shelf-header">
                <h2>📚 我的书架</h2>
                <div class="shelf-actions">
                    <button class="btn-paper" id="btn-new-book">+ 新建翻译</button>
                </div>
            </div>
            <div class="shelf-empty" id="shelf-empty">
                <div class="shelf-empty-icon">📖</div>
                <p>书架空空如也</p>
                <p class="sub">点击「新建翻译」开始你的第一本书</p>
            </div>
            <div class="shelf-grid" id="shelf-grid"></div>
        </section>

        <!-- ══ 页面2: 新建/上传 ══ -->
        <section class="page page-upload hidden" id="page-upload">
            <div class="page-back">
                <button class="btn-link" id="btn-back-shelf">← 返回书架</button>
            </div>
            <div class="upload-card">
                <div class="upload-area" id="upload-area">
                    <span class="upload-icon">📜</span>
<h3>导入原文</h3>
<p>支持 EPUB · TXT · HTML · Markdown · DOCX</p>
<button class="btn-paper btn-lg" id="btn-choose-file">选择文件</button>
<input type="file" id="file-input" accept=".txt,.epub,.html,.htm,.md,.markdown,.docx" hidden>
<div style="font-size:.7rem;color:var(--text-dim);margin-top:6px" id="upload-format-hint"></div>
                    <div class="upload-or">
                        <button class="btn-link" id="btn-demo">🎭 使用演示文本</button>
                    </div>
                </div>
            </div>
        </section>

        <!-- ══ 页面3: 预览 & 配置 ══ -->
        <section class="page page-config hidden" id="page-config">
            <div class="page-back">
                <button class="btn-link" id="btn-back-upload">← 返回</button>
            </div>
            <div class="config-card">
                <div class="config-header">
                    <h3>📄 <span id="cfg-filename">文件</span></h3>
                </div>
                <div class="config-stats">
                    <div class="cstat"><span class="cstat-val" id="cfg-chars">0</span><span class="cstat-lbl">字符</span></div>
                    <div class="cstat"><span class="cstat-val" id="cfg-sentences">0</span><span class="cstat-lbl">句子</span></div>
                    <div class="cstat"><span class="cstat-val" id="cfg-chapters">0</span><span class="cstat-lbl">章节</span></div>
                    <div class="cstat"><span class="cstat-val" id="cfg-tokens">0</span><span class="cstat-lbl">预估Tokens</span></div>
                </div>
                <div class="config-preview" id="cfg-preview"></div>
                <div class="config-form">
                    <div class="cfg-row">
                        <label>目标语言</label>
                        <select id="cfg-lang">
                            <option value="简体中文" selected>🇨🇳 简体中文</option>
                            <option value="繁體中文">🇭🇰 繁體中文</option>
                            <option value="English">🇺🇸 English</option>
                            <option value="日本語">🇯🇵 日本語</option>
                            <option value="한국어">🇰🇷 한국어</option>
                            <option value="Français">🇫🇷 Français</option>
                            <option value="Deutsch">🇩🇪 Deutsch</option>
                            <option value="Español">🇪🇸 Español</option>
                            <option value="Русский">🇷🇺 Русский</option>
                        </select>
                    </div>
                    <details class="cfg-advanced">
                        <summary>⚡ 高级选项</summary>
                        <div class="cfg-row"><label>上下文窗口</label><input type="number" id="cfg-window" value="8" min="2" max="20"><span class="cfg-hint">前N句上下文</span></div>
                        <div class="cfg-row"><label>自动术语</label><input type="checkbox" id="cfg-glossary" checked></div>
                        <div class="cfg-row"><label>分析文风</label><input type="checkbox" id="cfg-style" checked></div>
                    </details>
                </div>
                <div class="config-actions">
                    <button class="btn-paper btn-lg btn-accent" id="btn-start-translate">🚀 开始翻译</button>
                </div>
            </div>
        </section>

        <!-- ══ 页面4: 翻译工作台 ══ -->
        <section class="page page-work hidden" id="page-work">
            <div class="work-topbar">
                <button class="btn-link" id="btn-back-shelf2">← 书架</button>
                <button class="btn-link" id="btn-back-reader" style="margin-left:8px">📖 阅读</button>
                <span class="work-title" id="work-title">翻译中...</span>
                <div class="work-actions">
                    <button class="btn-paper btn-sm" id="btn-export">📥 导出</button>
                </div>
            </div>

            <!-- 暂停提示 -->
            <div class="pause-bar" id="pause-bar">
                <span>⚠️ 翻译已暂停</span>
                <button class="btn-paper btn-sm" id="btn-resume-bar">继续</button>
            </div>

            <!-- 状态 & 进度 -->
            <div class="work-status">
                <div class="ws-left">
                    <span class="ws-dot" id="ws-dot"></span>
                    <span class="ws-phase" id="ws-phase">准备中</span>
                    <span class="ws-detail" id="ws-detail"></span>
                </div>
                <div class="ws-right">
                    <span class="ws-tokens" id="ws-tokens">0 tokens</span>
                    <button class="btn-paper btn-sm" id="btn-pause">⏸ 暂停</button>
                    <button class="btn-paper btn-sm btn-danger" id="btn-cancel">✖ 取消</button>
                </div>
            </div>
            <div class="progress-wrap">
                <div class="progress-track"><div class="progress-bar" id="progress-bar"></div></div>
                <div class="progress-info"><span id="prog-label">0/0</span><span id="prog-pct">0%</span></div>
            </div>

            <!-- 完成横幅 -->
            <div class="done-banner hidden" id="done-banner">
                <h3>🎉 翻译完成！</h3>
                <p id="done-summary"></p>
                <div class="done-actions">
                    <button class="btn-paper btn-accent" id="btn-done-export">📥 导出</button>
                    <button class="btn-paper" id="btn-optimize">✨ 优化翻译</button>
                    <button class="btn-paper" id="btn-done-shelf">📚 回到书架</button>
                </div>
            </div>

            <!-- 优化翻译进度 -->
            <div class="optimize-bar hidden" id="optimize-bar">
                <div class="optimize-info">
                    <span class="optimize-phase" id="optimize-phase">正在优化翻译...</span>
                    <span class="optimize-detail" id="optimize-detail"></span>
                </div>
                <div class="optimize-progress">
                    <div class="progress-track"><div class="progress-bar" id="optimize-progress-bar"></div></div>
                    <span id="optimize-pct">0%</span>
                </div>
                <button class="btn-paper btn-sm btn-danger" id="btn-cancel-optimize">取消</button>
            </div>

            <!-- 标签页 -->
            <div class="work-tabs">
                <button class="wtab active" data-tab="translation">📝 对照</button>
                <button class="wtab" data-tab="reading">📖 阅读</button>
                <button class="wtab" data-tab="glossary">📚 术语 <span class="wtab-badge" id="gl-count">0</span></button>
                <button class="wtab" data-tab="style">🎨 文风</button>
                <button class="wtab" data-tab="summary">📋 摘要</button>
<button class="wtab" data-tab="logs">🔍 日志</button>
</div>

            <!-- Panel: 翻译对照 -->
            <div class="wpanel active" id="panel-translation">
                <div class="trans-view">
                    <div class="trans-col">
                        <div class="trans-col-head">原文 Source</div>
                        <div class="trans-col-body" id="src-list"></div>
                    </div>
                    <div class="trans-col">
                        <div class="trans-col-head">译文 Translation</div>
                        <div class="trans-col-body" id="tgt-list"></div>
                    </div>
                </div>
            </div>

            <!-- Panel: 边翻边读 -->
            <div class="wpanel" id="panel-reading">
                <div class="live-reader">
                    <div class="live-reader-toolbar">
                        <select id="live-chapter-select" class="live-chapter-sel"></select>
                        <div class="live-reader-modes">
                            <button class="live-mode-btn active" data-lmode="translated">译文</button>
                            <button class="live-mode-btn" data-lmode="bilingual">双语</button>
                            <button class="live-mode-btn" data-lmode="original">原文</button>
                        </div>
                        <div class="live-reader-progress">
                            <span id="live-progress-text">0%</span>
                            <button class="btn-paper btn-sm" id="btn-live-to-work">查看进度</button>
                        </div>
<div class="live-api-log" id="live-api-log" style="display:none;padding:8px 12px;background:var(--paper-dim);border-bottom:1px solid var(--border-light);font-size:0.75rem;color:var(--text-dim);max-height:80px;overflow-y:auto;">
<div id="live-api-status">等待API响应...</div>
</div>
<div class="live-reader-body" id="live-reader-body">
<div class="live-chapter-title" id="live-chapter-title"></div>
<div class="live-content" id="live-content"></div>
</div>
                    </div>
                    <div class="live-reader-nav">
                        <button class="btn-paper btn-sm" id="btn-live-prev">上一章</button>
                        <span id="live-ch-indicator">1/1</span>
                        <button class="btn-paper btn-sm" id="btn-live-next">下一章</button>
                    </div>
                </div>
            </div>

            <!-- Panel: 术语表 -->
            <div class="wpanel" id="panel-glossary">
                <div class="gl-toolbar">
                    <input type="text" id="gl-search" placeholder="🔍 搜索术语...">
                    <button class="btn-paper btn-sm" id="btn-add-term">+ 添加</button>
                    <button class="btn-paper btn-sm" id="btn-import-gl">📂 导入</button>
                </div>
                <table class="gl-table">
                    <thead><tr><th>原文</th><th>译文</th><th>类别</th><th>操作</th></tr></thead>
                    <tbody id="gl-body"></tbody>
                </table>
            </div>

            <!-- Panel: 文风 -->
            <div class="wpanel" id="panel-style">
                <div class="panel-content" id="style-content">
                    <div class="panel-empty">🎨 翻译开始后将自动分析文风...</div>
                </div>
            </div>

            <!-- Panel: 摘要 -->
            <div class="wpanel" id="panel-summary">
                <div class="panel-content" id="summary-content">
                    <div class="panel-empty">📋 翻译进行中将自动生成摘要...</div>
                </div>
            </div>
        </section>

        <!-- ══ 页面5: 沉浸式阅读器 ══ -->
        <section class="page page-reader hidden" id="page-reader" data-theme="light">
            <div class="rd-topbar" id="rd-topbar">
                <button class="rd-back" id="btn-reader-back">←</button>
                <span class="rd-title" id="reader-title">书名</span>
                <div class="rd-top-actions">
                    <span class="rd-progress-badge hidden" id="rd-progress-badge">0%</span>
                    <button class="rd-icon-btn" id="btn-reader-live" title="翻译实况">📊</button>
                    <button class="rd-icon-btn" id="btn-reader-export" title="导出">📥</button>
                </div>
            </div>
            <div class="rd-content" id="rd-content">
                <div class="rd-chapter-title" id="rd-chapter-title"></div>
                <div class="rd-body" id="reader-body"></div>
            </div>
            <div class="rd-progress-line"><div class="rd-progress-fill" id="rd-progress-fill"></div></div>
            <div class="rd-bottombar" id="rd-bottombar">
                <div class="rd-nav-row">
                    <button class="rd-nav-btn" id="btn-prev-ch">上一章</button>
                    <span class="rd-ch-ind" id="rd-ch-ind">1/1</span>
                    <button class="rd-nav-btn" id="btn-next-ch">下一章</button>
                </div>
                <div class="rd-toolbar">
<button class="rd-tool" id="btn-rd-toc"><span class="rd-tool-icon">☰</span><span>目录</span></button>
<button class="rd-tool" id="btn-rd-theme"><span class="rd-tool-icon">🌙</span><span id="rd-theme-label">夜间</span></button>
<button class="rd-tool" id="btn-rd-display"><span class="rd-tool-icon">Aa</span><span>显示</span></button>
<button class="rd-tool" id="btn-rd-optimize"><span class="rd-tool-icon">✨</span><span>优化</span></button>
<button class="rd-tool" id="btn-rd-settings2"><span class="rd-tool-icon">⚙️</span><span>设置</span></button>
</div>
            </div>
            <div class="rd-toc-overlay hidden" id="rd-toc-overlay">
                <div class="rd-toc-panel"><div class="rd-toc-head"><h3>📖 目录</h3><button class="rd-toc-close" id="btn-close-toc">✕</button></div><div class="rd-toc-list" id="rd-toc-list"></div></div>
            </div>
            <div class="rd-display-panel hidden" id="rd-display-panel">
                <div class="rd-dp-row rd-dp-row-fonts"><span class="rd-dp-label">字体</span><div class="rd-dp-btns rd-dp-fonts" id="rd-font-list">
                    <button class="rd-font-btn active" data-rfont="serif" style="font-family:'Noto Serif SC',serif">思源宋</button>
                    <button class="rd-font-btn" data-rfont="sans" style="font-family:'Noto Sans SC',sans-serif">思源黑</button>
                    <button class="rd-font-btn" data-rfont="wenkai" style="font-family:'LXGW WenKai Screen',cursive">霞鹜文楷</button>
                    <button class="rd-font-btn" data-rfont="xiaowei" style="font-family:'ZCOOL XiaoWei',serif">站酷小薇</button>
                    <button class="rd-font-btn" data-rfont="kuaile" style="font-family:'ZCOOL KuaiLe',cursive">站酷快乐</button>
                    <button class="rd-font-btn" data-rfont="qingke" style="font-family:'ZCOOL QingKe HuangYou',cursive">清刻黄油</button>
                    <button class="rd-font-btn" data-rfont="liujian" style="font-family:'Liu Jian Mao Cao',cursive">流江毛草</button>
                    <button class="rd-font-btn" data-rfont="zhimang" style="font-family:'Zhi Mang Xing',cursive">志莽行书</button>
                    <button class="rd-font-btn" data-rfont="mashanzheng" style="font-family:'Ma Shan Zheng',cursive">马善政楷</button>
                    <button class="rd-font-btn" data-rfont="longcang" style="font-family:'Long Cang',cursive">龙藏体</button>
                    <button class="rd-font-btn" data-rfont="system" style="font-family:system-ui,sans-serif">系统默认</button>
                </div></div>
                <div class="rd-dp-row"><span class="rd-dp-label">字号</span><div class="rd-dp-btns"><button class="rd-dp-btn" id="btn-font-down">A-</button><span class="rd-dp-val" id="rd-font-val">18</span><button class="rd-dp-btn" id="btn-font-up">A+</button></div></div>
                <div class="rd-dp-row"><span class="rd-dp-label">行距</span><div class="rd-dp-btns"><button class="rd-dp-btn" id="btn-lh-down">紧凑</button><span class="rd-dp-val" id="rd-lh-val">1.8</span><button class="rd-dp-btn" id="btn-lh-up">宽松</button></div></div>
                <div class="rd-dp-row"><span class="rd-dp-label">模式</span><div class="rd-dp-btns rd-dp-modes"><button class="rd-mode-btn active" data-rmode="translated">译文</button><button class="rd-mode-btn" data-rmode="bilingual">双语</button><button class="rd-mode-btn" data-rmode="original">原文</button></div></div>
                <div class="rd-dp-row"><span class="rd-dp-label">主题</span><div class="rd-dp-btns rd-dp-themes"><button class="rd-theme-dot active" data-rtheme="light" style="background:#f5f0e8"></button><button class="rd-theme-dot" data-rtheme="warm" style="background:#f5ecd7"></button><button class="rd-theme-dot" data-rtheme="green" style="background:#e0eed3"></button><button class="rd-theme-dot" data-rtheme="dark" style="background:#1a1a1a"></button><button class="rd-theme-dot" data-rtheme="black" style="background:#000"></button></div></div>
            </div>
        </section>
    </div>

    <!-- ═══ 弹窗: 设置 ═══ -->
    <div class="modal-bg hidden" id="modal-settings">
        <div class="modal-card">
            <div class="modal-head"><h3>⚙️ API 设置</h3><button class="modal-close" onclick="document.getElementById('modal-settings').classList.add('hidden')">✕</button></div>
            <div class="modal-body">
                <div class="fg"><label>API 提供商</label><select id="api-provider"><option value="deepseek">DeepSeek</option><option value="openai">OpenAI</option><option value="custom">自定义</option></select></div>
                <div class="fg">
                    <label>API Keys <span style="font-weight:400;text-transform:none;font-size:.72rem;color:var(--text-dim)">（多个密钥自动轮询，每行一个）</span></label>
                    <textarea id="api-keys" rows="3" placeholder="sk-key1&#10;sk-key2&#10;sk-key3" style="font-family:var(--font-mono);font-size:.8rem;padding:8px 12px;border:1px solid var(--border-mid);border-radius:var(--r-sm);background:var(--paper-lightest);color:var(--text-primary);width:100%;resize:vertical;outline:none"></textarea>
                    <div style="font-size:.7rem;color:var(--text-dim);margin-top:2px" id="key-count-hint">0 个密钥</div>
                </div>
                <div class="fg hidden" id="custom-url-group"><label>Base URL</label><input type="text" id="api-base-url" placeholder="https://..."></div>
                <div class="fg">
                    <label>模型</label>
                    <div style="display:flex;gap:6px;align-items:stretch">
                        <select id="api-model-select" style="flex:1;padding:8px 12px;border:1px solid var(--border-mid);border-radius:var(--r-sm);background:var(--paper-lightest);color:var(--text-primary);font-size:.85rem;display:none">
                        </select>
                        <input type="text" id="api-model" placeholder="deepseek-chat" style="flex:1">
                        <button type="button" id="btn-fetch-models" class="btn-paper btn-accent" style="white-space:nowrap;padding:6px 14px;font-size:.78rem;border-radius:var(--r-sm)">📡 获取模型</button>
                    </div>
                    <div id="model-fetch-hint" style="font-size:.7rem;color:var(--text-dim);margin-top:3px;display:none"></div>
                </div>
                <div class="fg">
                    <label>推理程度</label>
                    <select id="api-reasoning">
                        <option value="precise">🎯 精确 (Temp 0.1) — 术语一致性最高</option>
                        <option value="balanced" selected>⚖️ 均衡 (Temp 0.3) — 推荐</option>
                        <option value="creative">🎨 创意 (Temp 0.6) — 文风更自由</option>
                        <option value="wild">🔥 奔放 (Temp 0.9) — 大胆意译</option>
                        <option value="custom">⚙️ 自定义</option>
                    </select>
                </div>
                <div class="fg-row" id="custom-temp-group" style="display:none">
                    <div class="fg"><label>Temperature</label><input type="number" id="api-temp" value="0.3" step="0.1" min="0" max="2"></div>
                    <div class="fg"><label>Max Tokens</label><input type="number" id="api-max-tokens" value="1024" step="128" min="128"></div>
                </div>
                <hr><p class="modal-note">🔒 所有密钥仅保存在本地浏览器，不会上传。支持多密钥自动轮询，限流时自动切换。</p>
<div style="margin-top:var(--sp-md);padding:var(--sp-sm);background:var(--paper-light);border-radius:var(--r-md);border:1px solid var(--border-light)">
<div style="font-family:var(--font-ui);font-size:.8rem;font-weight:600;color:var(--text-secondary);margin-bottom:6px">📦 数据备份（跨浏览器迁移）</div>
<div style="display:flex;gap:8px;flex-wrap:wrap">
<button class="btn-paper btn-sm" id="btn-export-all">⬇️ 导出全部数据</button>
<button class="btn-paper btn-sm" id="btn-import-all">⬆️ 导入数据</button>
</div>
<p style="font-size:.7rem;color:var(--text-dim);margin-top:6px">导出后可在其他浏览器导入，实现数据迁移</p>
</div>
<div class="modal-actions"><button class="btn-paper" onclick="document.getElementById('modal-settings').classList.add('hidden')">取消</button><button class="btn-paper btn-accent" id="btn-save-settings">保存</button></div>
            </div>
        </div>
    </div>

    <!-- ═══ 弹窗: 添加术语 ═══ -->
    <div class="modal-bg hidden" id="modal-add-term">
        <div class="modal-card modal-sm">
            <div class="modal-head"><h3>📝 添加术语</h3><button class="modal-close" onclick="document.getElementById('modal-add-term').classList.add('hidden')">✕</button></div>
            <div class="modal-body">
                <div class="fg"><label>原文</label><input type="text" id="term-src" placeholder="Frodo"></div>
                <div class="fg"><label>译文</label><input type="text" id="term-tgt" placeholder="弗罗多"></div>
                <div class="fg"><label>类别</label><select id="term-cat"><option value="character">👤 角色</option><option value="location">📍 地点</option><option value="item">🗡️ 物品</option><option value="organization">🏛️ 组织</option><option value="concept">💡 概念</option><option value="other">📌 其他</option></select></div>
                <div class="modal-actions"><button class="btn-paper" onclick="document.getElementById('modal-add-term').classList.add('hidden')">取消</button><button class="btn-paper btn-accent" id="btn-confirm-term">添加</button></div>
            </div>
        </div>
    </div>

    <!-- ═══ 弹窗: 导出 ═══ -->
    <div class="modal-bg hidden" id="modal-export">
        <div class="modal-card">
            <div class="modal-head"><h3>📥 导出</h3><button class="modal-close" onclick="document.getElementById('modal-export').classList.add('hidden')">✕</button></div>
            <div class="modal-body">
                <div class="export-list">
                    <div class="export-item" data-fmt="txt"><span>📄</span><div><strong>纯译文 TXT</strong><p>仅翻译结果</p></div></div>
                    <div class="export-item" data-fmt="bilingual"><span>📑</span><div><strong>双语对照 TXT</strong><p>原文+译文逐句</p></div></div>
                    <div class="export-item" data-fmt="json"><span>📦</span><div><strong>完整数据 JSON</strong><p>含术语/文风/摘要</p></div></div>
                    <div class="export-item" data-fmt="glossary"><span>📚</span><div><strong>术语表 JSON</strong><p>可导入复用</p></div></div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js"></script>
<script src="js/utils.js"></script>
    <script src="js/llm-adapter.js"></script>
    <script src="js/text-splitter.js"></script>
    <script src="js/glossary-manager.js"></script>
    <script src="js/translation-engine.js"></script>
    <script src="js/ui-controller.js"></script>
    <script src="js/app.js"></script>
</body>
</html>
