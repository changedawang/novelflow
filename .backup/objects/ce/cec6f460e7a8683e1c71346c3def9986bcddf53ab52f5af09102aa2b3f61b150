/* NovelFlow — 组件样式 */

/* ═══ 1. 书架页 ═══ */
.shelf-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--sp-lg)}
.shelf-header h2{font-family:var(--font-heading);font-size:1.4rem;color:var(--text-primary)}
.shelf-empty{text-align:center;padding:var(--sp-xl) var(--sp-md);color:var(--text-dim)}
.shelf-empty-icon{font-size:3rem;margin-bottom:var(--sp-sm);opacity:.5}
.shelf-empty p{margin:4px 0}.shelf-empty .sub{font-size:.85rem}
.shelf-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:var(--sp-md)}

.book-card{position:relative;border-radius:var(--r-md);overflow:hidden;cursor:pointer;transition:all .3s var(--ease);box-shadow:var(--shadow-book);background:linear-gradient(135deg,var(--paper-lightest) 0%,var(--paper-light) 40%,var(--paper-base) 100%);border:1px solid var(--border-mid)}
.book-card:hover{transform:translateY(-4px) scale(1.02);box-shadow:0 12px 40px rgba(58,46,31,.22)}
.book-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:6px;background:linear-gradient(180deg,var(--accent),var(--accent-hover));border-radius:var(--r-md) 0 0 var(--r-md)}
.book-card-inner{padding:20px 16px 16px 20px;display:flex;flex-direction:column;min-height:200px}
.book-emoji{font-size:2.2rem;margin-bottom:10px}
.book-title{font-family:var(--font-heading);font-size:.95rem;font-weight:700;color:var(--text-primary);line-height:1.4;margin-bottom:6px;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
.book-lang{font-family:var(--font-ui);font-size:.7rem;color:var(--text-dim);margin-bottom:auto;padding-bottom:12px}
.book-progress{margin-top:auto}
.book-progress-bar{height:4px;background:var(--paper-mid);border-radius:2px;overflow:hidden;margin-bottom:6px}
.book-progress-fill{height:100%;border-radius:2px;transition:width .5s var(--ease);background:linear-gradient(90deg,var(--accent),var(--accent-hover))}
.book-progress-fill.complete{background:linear-gradient(90deg,var(--success),#6a8a57)}
.book-meta{display:flex;justify-content:space-between;align-items:center}
.book-status{font-family:var(--font-ui);font-size:.7rem;font-weight:600;padding:2px 8px;border-radius:10px;letter-spacing:.3px}
.book-status.s-translating{background:var(--accent-light);color:var(--accent)}
.book-status.s-paused{background:rgba(184,134,11,.15);color:var(--warning)}
.book-status.s-completed{background:rgba(90,114,71,.15);color:var(--success)}
.book-status.s-cancelled{background:rgba(160,65,58,.1);color:var(--danger)}
.book-date{font-family:var(--font-ui);font-size:.65rem;color:var(--text-dim)}
.book-delete{position:absolute;top:8px;right:8px;width:24px;height:24px;border-radius:50%;background:rgba(160,65,58,.8);color:#fff;border:none;font-size:.7rem;cursor:pointer;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .2s}
.book-card:hover .book-delete{opacity:1}

/* ═══ 2. 上传页 ═══ */
.upload-card{max-width:520px;margin:var(--sp-xl) auto}
.upload-area{text-align:center;padding:var(--sp-xl) var(--sp-lg);border:2px dashed var(--border-mid);border-radius:var(--r-lg);background:var(--paper-lightest);transition:all .3s var(--ease);cursor:pointer}
.upload-area.dragover{border-color:var(--accent);background:var(--accent-light);box-shadow:0 0 0 4px var(--accent-light)}
.upload-icon{font-size:3rem;display:block;margin-bottom:var(--sp-md)}
.upload-area h3{font-family:var(--font-heading);margin-bottom:8px;color:var(--text-primary)}
.upload-area p{font-family:var(--font-ui);color:var(--text-dim);font-size:.85rem;margin-bottom:var(--sp-md)}
.upload-or{margin-top:var(--sp-md);padding-top:var(--sp-md);border-top:1px solid var(--border-light)}

/* ═══ 3. 配置页 ═══ */
.config-card{max-width:600px;margin:0 auto;background:var(--paper-lightest);border:1px solid var(--border-mid);border-radius:var(--r-lg);padding:var(--sp-lg);box-shadow:var(--shadow-md)}
.config-header h3{font-family:var(--font-heading);font-size:1.15rem;margin-bottom:var(--sp-md)}
.config-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--sp-sm);margin-bottom:var(--sp-md)}
.cstat{text-align:center;padding:12px 8px;background:var(--paper-light);border-radius:var(--r-md);border:1px solid var(--border-light)}
.cstat-val{display:block;font-family:var(--font-mono);font-size:1.3rem;font-weight:700;color:var(--accent)}
.cstat-lbl{display:block;font-family:var(--font-ui);font-size:.7rem;color:var(--text-dim);margin-top:2px;text-transform:uppercase}
.config-preview{max-height:120px;overflow-y:auto;padding:var(--sp-sm);background:var(--paper-light);border-radius:var(--r-sm);border:1px solid var(--border-light);font-size:.8rem;color:var(--text-secondary);line-height:1.6;margin-bottom:var(--sp-md);font-family:var(--font-mono)}
.config-form{margin-bottom:var(--sp-lg)}
.cfg-row{display:flex;align-items:center;gap:var(--sp-sm);margin-bottom:var(--sp-sm)}
.cfg-row label{min-width:90px;flex-shrink:0}
.cfg-row select,.cfg-row input{flex:1}
.cfg-hint{font-family:var(--font-ui);font-size:.72rem;color:var(--text-dim);white-space:nowrap}
.cfg-advanced{margin-top:var(--sp-sm);border:1px solid var(--border-light);border-radius:var(--r-md);padding:var(--sp-sm) var(--sp-md)}
.cfg-advanced summary{font-family:var(--font-ui);font-size:.85rem;font-weight:600;cursor:pointer;color:var(--text-secondary);padding:4px 0}
.cfg-advanced[open]{padding-bottom:var(--sp-md)}
.config-actions{text-align:center}
