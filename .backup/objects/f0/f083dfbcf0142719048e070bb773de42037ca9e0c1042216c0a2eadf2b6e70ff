/* ============================================
   NovelFlow — 组件样式
   ============================================ */

/* ── 上传区域 ── */
.phase-upload {
    display: flex; align-items: center; justify-content: center;
    min-height: calc(100vh - 92px);
}
.upload-area {
    text-align: center;
    padding: 60px 40px;
    border: 2px dashed var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    max-width: 520px;
    width: 100%;
    transition: border-color 0.3s, background 0.3s;
}
.upload-area.drag-over {
    border-color: var(--primary);
    background: var(--primary-bg);
}
.upload-icon { font-size: 48px; margin-bottom: 16px; }
.upload-area h2 { font-size: 20px; margin-bottom: 8px; }
.upload-area p { color: var(--text-dim); margin-bottom: 20px; }
.upload-btn { margin-bottom: 16px; }
.upload-demo { margin-top: 8px; }

/* ── 预览卡片 ── */
.phase-preview {
    display: flex; justify-content: center;
    padding-top: 20px;
}
.preview-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    max-width: 680px;
    width: 100%;
    overflow: hidden;
}
.preview-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
}
.preview-header h3 { font-size: 15px; }
.preview-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
}
.stat {
    display: flex; flex-direction: column; align-items: center;
    padding: 14px 8px;
    background: var(--bg-card);
}
.stat-value { font-size: 20px; font-weight: 700; color: var(--primary); }
.stat-label { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
.preview-text {
    padding: 16px 20px;
    max-height: 120px;
    overflow-y: auto;
    font-size: 12px;
    color: var(--text-dim);
    border-bottom: 1px solid var(--border);
    font-family: var(--mono);
    line-height: 1.8;
    white-space: pre-wrap;
}
.preview-config { padding: 16px 20px; }
.config-row {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 10px;
}
.config-row label {
    min-width: 100px;
    font-size: 13px;
    color: var(--text-dim);
    flex-shrink: 0;
}
.config-row input, .config-row select { flex: 1; }
.config-row input[type="number"] { max-width: 80px; }
.config-hint { font-size: 12px; color: var(--text-muted); }
.advanced-config {
    margin-top: 8px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0;
}
.advanced-config summary {
    padding: 10px 16px;
    cursor: pointer;
    color: var(--text-dim);
    font-size: 13px;
}
.advanced-config[open] summary { border-bottom: 1px solid var(--border); }
.advanced-config .config-row { padding: 0 16px; }
.advanced-config .config-row:first-of-type { margin-top: 10px; }
.preview-actions {
    padding: 16px 20px;
    text-align: center;
    border-top: 1px solid var(--border);
}

/* ── 状态栏 ── */
.status-bar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 16px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-bottom: 12px;
    flex-wrap: wrap;
    gap: 8px;
}
.status-left, .status-right { display: flex; align-items: center; gap: 12px; }
.status-phase { font-weight: 600; font-size: 13px; }
.status-detail { font-size: 12px; color: var(--text-dim); }
.status-tokens { font-size: 12px; color: var(--text-muted); font-family: var(--mono); }

/* ── 进度条 ── */
.progress-container { margin-bottom: 12px; }
.progress-bar {
    height: 6px;
    background: var(--bg-hover);
    border-radius: 3px;
    overflow: hidden;
}
.progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--primary), #a78bfa);
    border-radius: 3px;
    transition: width 0.3s ease;
}
.progress-text {
    display: flex; justify-content: space-between;
    padding: 4px 0;
    font-size: 12px;
    color: var(--text-muted);
}

/* ── 标签页 ── */
.tabs {
    display: flex;
    gap: 2px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius) var(--radius) 0 0;
    padding: 4px 4px 0;
    overflow-x: auto;
}
.tab {
    padding: 10px 16px;
    background: transparent;
    border: none;
    border-radius: var(--radius) var(--radius) 0 0;
    color: var(--text-dim);
    font-size: 13px;
    cursor: pointer;
    font-family: var(--font);
    transition: all 0.2s;
    white-space: nowrap;
}
.tab:hover { color: var(--text); background: var(--bg-hover); }
.tab.active {
    color: var(--primary);
    background: var(--bg);
    border-bottom: 2px solid var(--primary);
}

.tab-panel {
    display: none;
    background: var(--bg);
    border: 1px solid var(--border);
    border-top: none;
    border-radius: 0 0 var(--radius) var(--radius);
    min-height: 400px;
}
.tab-panel.active { display: block; }

/* ── 翻译对照视图 ── */
.translation-view {
    display: flex;
    height: calc(100vh - 320px);
    min-height: 400px;
}
.translation-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}
.translation-col + .translation-col { border-left: 1px solid var(--border); }
.col-header {
    padding: 10px 16px;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    border-bottom: 1px solid var(--border);
    background: var(--bg-card);
}
.col-content {
    flex: 1;
    overflow-y: auto;
    padding: 8px 0;
}

/* 句子行 */
.sentence-row {
    display: flex;
    align-items: flex-start;
    padding: 6px 16px;
    gap: 8px;
    transition: background 0.15s;
    cursor: default;
}
.sentence-row:hover { background: var(--bg-hover); }
.sentence-row.current { background: var(--primary-bg); }
.sentence-row.translating { background: var(--warning-bg); }
.sentence-idx {
    min-width: 32px;
    font-size: 11px;
    color: var(--text-muted);
    font-family: var(--mono);
    text-align: right;
    padding-top: 2px;
    flex-shrink: 0;
}
.sentence-text {
    flex: 1;
    font-size: 14px;
    line-height: 1.7;
    word-break: break-word;
}
.sentence-text.pending { color: var(--text-muted); font-style: italic; }
.sentence-text.streaming { color: var(--warning); }
.sentence-actions {
    flex-shrink: 0;
    opacity: 0;
    transition: opacity 0.15s;
}
.sentence-row:hover .sentence-actions { opacity: 1; }
.btn-retranslate {
    background: none; border: none;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 14px;
    padding: 2px 4px;
}
.btn-retranslate:hover { color: var(--primary); }

/* ── 术语表 ── */
.glossary-toolbar {
    display: flex; gap: 8px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
}
.glossary-search { flex: 1; }
.glossary-table-wrap {
    overflow-y: auto;
    max-height: calc(100vh - 400px);
}
.glossary-table {
    width: 100%;
    border-collapse: collapse;
}
.glossary-table th {
    padding: 10px 16px;
    text-align: left;
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0;
    background: var(--bg-card);
}
.glossary-table td {
    padding: 8px 16px;
    font-size: 13px;
    border-bottom: 1px solid var(--border);
}
.glossary-table tr:hover { background: var(--bg-hover); }
.term-category {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 10px;
    font-size: 11px;
    font-weight: 500;
}
.cat-character { background: rgba(255,107,107,0.15); color: var(--accent-char); }
.cat-location { background: rgba(78,205,196,0.15); color: var(--accent-loc); }
.cat-item { background: rgba(69,183,209,0.15); color: var(--accent-item); }
.cat-organization { background: rgba(150,206,180,0.15); color: var(--accent-org); }
.cat-concept { background: rgba(255,234,167,0.15); color: var(--accent-concept); }
.cat-other { background: var(--bg-hover); color: var(--text-dim); }

.term-actions { display: flex; gap: 4px; }
.term-actions button {
    background: none; border: none;
    color: var(--text-muted);
    cursor: pointer; font-size: 14px;
    padding: 2px 4px;
    border-radius: 4px;
}
.term-actions button:hover { background: var(--bg-hover); color: var(--text); }
.term-locked { color: var(--warning) !important; }

/* ── 文风面板 ── */
.style-card {
    padding: 20px;
}
.style-placeholder { color: var(--text-muted); text-align: center; padding: 40px; }
.style-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
    margin-bottom: 16px;
}
.style-item {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 12px;
}
.style-item-label { font-size: 11px; color: var(--text-muted); margin-bottom: 4px; }
.style-item-value { font-size: 14px; font-weight: 500; }
.style-summary {
    background: var(--primary-bg);
    border: 1px solid rgba(91,141,239,0.2);
    border-radius: var(--radius);
    padding: 16px;
    margin-top: 12px;
    font-size: 14px;
    line-height: 1.8;
}
.style-guidelines {
    margin-top: 12px;
}
.style-guidelines h4 { font-size: 13px; color: var(--text-dim); margin-bottom: 8px; }
.style-guideline-item {
    padding: 6px 12px;
    background: var(--bg-card);
    border-left: 3px solid var(--primary);
    margin-bottom: 6px;
    border-radius: 0 var(--radius) var(--radius) 0;
    font-size: 13px;
}

/* ── 摘要面板 ── */
.summary-section { padding: 16px 20px; }
.summary-section + .summary-section { border-top: 1px solid var(--border); }
.summary-section h4 { font-size: 14px; margin-bottom: 8px; }
.summary-content {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 12px 16px;
    font-size: 13px;
    line-height: 1.8;
    color: var(--text-dim);
}
.chapter-summary-item {
    margin-bottom: 8px;
}
.chapter-summary-title {
    font-size: 12px;
    font-weight: 600;
    color: var(--primary);
    margin-bottom: 4px;
}

/* ── 导出按钮 ── */
.export-option {
    width: 100%;
    margin-bottom: 8px;
    justify-content: center;
}
