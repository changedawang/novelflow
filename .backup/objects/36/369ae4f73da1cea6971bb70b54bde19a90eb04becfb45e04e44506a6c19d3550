<!DOCTYPE html>
<html>
<head><meta charset="utf-8"><title>CORS Test</title></head>
<body>
<h2>CORS Test</h2>
<pre id="log" style="white-space:pre-wrap;font-size:13px;background:#eee;padding:12px;max-height:80vh;overflow:auto;"></pre>
<script>
var log = document.getElementById('log');
function L(msg){ log.textContent += msg + '\n'; }

L('Script started at ' + new Date().toLocaleTimeString());
L('UserAgent: ' + navigator.userAgent.slice(0,120));
L('');

(async function(){
    var url = 'https://api.ccroute.net/v1/models';
    var key = 'ccp_e89cd0260f3c49971e09124b920f98af';

    L('--- Test 1: fetch GET with Auth header ---');
    try {
        var r = await fetch(url, {
            method: 'GET',
            headers: { 'Authorization': 'Bearer ' + key }
        });
        L('HTTP ' + r.status + ' ' + r.statusText);
        var t = await r.text();
        L('Body: ' + t.slice(0, 400));
    } catch(e) {
        L('CATCH: ' + e.name + ': ' + e.message);
        L('Stack: ' + (e.stack || 'N/A').slice(0,200));
    }

    L('');
    L('--- Test 2: fetch GET no Auth (simple) ---');
    try {
        var r2 = await fetch(url);
        L('HTTP ' + r2.status + ' ' + r2.statusText);
        var t2 = await r2.text();
        L('Body: ' + t2.slice(0, 300));
    } catch(e) {
        L('CATCH: ' + e.name + ': ' + e.message);
    }

    L('');
    L('--- Test 3: fetch POST /chat/completions with Auth ---');
    try {
        var r3 = await fetch('https://api.ccroute.net/v1/chat/completions', {
            method: 'POST',
            headers: {
                'Authorization': 'Bearer ' + key,
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({model:'claude-sonnet-4.6',messages:[{role:'user',content:'hi'}],max_tokens:5})
        });
        L('HTTP ' + r3.status + ' ' + r3.statusText);
        var t3 = await r3.text();
        L('Body: ' + t3.slice(0, 400));
    } catch(e) {
        L('CATCH: ' + e.name + ': ' + e.message);
    }

    L('');
    L('--- Done ---');
})();
</script>
</body>
</html>