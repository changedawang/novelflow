/**
 * NovelFlow — UI Controller v3
 * localStorage进度持久化 + 实时翻译跟踪
 */
class UIController {
    constructor() {
        this.engine = null;
        this.splitter = new TextSplitter();
        this.chapters = [];
        this.fileName = '';
        this.rawText = '';
        this._isPaused = false;
        this._translationResults = [];
        this._autoScrollEnabled = true;
        this._cacheDOM();
        this._bindEvents();
        this._loadSettings();
        this._checkResumableSession();
    }

    _cacheDOM() {
        const $ = id => document.getElementById(id);
        this.$upload=$('phase-upload'); this.$preview=$('phase-preview'); this.$translate=$('phase-translate');
        this.$uploadArea=$('upload-area'); this.$fileInput=$('file-input'); this.$btnChoose=$('btn-choose-file');
        this.$btnDemo=$('btn-demo'); this.$fileName=$('file-name'); this.$previewText=$('preview-text');
        this.$statChars=$('stat-chars'); this.$statSentences=$('stat-sentences');
        this.$statChapters=$('stat-chapters'); this.$statTokens=$('stat-tokens');
        this.$btnReUpload=$('btn-re-upload'); this.$btnStart=$('btn-start');
        this.$targetLang=$('target-lang'); this.$contextWindow=$('context-window');
        this.$autoGlossary=$('auto-glossary'); this.$autoStyle=$('auto-style');
        this.$statusBar=$('status-bar'); this.$statusPhase=$('status-phase');
        this.$statusDetail=$('status-detail'); this.$statusTokens=$('status-tokens');
        this.$progressFill=$('progress-fill'); this.$progressLabel=$('progress-label');
        this.$progressPercent=$('progress-percent');
        this.$btnPause=$('btn-pause'); this.$btnCancel=$('btn-cancel');
        this.$sourceList=$('source-list'); this.$targetList=$('target-list');
        this.$pauseAlert=$('pause-alert'); this.$btnResumeAlert=$('btn-resume-alert');
        this.$completeBanner=$('complete-banner'); this.$completeSummary=$('complete-summary');
        this.$btnExportComplete=$('btn-export-complete'); this.$btnNewTask=$('btn-new-task');
        this.$glossaryCount=$('glossary-count'); this.$glossaryBody=$('glossary-body');
        this.$glossarySearch=$('glossary-search');
        this.$styleContent=$('style-content'); this.$summaryContent=$('summary-content');
        this.$btnSettings=$('btn-settings'); this.$btnExport=$('btn-export');
        this.$modalSettings=$('modal-settings'); this.$modalAddTerm=$('modal-add-term');
        this.$modalExport=$('modal-export');
        this.$apiProvider=$('api-provider'); this.$apiKey=$('api-key');
        this.$apiBaseUrl=$('api-base-url'); this.$customUrlGroup=$('custom-url-group');
        this.$apiModel=$('api-model'); this.$apiTemp=$('api-temperature');
        this.$apiMaxTokens=$('api-max-tokens');
    }

    _bindEvents() {
        this.$btnChoose.onclick = () => this.$fileInput.click();
        this.$fileInput.onchange = e => this._handleFile(e.target.files[0]);
        this.$btnDemo.onclick = () => this._loadDemo();
        this.$uploadArea.ondragover = e => { e.preventDefault(); this.$uploadArea.classList.add('drag-over'); };
        this.$uploadArea.ondragleave = () => this.$uploadArea.classList.remove('drag-over');
        this.$uploadArea.ondrop = e => { e.preventDefault(); this.$uploadArea.classList.remove('drag-over'); if(e.dataTransfer.files[0]) this._handleFile(e.dataTransfer.files[0]); };
        this.$btnReUpload.onclick = () => this._showPhase('upload');
        this.$btnStart.onclick = () => this._startTranslation();
        this.$btnPause.onclick = () => this._togglePause();
        this.$btnCancel.onclick = () => this._cancelTranslation();
        this.$btnResumeAlert.onclick = () => this._togglePause();
        this.$btnExportComplete.onclick = () => this._showModal('export');
        this.$btnNewTask.onclick = () => { if(confirm('开始新任务？当前进度已保存。')){ this._clearSession(); location.reload(); } };
        this.$btnSettings.onclick = () => this._showModal('settings');
        this.$btnExport.onclick = () => this._showModal('export');
        document.querySelectorAll('.tab').forEach(t => { t.onclick = () => this._switchTab(t.dataset.tab); });
        this.$apiProvider.onchange = () => { this.$customUrlGroup.classList.toggle('hidden', this.$apiProvider.value !== 'custom'); };
        document.getElementById('btn-save-settings').onclick = () => this._saveSettings();
        document.getElementById('btn-add-term').onclick = () => this._showModal('addTerm');
        document.getElementById('btn-confirm-add-term').onclick = () => this._addTerm();
        this.$glossarySearch.oninput = () => this._renderGlossary();
        document.getElementById('btn-import-glossary').onclick = () => this._importGlossary();
        document.querySelectorAll('.export-option').forEach(o => { o.onclick = () => this._doExport(o.dataset.format); });
        document.querySelectorAll('.modal-overlay').forEach(o => { o.addEventListener('click', e => { if(e.target===o) o.classList.add('hidden'); }); });
        [this.$sourceList, this.$targetList].forEach(el => {
            if(!el) return; let t;
            el.addEventListener('scroll', () => { this._autoScrollEnabled=false; clearTimeout(t); t=setTimeout(()=>{ if(el.scrollHeight-el.scrollTop-el.clientHeight<80) this._autoScrollEnabled=true; },1000); }, {passive:true});
        });
    }

    _showPhase(p) {
        this.$upload.classList.toggle('hidden', p!=='upload');
        this.$preview.classList.toggle('hidden', p!=='preview');
        this.$translate.classList.toggle('hidden', p!=='translate');
        this.$btnExport.style.display = p==='translate' ? '' : 'none';
    }

    _handleFile(file) {
        if(!file) return;
        this.fileName = file.name;
        const r = new FileReader();
        r.onload = e => { this.rawText=e.target.result; this._analyzeText(); this._showPhase('preview'); };
        r.readAsText(file, 'utf-8');
    }

    _loadDemo() {
        if(typeof DEMO_TEXT==='undefined'){alert('演示文本未加载');return;}
        this.fileName='demo_novel.txt'; this.rawText=DEMO_TEXT;
        this._analyzeText(); this._showPhase('preview');
    }

    _analyzeText() {
        this.chapters = this.splitter.parse(this.rawText);
        const total = this.chapters.reduce((s,ch)=>s+ch.sentences.length, 0);
        this.$fileName.textContent = this.fileName;
        this.$statChars.textContent = Utils.formatNumber(this.rawText.length);
        this.$statSentences.textContent = Utils.formatNumber(total);
        this.$statChapters.textContent = this.chapters.length;
        this.$statTokens.textContent = Utils.formatNumber(total * 1676);
        this.$previewText.textContent = this.rawText.slice(0,500) + (this.rawText.length>500?'...':'');
    }

    async _startTranslation() {
        const apiKey = this.$apiKey.value.trim() || Utils.loadLocal('apiKey','');
        if(!apiKey){ this._showModal('settings'); alert('请先设置 API Key'); return; }
        this._saveSettings(); this._showPhase('translate');
        this._isPaused=false; this._autoScrollEnabled=true;
        this.$completeBanner.classList.add('hidden');
        this.engine = new TranslationEngine({
            api:{ provider:this.$apiProvider.value, apiKey, model:this.$apiModel.value||undefined, baseUrl:this.$apiBaseUrl.value||undefined },
            targetLang:this.$targetLang.value, windowSize:parseInt(this.$contextWindow.value)||8,
            summaryInterval:20, temperature:parseFloat(this.$apiTemp.value)||0.3,
            autoGlossary:this.$autoGlossary.checked, autoStyle:this.$autoStyle.checked,
        });
        this._initTranslationView();
        this._saveSessionMeta();
        try {
            this._translationResults = await this.engine.translateBook(this.chapters, (ev,d)=>this._handleProgress(ev,d));
            this._onComplete();
        } catch(e) {
            if(e.message==='CANCELLED'){ this.$statusPhase.textContent='⏹ 已取消'; this._setStatusBarState('warning'); }
            else { this.$statusPhase.textContent='❌ 翻译出错'; this.$statusDetail.textContent=e.message; this._setStatusBarState('error'); }
            this._saveProgress();
        }
    }

    _initTranslationView() {
        this.$sourceList.innerHTML=''; this.$targetList.innerHTML='';
        let gi=0;
        for(let ci=0;ci<this.chapters.length;ci++){
            const ch=this.chapters[ci];
            const mk=t=>{ const r=document.createElement('div'); r.className='sentence-row chapter-title-row'; r.innerHTML=`<span class="sentence-idx"></span><span class="sentence-text" style="font-weight:700;color:var(--primary)">${Utils.escapeHtml(t)}</span>`; return r; };
            this.$sourceList.appendChild(mk(ch.title));
            const tt=mk('—'); tt.id='trans-title-'+ci; this.$targetList.appendChild(tt);
            for(let i=0;i<ch.sentences.length;i++){
                gi++;
                const or=document.createElement('div'); or.className='sentence-row'; or.id='orig-'+gi;
                or.innerHTML=`<span class="sentence-idx">${gi}</span><span class="sentence-text">${Utils.escapeHtml(ch.sentences[i])}</span>`;
                this.$sourceList.appendChild(or);
                const tr=document.createElement('div'); tr.className='sentence-row'; tr.id='trans-'+gi;
                tr.innerHTML=`<span class="sentence-idx">${gi}</span><span class="sentence-text pending">⏳ 等待翻译...</span>`;
                this.$targetList.appendChild(tr);
            }
        }
    }
