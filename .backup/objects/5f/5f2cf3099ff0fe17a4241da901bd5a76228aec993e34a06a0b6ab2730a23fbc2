/* ============================================
   NovelFlow — 核心翻译引擎
   三层记忆系统 + 术语表 + 文风锚定
   ============================================ */

class TranslationEngine {
    constructor(config) {
        this.llm = new LLMAdapter({
            ...config.api,
            onKeySwitch: (info) => this._emit('keySwitch', info),
        });
        this.config = {
            targetLang: config.targetLang || '简体中文',
            novelType: config.novelType || '通用',
            windowSize: config.windowSize || 5,        // 降低默认窗口
            windowSizeShort: config.windowSizeShort || 3, // 短句用更小窗口
            summaryInterval: config.summaryInterval || 30, // 增大间隔省token
            temperature: config.temperature || 0.3,
            autoGlossary: config.autoGlossary !== false,
            autoStyle: config.autoStyle !== false,
            maxGlossaryPerSentence: config.maxGlossaryPerSentence || 8, // 每句最多术语
            translationBatchSize: Math.max(1, parseInt(config.translationBatchSize, 10) || 30),
            chapterSummaryLen: config.chapterSummaryLen || 60,  // 章节摘要长度
            globalSummaryLen: config.globalSummaryLen || 120,   // 全局摘要长度
            enableReasoningTrace: config.enableReasoningTrace !== false,
            streamReasoningTrace: config.streamReasoningTrace !== false,
            translationReasoningEffort: config.translationReasoningEffort || 'medium',
            optimizeReasoningEffort: config.optimizeReasoningEffort || 'high',
        };

        // 核心状态
        this.glossary = new GlossaryManager();
        this.styleProfile = null;
        this.globalSummary = '';
        this.chapterSummaries = {};
        this.slidingWindow = []; // [{original, translation}]

        // 统计
        this.tokensInput = 0;
        this.tokensOutput = 0;
        this.completedSentences = 0;
        this.totalSentences = 0;

        // 控制
        this._paused = false;
        this._pausedAt = null;
        this._cancelled = false;
        this._onProgress = null; // callback(event, data)
        this._listeners = Object.create(null);
        this._apiTraceSeq = 0;

    }

    /**
     * 翻译全书 — 主入口
     */
    async translateBook(chapters, onProgress) {
        this._onProgress = onProgress;
        this._cancelled = false;
        this._paused = false;
        this.totalSentences = chapters.reduce((sum, ch) => sum + ch.sentences.length, 0);
        this.completedSentences = 0;

        // === Phase 0: 预处理 ===
        this._emit('phase', { phase: 'preprocessing', message: '预处理中...' });

        // 收集全文前部分用于分析
        const allText = chapters.map(ch => ch.sentences.join(' ')).join('\n\n');
        const sampleText = allText.slice(0, 2500);

        // 文风分析
        if (this.config.autoStyle) {
            this._emit('phase', { phase: 'style', message: '分析文风...' });
            await this._analyzeStyle(sampleText);
        }

        // 术语提取
        if (this.config.autoGlossary) {
            this._emit('phase', { phase: 'glossary', message: '提取术语...' });
            await this._extractGlossary(allText);
        }

        // === Phase 1: 逐章翻译 ===
        this._emit('phase', { phase: 'translating', message: '开始翻译...' });

        const results = [];

        for (let chIdx = 0; chIdx < chapters.length; chIdx++) {
            await this._checkPauseCancel();
            const chapter = chapters[chIdx];

            this._emit('chapterStart', {
                chapterIndex: chIdx,
                title: chapter.title,
                sentenceCount: chapter.sentences.length,
            });

            // 保留跨章上下文（最后3句）
            if (this.slidingWindow.length > 3) {
                this.slidingWindow = this.slidingWindow.slice(-3);
            }

            const translatedSentences = [];
            const summaryBatchSize = this.config.summaryInterval;
            const translationBatchSize = this.config.translationBatchSize;

            for (let i = 0; i < chapter.sentences.length; i += translationBatchSize) {
                await this._checkPauseCancel();

                const sourceBatch = chapter.sentences.slice(i, i + translationBatchSize);

                // 构建上下文（优化：只用当前批次+最近2句做术语匹配，省CPU和内存）
                const recentCtx = this.slidingWindow.slice(-2).map(w => w.original).join(' ');
                const relevantTerms = this.glossary.getRelevant(sourceBatch.join(' ') + ' ' + recentCtx);

                const context = {
                    chapterIndex: chIdx,
                    sentenceIndex: i,
                    slidingWindow: [...this.slidingWindow],
                    chapterSummary: this.chapterSummaries[chIdx] || '',
                    globalSummary: this.globalSummary,
                    relevantGlossary: relevantTerms,
                };

                const batchResult = await this._translateBatch(sourceBatch, context);

                if (batchResult.newTerms && batchResult.newTerms.length > 0) {
                    this.glossary.addBatch(batchResult.newTerms);
                    this._emit('glossaryUpdate', { glossary: this.glossary });
                }

                for (let bi = 0; bi < batchResult.items.length; bi++) {
                    const sentenceIndex = i + bi;
                    const sentence = sourceBatch[bi];
                    const result = batchResult.items[bi];

                    translatedSentences.push(result);

                    this.slidingWindow.push({ original: sentence, translation: result.translation });
                    if (this.slidingWindow.length > this.config.windowSize) {
                        this.slidingWindow.shift();
                    }

                    this.completedSentences++;
                    this._emit('sentenceComplete', {
                        chapterIndex: chIdx,
                        sentenceIndex: sentenceIndex,
                        original: sentence,
                        translation: result.translation,
                        note: result.note || '',
                        completed: this.completedSentences,
                        total: this.totalSentences,
                        percent: Math.round(this.completedSentences / this.totalSentences * 100),
                        tokensIn: this.tokensInput,
                        tokensOut: this.tokensOutput,
                    });

                    // 每batch句生成摘要
                    if ((sentenceIndex + 1) % summaryBatchSize === 0 || sentenceIndex === chapter.sentences.length - 1) {
                        const batchStart = Math.max(0, sentenceIndex - summaryBatchSize + 1);
                        const batchTranslations = translatedSentences.slice(batchStart).map(s => s.translation).join(' ');
                        await this._updateChapterSummary(chIdx, batchTranslations);
                    }
                }
            }

            // 章节完成 → 更新全局摘要
            await this._updateGlobalSummary();

            results.push({
                chapterIndex: chIdx,
                title: chapter.title,
                sentences: translatedSentences,
                summary: this.chapterSummaries[chIdx] || '',
            });

            this._emit('chapterComplete', {
                chapterIndex: chIdx,
                title: chapter.title,
            });
        }

        // === Phase 2: 完成 ===
        this._emit('complete', {
            chapters: results.length,
            sentences: this.completedSentences,
            tokensIn: this.tokensInput,
            tokensOut: this.tokensOutput,
            glossaryTerms: this.glossary.entries.length,
        });

        return results;
    }

    // ── 文风分析（优化版）──

    async _analyzeStyle(sampleText) {
        await this._checkPauseCancel();
        const sample = sampleText.slice(0, 1200);
        const prompt = `分析文风,输出JSON:{"style_summary":"30字风格","translation_guidelines":["要点1","要点2"]}\n文本:${sample}`;

        try {
            const messages = [{ role: 'system', content: 'JSON输出' }, { role: 'user', content: prompt }];
            const res = await this._chatWithTrace(messages, {
                type: 'translate',
                batch: 0,
                chapterTitle: '文风分析',
                temperature: 0.3,
                useStream: false
            });
            this.tokensInput += (res.usage && res.usage.prompt_tokens) || 0;
            this.tokensOutput += (res.usage && res.usage.completion_tokens) || 0;

            const data = Utils.parseJSON(res.content);
            if (data) {
                this.styleProfile = data;
                this._emit('styleAnalyzed', { style: data });
            }
        } catch (e) {
            if (this._cancelled) throw new Error('CANCELLED');
            if (this._paused || this._isRequestAbortedError(e)) {
                await this._checkPauseCancel();
                return this._analyzeStyle(sampleText);
            }
            console.warn('文风分析失败:', e);
            this.styleProfile = { style_summary: '忠实流畅', translation_guidelines: ['忠实', '流畅'] };
            this._emit('styleAnalyzed', { style: this.styleProfile });
        }
    }

    // ── 术语提取（优化版）──

    async _extractGlossary(fullText) {
        const chunkSize = 2000;
        const maxChunks = 3;
        const chunks = [];
        for (let i = 0; i < fullText.length && chunks.length < maxChunks; i += chunkSize) {
            chunks.push(fullText.slice(i, i + chunkSize));
        }

        for (let i = 0; i < chunks.length; i++) {
            // 暂停检查：必须在循环开头
            await this._checkPauseCancel();
            
            // 暂停后继续时跳过已完成的
            if (this._paused) {
                this._emit('phase', { phase: 'paused', message: '已暂停 - 术语提取' });
                await this._checkPauseCancel(); // 等待恢复
            }
            
            this._emit('phase', { phase: 'glossary', message: `术语 (${i + 1}/${chunks.length})` });

            const prompt = `提取专名(人/地/物),输出JSON:{"terms":[{"original":"","translation":"","category":"character|location|item|other"}]}\n${chunks[i]}`;

            try {
                const res = await this.llm.chat(
                    [{ role: 'system', content: 'NER,JSON' }, { role: 'user', content: prompt }],
                    { temperature: 0.1 }
                );
                this.tokensInput += res.usage.prompt_tokens || 0;
                this.tokensOutput += res.usage.completion_tokens || 0;

                const data = Utils.parseJSON(res.content);
                if (data && data.terms) this.glossary.addBatch(data.terms);
            } catch (e) {
                if (this._cancelled) throw new Error('CANCELLED');
                // 暂停导致的abort错误，等待恢复后重试当前块
                if (this._paused || this._isRequestAbortedError(e)) {
                    this._emit('phase', { phase: 'paused', message: '已暂停' });
                    await this._checkPauseCancel();
                    i -= 1; // 重试当前块
                    continue;
                }
                console.warn(`术语提取块${i}失败:`, e);
                if (e && /超时/.test(String(e.message || ''))) {
                    this._emit('phase', { phase: 'glossary', message: '术语提取超时，跳过剩余术语...' });
                    break;
                }
            }
        }
        this._emit('glossaryUpdate', { glossary: this.glossary });
    }

    // ── 翻译单句 ──

    async _translateSentence(sentence, context) {
        const messages = this._buildPrompt(sentence, context);
        // 无限重试直到成功（API不可用时自动暂停，可用时自动恢复）
        while (true) {
            await this._checkPauseCancel();
            // 尝试3轮（每轮会轮询所有key）
            let lastError;
            for (let attempt = 0; attempt < 3; attempt++) {
                await this._checkPauseCancel();
                try {
                    const res = await this._chatWithTrace(messages, {
                        type: 'translate',
                        batch: 1,
                        chapterIndex: context.chapterIndex,
                        temperature: this.config.temperature,
                        reasoningEffort: this._getReasoningEffort('translate'),
                        useStream: true
                    });
                    this.tokensInput += res.usage.prompt_tokens || 0;
                    this.tokensOutput += res.usage.completion_tokens || 0;
                    this._consecutiveErrors = 0;
                    return this._parseTranslationResponse(res.content, sentence);
                } catch (e) {
                    if (this._cancelled) throw new Error('CANCELLED');
                    if (this._paused) {
                        attempt -= 1;
                        await this._checkPauseCancel();
                        continue;
                    }
                    lastError = e;
                    this._emit('error', {
                        type: 'api', message: e.message,
                        attempt: attempt + 1, maxAttempts: 3,
                        sentence: sentence.slice(0, 50),
                    });
                    if (attempt < 2) {
                        const delay = 3000 * (attempt + 1);
                        this._emit('phase', { phase:'retrying', message:`API错误，${delay/1000}秒后重试 (${attempt+1}/3)...` });
                        await Utils.sleep(delay);
                    }
                }
            }
            // 3轮全失败 → 自动暂停等待
            this._consecutiveErrors = (this._consecutiveErrors || 0) + 1;
            this._paused = true;
            this._emit('autoPaused', {
                reason: 'api_error',
                message: `API连续失败(${this._consecutiveErrors}): ${lastError.message}`,
                hint: '所有密钥不可用，等待恢复中... 点击"继续"重试',
                consecutiveErrors: this._consecutiveErrors,
            });
            // 等待用户恢复（或API恢复后用户点继续）
            await this._checkPauseCancel();
            this._emit('phase', { phase:'retrying', message:'恢复中，重新尝试...' });
            // 循环回去继续尝试，永不放弃
        }
    }

    async _translateBatch(sentences, context) {
        if (!sentences || sentences.length === 0) {
            return { items: [], newTerms: [] };
        }

        if (sentences.length === 1) {
            const result = await this._translateSentence(sentences[0], context);
            const item = { original: result.original, translation: result.translation };
            if (result.note && String(result.note).trim()) item.note = String(result.note).trim();
            return {
                items: [item],
                newTerms: result.newTerms || [],
            };
        }

        const messages = this._buildBatchPrompt(sentences, context);
        const maxTokens = this._estimateBatchMaxTokens(sentences);

        while (true) {
            await this._checkPauseCancel();
            let lastError;

            for (let attempt = 0; attempt < 3; attempt++) {
                await this._checkPauseCancel();
                try {
                    const res = await this._chatWithTrace(messages, {
                        type: 'translate',
                        batch: sentences.length,
                        chapterIndex: context.chapterIndex,
                        temperature: this.config.temperature,
                        maxTokens: maxTokens,
                        reasoningEffort: this._getReasoningEffort('translate'),
                        useStream: true
                    });
                    this.tokensInput += res.usage.prompt_tokens || 0;
                    this.tokensOutput += res.usage.completion_tokens || 0;
                    this._consecutiveErrors = 0;
                    return this._parseBatchTranslationResponse(res.content, sentences, {
                        finishReason: res.finishReason,
                        requestId: res.requestId,
                        usage: res.usage,
                        maxTokens: maxTokens
                    });
                } catch (e) {
                    if (this._cancelled) throw new Error('CANCELLED');
                    if (this._paused || this._isRequestAbortedError(e)) {
                        attempt -= 1;
                        await this._checkPauseCancel();
                        continue;
                    }
                    lastError = e;
                    const isParseError = !!e._batchParseFailure;
                    const details = e && e._batchDetails ? e._batchDetails : null;
                    const isLengthTruncated = isParseError
                        && details
                        && ['length', 'max_tokens'].includes(String(details.finishReason || '').trim().toLowerCase());
                    this._emit('error', {
                        taskType: 'translate',
                        type: isParseError ? 'format' : 'api',
                        message: e.message,
                        attempt: attempt + 1,
                        maxAttempts: 3,
                        sentence: (sentences[0] || '').slice(0, 50),
                        batch: sentences.length,
                        chapterIndex: context.chapterIndex,
                        requestId: details ? details.requestId : undefined,
                        expectedCount: details ? details.expectedCount : undefined,
                        actualCount: details ? details.actualCount : undefined,
                        jsonCount: details ? details.jsonCount : undefined,
                        textCount: details ? details.textCount : undefined,
                        parseSource: details ? details.parseSource : '',
                        finishReason: details ? details.finishReason : '',
                        responseLength: details ? details.responseLength : undefined,
                        usage: details ? details.usage : null,
                        contentPreview: details ? details.responsePreview : '',
                        maxTokens: details ? details.maxTokens : maxTokens
                    });
                    if (isLengthTruncated) {
                        return this._translateBatchParseFailureFallback(sentences, context);
                    }
                    if (attempt < 2) {
                        const delay = isParseError ? 1000 : 3000 * (attempt + 1);
                        this._emit('phase', {
                            phase: 'retrying',
                            message: isParseError
                                ? `批量译文格式异常，${delay / 1000}秒后重试 (${attempt + 1}/3)...`
                                : `API错误，${delay / 1000}秒后重试 (${attempt + 1}/3)...`
                        });
                        await Utils.sleep(delay);
                    }
                }
            }

            if (lastError && lastError._batchParseFailure) {
                console.warn('批量翻译解析失败，拆半后重试:', lastError);
                return this._translateBatchParseFailureFallback(sentences, context);
            }

            this._consecutiveErrors = (this._consecutiveErrors || 0) + 1;
            this._paused = true;
            this._emit('autoPaused', {
                reason: 'api_error',
                message: `API连续失败(${this._consecutiveErrors}): ${String(lastError && lastError.message || lastError || '未知错误')}`,
                hint: '所有密钥不可用，等待恢复中... 点击"继续"重试',
                consecutiveErrors: this._consecutiveErrors,
            });
            await this._checkPauseCancel();
            this._emit('phase', { phase:'retrying', message:'恢复中，重新尝试...' });
        }
    }

    _mergeSlidingWindow(baseWindow, items) {
        const window = [...(baseWindow || [])];
        for (let i = 0; i < (items || []).length; i++) {
            const item = items[i];
            if (!item || !item.translation) continue;
            window.push({ original: item.original, translation: item.translation });
            if (window.length > this.config.windowSize) {
                window.shift();
            }
        }
        return window;
    }

    async _translateBatchParseFailureFallback(sentences, context) {
        if (!sentences || sentences.length === 0) {
            return { items: [], newTerms: [] };
        }

        if (sentences.length <= 2) {
            this._emit('phase', {
                phase: 'retrying',
                message: `批量失败，改逐句重试（${sentences.length}句）...`
            });
            return this._translateBatchSequentialFallback(sentences, context);
        }

        const leftSize = Math.ceil(sentences.length / 2);
        const rightSize = sentences.length - leftSize;
        this._emit('phase', {
            phase: 'retrying',
            message: `批量失败，拆半重试（${sentences.length}→${leftSize}+${rightSize}）...`
        });

        const leftSentences = sentences.slice(0, leftSize);
        const rightSentences = sentences.slice(leftSize);
        const leftResult = await this._translateBatch(leftSentences, context);
        const rightContext = {
            ...context,
            sentenceIndex: (context.sentenceIndex || 0) + leftSize,
            slidingWindow: this._mergeSlidingWindow(context.slidingWindow, leftResult.items)
        };
        const rightResult = await this._translateBatch(rightSentences, rightContext);

        return {
            items: [...leftResult.items, ...rightResult.items],
            newTerms: this._normalizeTerms([...(leftResult.newTerms || []), ...(rightResult.newTerms || [])]),
        };
    }

    async _translateBatchSequentialFallback(sentences, context) {
        const items = [];
        let newTerms = [];
        const localWindow = [...(context.slidingWindow || [])];

        for (let i = 0; i < sentences.length; i++) {
            const sentence = sentences[i];
            const recentCtx = localWindow.slice(-2).map(w => w.original).join(' ');
            const relevantTerms = this.glossary.getRelevant(sentence + ' ' + recentCtx);
            const result = await this._translateSentence(sentence, {
                chapterIndex: context.chapterIndex,
                sentenceIndex: context.sentenceIndex + i,
                slidingWindow: [...localWindow],
                chapterSummary: context.chapterSummary,
                globalSummary: context.globalSummary,
                relevantGlossary: relevantTerms,
            });

            const item = { original: sentence, translation: result.translation };
            if (result.note && String(result.note).trim()) item.note = String(result.note).trim();
            items.push(item);

            if (result.newTerms && result.newTerms.length > 0) {
                newTerms = newTerms.concat(result.newTerms);
            }

            localWindow.push({ original: sentence, translation: result.translation });
            if (localWindow.length > this.config.windowSize) {
                localWindow.shift();
            }
        }

        return {
            items: items,
            newTerms: this._normalizeTerms(newTerms),
        };
    }

    // ── 构建Prompt（优化版：动态上下文 + token节省）──

    _buildPromptContextParts(context, sourceLength) {
        const parts = [];
        const maxTerms = this.config.maxGlossaryPerSentence;
        const relevantTerms = (context.relevantGlossary || []).slice(0, maxTerms);

        if (relevantTerms.length > 0) {
            const termLines = relevantTerms.map(t => `${t.original}→${t.translation}`).join('; ');
            parts.push(`[术语] ${termLines}`);
        }

        if (context.globalSummary && context.sentenceIndex >= 5) {
            parts.push(`[背景] ${context.globalSummary.slice(0, this.config.globalSummaryLen)}`);
        }

        if (context.chapterSummary) {
            parts.push(`[本章] ${context.chapterSummary.slice(0, this.config.chapterSummaryLen)}`);
        }

        if (context.slidingWindow && context.slidingWindow.length > 0) {
            const isShort = sourceLength < 80;
            const winSize = isShort ? this.config.windowSizeShort : this.config.windowSize;
            const window = context.slidingWindow.slice(-winSize);
            const windowLines = window.map(w => `${w.original}|${w.translation}`).join('\n');
            parts.push(`[前文]\n${windowLines}`);
        }

        return parts;
    }

    _buildPrompt(sentence, context) {
        const style = this.styleProfile;
        const styleSum = style?.style_summary || '忠实流畅';
        const typeTag = { '奇幻': '史诗', '科幻': '精确', '文学': '细腻', '言情': '温柔' }[this.config.novelType] || '';
        const systemPrompt = `你是一位顶级文学翻译大师，精通原语言与${this.config.targetLang}的文化差异和表达习惯。
翻译风格：${styleSum}${typeTag ? '/' + typeTag : ''}。

【翻译原则】
1. 深入理解原文语境、情感、语气和潜台词，而非逐字直译
2. 用地道的${this.config.targetLang}重新表达，让读者感觉这就是用${this.config.targetLang}写的原创小说
3. 保持人物的说话风格、性格特征和情感色彩
4. 对话要口语化、自然，叙述要有文学质感
5. 注意句式变化，避免所有句子都用相同句式，消除翻译腔
6. 遵循术语表，保持专有名词一致

严格只输出JSON，不要输出任何其他内容。`;

        const parts = this._buildPromptContextParts(context, sentence.length);
        parts.push(`[待翻译] ${sentence}`);
        parts.push('请先在内心充分分析：这句话在上下文中的含义是什么？人物的情绪和语气？用中文最自然的方式该怎么表达？然后输出最终译文。不要把思考过程写进JSON。');
        parts.push('如遇书名、典故、俚语、双关或需要背景知识才能理解的内容，可用note字段补充15字以内简短注释；普通句子省略note。');
        parts.push('只输出JSON:{"translation":"","note":"可选,15字内注释","newTerms":[{"original":"","translation":"","category":"character|location|item|other"}]}');

        return [
            { role: 'system', content: systemPrompt },
            { role: 'user', content: parts.join('\n') },
        ];
    }

    _buildBatchPrompt(sentences, context) {
const systemPrompt = `你是一位顶级文学翻译大师，精通原语言与${this.config.targetLang}之间的文化差异和语言特性。

【翻译核心原则】
1. 理解优先：先深入理解每句话在上下文中的真实含义、情感和语气，再用${this.config.targetLang}重新创作
2. 地道表达：译文应读起来像${this.config.targetLang}原创小说，而非翻译作品。避免欧化长句、被动语态堆砌等翻译腔
3. 人物区分：不同角色的对话应体现不同的说话风格和性格特征。对话要口语化、鲜活
4. 叙述质感：叙述文字要有文学韵味，注意节奏感和画面感
5. 句式多变：避免所有句子用相同句式开头或结构，灵活调整语序
6. 术语一致：严格遵循术语表中的译名

先充分推理思考，再输出最终结果，但不要把推理过程写进translation或note。严格只输出JSON。

【注释规则】遇到以下内容时，用note字段添加15字以内的简短注释：
- 书名/名著/文学引用/典故（简述出处和含义）
- 俚语/双关语（解释字面外的含义）
- 需要背景知识才能理解的文化内容
普通句子不加note。`;

const parts = this._buildPromptContextParts(context, sentences.join(' ').length);
parts.push('[待译]');
parts.push(sentences.map((sentence, idx) => `${idx + 1}. ${sentence}`).join('\n'));
parts.push('只输出JSON:{"translations":[{"index":1,"translation":"","note":"可选,15字内注释"}],"newTerms":[{"original":"","translation":"","category":"character|location|item|other"}]}');
parts.push('要求:translations数量=原句数量,顺序一致。仅特殊内容加note,普通句子省略note字段。');

return [
{ role: 'system', content: systemPrompt },
{ role: 'user', content: parts.join('\n') },
];
}

    _estimateBatchMaxTokens(sentences) {
        // 不设上限，让模型自由输出完整结果
        return undefined;
    }

    _normalizeReasoningEffort(value, fallback = 'medium') {
        const normalized = String(value || '').trim().toLowerCase();
        if (['low', 'medium', 'high', 'xhigh'].includes(normalized)) return normalized;
        if (['precise', 'minimal', 'light', 'weak'].includes(normalized)) return 'low';
        if (['balanced', 'moderate', 'normal', 'mid'].includes(normalized)) return 'medium';
        if (['strong', 'deep', 'extreme', 'very_high', 'max'].includes(normalized)) return 'high';
        return fallback;
    }

    _getReasoningEffort(taskType) {
        const fallback = taskType === 'optimize' ? 'low' : 'medium';
        const raw = taskType === 'optimize'
            ? this.config.optimizeReasoningEffort
            : this.config.translationReasoningEffort;
        return this._normalizeReasoningEffort(raw, fallback);
    }

    _estimateUsageFromText(messages, content, reasoning) {
        const promptText = (messages || []).map(m => `[${m.role || 'user'}]\n${m.content || ''}`).join('\n\n');
        const completionText = [reasoning || '', content || ''].filter(Boolean).join('\n');
        const promptTokens = this.llm && this.llm.countTokens ? this.llm.countTokens(promptText) : 0;
        const completionTokens = this.llm && this.llm.countTokens ? this.llm.countTokens(completionText) : 0;
        return {
            prompt_tokens: promptTokens,
            completion_tokens: completionTokens,
            total_tokens: promptTokens + completionTokens
        };
    }

    async _chatWithTrace(messages, meta = {}) {
        const {
            type = 'translate',
            batch = 0,
            chapterIndex,
            chapterTitle = '',
            temperature = this.config.temperature,
            maxTokens,
            reasoningEffort,
            useStream = true
        } = meta;

        const requestId = ++this._apiTraceSeq;
        const requestedReasoningMode = reasoningEffort ? 'effort' : 'none';
        this._emit('apiCall', {
            type,
            status: 'requesting',
            batch,
            chapterIndex,
            chapterTitle,
            requestId,
            reasoningEffort,
            reasoningRequestedMode: requestedReasoningMode,
            reasoningMode: requestedReasoningMode,
            requestMessages: messages,
            requestOptions: options
        });

        const options = { temperature };
        if (maxTokens !== undefined && maxTokens !== null) {
            options.maxTokens = maxTokens;
        }
        if (reasoningEffort) {
            options.reasoningEffort = reasoningEffort;
            options.reasoning = { effort: reasoningEffort };
        }

        const canStream = useStream
            && this.config.enableReasoningTrace !== false
            && this.config.streamReasoningTrace !== false
            && this.llm
            && typeof this.llm.chatStream === 'function';

        if (canStream) {
            let content = '';
            let reasoning = '';
            let usage = null;
            let reasoningMeta = null;
            let finishReason = '';
            let lastReasoningEmitAt = 0;
            let lastContentEmitAt = 0;

            try {
                for await (const chunk of this.llm.chatStream(messages, options)) {
                    if (!chunk) continue;

                    if (typeof chunk === 'string') {
                        content += chunk;
                    } else if (chunk.type === 'meta' && chunk.reasoningMeta) {
                        reasoningMeta = chunk.reasoningMeta;
                        continue;
                    } else if (chunk.type === 'usage' && chunk.usage) {
                        usage = chunk.usage;
                        continue;
                    } else if (chunk.type === 'finish' && chunk.finishReason) {
                        finishReason = String(chunk.finishReason || '').trim();
                        continue;
                    } else if (chunk.type === 'reasoning' && chunk.delta) {
                        reasoning += chunk.delta;
                        const now = Date.now();
                        if (now - lastReasoningEmitAt >= 120 || /[\n。！？.!?]$/.test(chunk.delta)) {
                            this._emit('apiCall', {
                                type,
                                status: 'reasoning',
                                batch,
                                chapterIndex,
                                chapterTitle,
                                requestId,
                                reasoningEffort,
                                reasoningPreview: reasoning.slice(-1600)
                            });
                            lastReasoningEmitAt = now;
                        }
                        continue;
                    } else if (chunk.type === 'content' && chunk.delta) {
                        content += chunk.delta;
                    }

                    const now = Date.now();
                    const lastChar = content ? content.slice(-1) : '';
                    if (content && (now - lastContentEmitAt >= 120 || /[\n}\]。！？.!?]/.test(lastChar))) {
                        this._emit('apiCall', {
                            type,
                            status: 'streaming',
                            batch,
                            chapterIndex,
                            chapterTitle,
                            requestId,
                            reasoningEffort,
                            reasoningPreview: reasoning ? reasoning.slice(-800) : '',
                            contentPreview: content.slice(-1200)
                        });
                        lastContentEmitAt = now;
                    }
                }

                content = String(content || '').trim();
                reasoning = String(reasoning || '').trim();

                if (content) {
                    usage = usage || this._estimateUsageFromText(messages, content, reasoning);
                    const finalReasoningMode = reasoningMeta && reasoningMeta.finalMode ? reasoningMeta.finalMode : requestedReasoningMode;
                    this._emit('apiCall', {
                        type,
                        status: 'received',
                        batch,
                        chapterIndex,
                        chapterTitle,
                        requestId,
                        reasoningEffort,
                        reasoningRequestedMode: reasoningMeta && reasoningMeta.requestedMode ? reasoningMeta.requestedMode : requestedReasoningMode,
                        reasoningMode: finalReasoningMode,
                        reasoning,
                        content,
                        usage,
                        finishReason
                    });
                    return { content, reasoning, usage, reasoningMeta, finishReason, requestId };
                }
            } catch (e) {
                if (this._cancelled || this._paused || this._isRequestAbortedError(e)) {
                    throw e;
                }
                console.warn('流式推理日志失败，回退普通请求:', e);
            }
        }

        const res = await this.llm.chat(messages, options);
        const content = String(res.content || '');
        const reasoning = String(res.reasoning || '').trim();
        const reasoningMeta = res.reasoningMeta || null;
        const usage = res.usage || this._estimateUsageFromText(messages, content, reasoning);
        const finishReason = String(res.finishReason || '').trim();
        const finalReasoningMode = reasoningMeta && reasoningMeta.finalMode ? reasoningMeta.finalMode : requestedReasoningMode;
        this._emit('apiCall', {
            type,
            status: 'received',
            batch,
            chapterIndex,
            chapterTitle,
            requestId,
            reasoningEffort,
            reasoningRequestedMode: reasoningMeta && reasoningMeta.requestedMode ? reasoningMeta.requestedMode : requestedReasoningMode,
            reasoningMode: finalReasoningMode,
            reasoning,
            content,
            usage,
            finishReason
        });
        return {
            content,
            reasoning,
            reasoningMeta,
            usage,
            finishReason,
            requestId
        };
    }

    // ── 解析翻译响应 ──

    _splitResponseAndTerms(response) {
        let body = String(response || '').trim();
        let newTerms = [];

        if (body.includes('NEW_TERMS:')) {
            const parts = body.split('NEW_TERMS:');
            body = parts[0].trim();
            try {
                const arrMatch = parts[1].match(/\[[\s\S]*\]/);
                if (arrMatch) {
                    newTerms = this._normalizeTerms(JSON.parse(arrMatch[0]));
                }
            } catch (e) {}
        }

        return { body, newTerms };
    }

    _normalizeTerms(terms) {
        if (!Array.isArray(terms)) return [];
        return terms.map(term => {
            if (!term || typeof term !== 'object') return null;
            const original = String(term.original || term.source || term.src || '').trim();
            const translation = String(term.translation || term.target || term.tgt || '').trim();
            const category = String(term.category || term.type || 'other').trim() || 'other';
            if (!original || !translation) return null;
            return { original, translation, category };
        }).filter(Boolean);
    }

    _cleanTranslationText(text) {
        return String(text || '')
            .replace(/^\s*(?:译文|翻译)\s*[:：]\s*/i, '')
            .replace(/^["“”']+|["“”']+$/g, '')
            .replace(/\n{3,}/g, '\n\n')
            .trim();
    }

    _trimBatchResponsePreview(text, maxLen = 1200) {
        const raw = String(text || '').trim();
        if (!raw) return '';
        return raw.length > maxLen ? raw.slice(0, maxLen) + '\n...(已截断)' : raw;
    }

    _describeBatchFinishReason(finishReason) {
        const reason = String(finishReason || '').trim().toLowerCase();
        if (!reason) return '';
        if (reason === 'length' || reason === 'max_tokens') return '模型输出被长度上限截断';
        if (reason === 'content_filter') return '模型输出被内容过滤截断';
        if (reason === 'stop') return '模型正常停止，但返回条数不足';
        return '';
    }

    _countValidBatchItems(items) {
        return Array.isArray(items) ? items.filter(Boolean).length : 0;
    }

    _extractBatchTranslations(data, originals, allowPartial = false) {
        if (!data) return null;

        const rawItems = Array.isArray(data) ? data
            : Array.isArray(data.translations) ? data.translations
            : Array.isArray(data.items) ? data.items
            : Array.isArray(data.results) ? data.results
            : Array.isArray(data.lines) ? data.lines
            : null;

        if (!rawItems || rawItems.length === 0) return null;

        const mapped = new Array(originals.length);
        for (let i = 0; i < rawItems.length; i++) {
            const item = rawItems[i];
            let index = i + 1;
            let translation = '';
            let note = '';

            if (typeof item === 'string') {
                translation = item;
            } else if (item && typeof item === 'object') {
                const rawIndex = item.index !== undefined ? item.index : (item.id !== undefined ? item.id : item.no);
                const parsedIndex = parseInt(rawIndex, 10);
                if (!isNaN(parsedIndex)) index = parsedIndex;
                translation = item.translation || item.text || item.result || item.target || item.chinese || item.content || '';
                note = item.note || item.annotation || item.comment || '';
            }

            translation = this._cleanTranslationText(translation);
            if (!translation || index < 1 || index > originals.length) continue;
            const entry = { original: originals[index - 1], translation: translation };
            if (note && note.trim()) entry.note = note.trim();
            mapped[index - 1] = entry;
        }

        const validCount = mapped.filter(Boolean).length;
        if (validCount === 0) return null;
        return (allowPartial || validCount === originals.length) ? mapped : null;
    }

    _extractBatchTranslationsFromText(text, originals, allowPartial = false) {
        const normalizedText = String(text || '').replace(/\r\n/g, '\n').replace(/\\n/g, '\n').trim();
        const mapped = new Array(originals.length);
        const groups = [];
        const lines = normalizedText.split(/\n/);
        let current = null;

        for (let i = 0; i < lines.length; i++) {
            const rawLine = lines[i];
            const line = rawLine.trim();
            if (!line) continue;

            const match = line.match(/^(?:\[)?(\d+)(?:\])?[\.\):：、-]\s*(.*)$/);
            if (match) {
                if (current) groups.push(current);
                current = {
                    index: parseInt(match[1], 10),
                    parts: [match[2] || '']
                };
            } else if (current) {
                current.parts.push(line);
            }
        }
        if (current) groups.push(current);

        for (let i = 0; i < groups.length; i++) {
            const group = groups[i];
            const index = group.index;
            const translation = this._cleanTranslationText(group.parts.join('\n'));
            if (!isNaN(index) && index >= 1 && index <= originals.length && translation) {
                mapped[index - 1] = { original: originals[index - 1], translation: translation };
            }
        }

        const validCount = mapped.filter(Boolean).length;
        if (validCount === originals.length) return mapped;

        const compactLines = normalizedText.split(/\n+/).map(line => line.trim()).filter(Boolean);
        if (compactLines.length === originals.length) {
            return compactLines.map((line, idx) => ({
                original: originals[idx],
                translation: this._cleanTranslationText(line.replace(/^\s*(?:\[)?\d+(?:\])?[\.\):：、-]\s*/, ''))
            }));
        }

        if (originals.length === 1 && normalizedText) {
            return [{
                original: originals[0],
                translation: this._cleanTranslationText(normalizedText.replace(/^\s*(?:\[)?1(?:\])?[\.\):：、-]\s*/, ''))
            }];
        }

        if (allowPartial && validCount > 0) return mapped;
        return null;
    }

    _parseBatchTranslationResponse(response, originals, meta = {}) {
        const split = this._splitResponseAndTerms(response);
        const data = Utils.parseJSON(split.body);
        const jsonItems = this._extractBatchTranslations(data, originals, true);
        const textItems = this._extractBatchTranslationsFromText(split.body, originals, true);
        const jsonCount = this._countValidBatchItems(jsonItems);
        const textCount = this._countValidBatchItems(textItems);
        let items = null;
        let parseSource = 'none';
        let newTerms = split.newTerms;

        if (jsonCount === originals.length && Array.isArray(jsonItems)) {
            items = jsonItems;
            parseSource = 'json';
        } else if (textCount === originals.length && Array.isArray(textItems)) {
            items = textItems;
            parseSource = 'text';
        } else if (jsonCount > 0 || textCount > 0) {
            parseSource = jsonCount >= textCount ? 'json_partial' : 'text_partial';
        }

        if (data && typeof data === 'object') {
            newTerms = this._normalizeTerms(data.newTerms || data.terms || data.glossary || newTerms);
        }

        if (!items || items.length !== originals.length) {
            const finishReason = String(meta.finishReason || '').trim();
            const responseBody = String(split.body || '').trim();
            const actualCount = Math.max(jsonCount, textCount);
            const finishHint = this._describeBatchFinishReason(finishReason);
            const details = {
                expectedCount: originals.length,
                actualCount: actualCount,
                jsonCount: jsonCount,
                textCount: textCount,
                parseSource: parseSource,
                finishReason: finishReason,
                responseLength: responseBody.length,
                responsePreview: this._trimBatchResponsePreview(responseBody),
                requestId: meta.requestId,
                usage: meta.usage || null,
                maxTokens: meta.maxTokens,
                finishHint: finishHint
            };
            const messageParts = [
                '批量译文数量与原句不一致',
                `期望${details.expectedCount}条`,
                `实际${details.actualCount}条`,
                `来源${details.parseSource}`
            ];
            if (details.finishReason) messageParts.push(`finish_reason=${details.finishReason}`);
            if (details.maxTokens) messageParts.push(`maxTokens=${details.maxTokens}`);
            if (details.responseLength) messageParts.push(`响应长度=${details.responseLength}`);
            if (details.finishHint) messageParts.push(details.finishHint);

            const error = new Error(messageParts.join('；'));
            error._batchParseFailure = true;
            error._batchDetails = details;
            throw error;
        }

        return { items, newTerms };
    }

    _parseTranslationResponse(response, original) {
        const parsed = this._splitResponseAndTerms(response);
        const data = Utils.parseJSON(parsed.body);

        if (data && typeof data === 'object' && !Array.isArray(data)) {
            const translation = this._cleanTranslationText(
                data.translation || data.text || data.result || data.target || data.chinese || data.content || data.final || ''
            );
            let newTerms = parsed.newTerms;
            if (data.newTerms || data.terms || data.glossary) {
                newTerms = this._normalizeTerms(data.newTerms || data.terms || data.glossary);
            }
            if (translation) {
                const result = { original, translation, newTerms };
                const note = data.note || data.annotation || data.comment || '';
                if (note && String(note).trim()) result.note = String(note).trim();
                return result;
            }
        }

        return { original, translation: this._cleanTranslationText(parsed.body), newTerms: parsed.newTerms };
    }

    // ── 摘要生成 ──

    async _updateChapterSummary(chIdx, newText) {
        const existing = this.chapterSummaries[chIdx] || '';
        const maxLen = this.config.chapterSummaryLen;
        // 精简prompt
        const prompt = `摘要(${maxLen}字内,含人物情节):${existing ? '已有:'+existing.slice(0,30)+'...\n' : ''}${newText.slice(0, 800)}`;

        try {
            const res = await this.llm.chat(
                [{ role: 'system', content: `摘要≤${maxLen}字` }, { role: 'user', content: prompt }],
                { temperature: 0.2 }
            );
            this.tokensInput += res.usage.prompt_tokens || 0;
            this.tokensOutput += res.usage.completion_tokens || 0;
            this.chapterSummaries[chIdx] = res.content.trim().slice(0, maxLen + 20);
            this._emit('summaryUpdate', {
                type: 'chapter',
                chapterIndex: chIdx,
                summary: this.chapterSummaries[chIdx],
            });
        } catch (e) {
            console.warn('章节摘要生成失败:', e);
        }
    }

    async _updateGlobalSummary() {
        const allSum = Object.entries(this.chapterSummaries)
            .sort(([a], [b]) => Number(a) - Number(b))
            .map(([, v], idx) => `${idx + 1}:${v.slice(0,40)}`)  // 压缩每章摘要
            .join(';');

        if (!allSum) return;
        const maxLen = this.config.globalSummaryLen;

        try {
            const res = await this.llm.chat(
                [
                    { role: 'system', content: `合并摘要≤${maxLen}字` },
                    { role: 'user', content: allSum }
                ],
                { temperature: 0.2 }
            );
            this.tokensInput += res.usage.prompt_tokens || 0;
            this.tokensOutput += res.usage.completion_tokens || 0;
            this.globalSummary = res.content.trim().slice(0, maxLen + 30);
            this._emit('summaryUpdate', { type: 'global', summary: this.globalSummary });
        } catch (e) {
            console.warn('全局摘要生成失败:', e);
        }
    }

    // ── 控制 ──

    pause() {
        this._paused = true;
        this._pausedAt = Date.now();
        if (this.llm && this.llm.abortCurrentRequest) this.llm.abortCurrentRequest();
        this._emit('phase', { phase: 'paused', message: '已暂停' });
    }
    
    resume() { 
        this._paused = false; 
        this._pausedAt = null;
        this._emit('phase', { phase: 'resuming', message: '恢复中...' });
    }
    
    cancel() {
        this._cancelled = true;
        this._paused = false;
        if (this.llm && this.llm.abortCurrentRequest) this.llm.abortCurrentRequest();
    }

    _isRequestAbortedError(error) {
        const msg = String(error && error.message || error || '');
        return /请求已取消|abort|cancel/i.test(msg);
    }
    
    _isPausedError(error) {
        // 如果在暂停期间发生的错误，不应该计入重试
        return this._paused || (this._pausedAt && Date.now() - this._pausedAt < 1000);
    }

    async _checkPauseCancel() {
        if (this._cancelled) throw new Error('CANCELLED');
        while (this._paused) {
            await Utils.sleep(300);
            if (this._cancelled) throw new Error('CANCELLED');
        }
    }

    on(event, handler) {
        if (!event || typeof handler !== 'function') return () => {};
        if (!this._listeners[event]) this._listeners[event] = new Set();
        this._listeners[event].add(handler);
        return () => this.off(event, handler);
    }

    off(event, handler) {
        const bucket = this._listeners[event];
        if (!bucket) return;
        bucket.delete(handler);
        if (bucket.size === 0) delete this._listeners[event];
    }

    _emit(event, data) {
        if (this._onProgress) {
            try { this._onProgress(event, data); } catch (e) { console.warn('Progress callback error:', e); }
        }
        const bucket = this._listeners[event];
        if (!bucket) return;
        [...bucket].forEach(handler => {
            try { handler(data, event); } catch (e) { console.warn('Event listener error:', event, e); }
        });
    }

    /**
     * 优化翻译 — 全文翻译完成后，按章节润色
     * 让AI根据上下文语境优化翻译，使语言更流畅自然
     */
    async optimizeTranslation(results, onProgress) {
        this._onProgress = onProgress;
        this._cancelled = false;
        this._paused = false;

        const totalChapters = results.length;
        let completedChapters = 0;

        this._emit('optimizeStart', { totalChapters });

        const optimizedResults = [];

        for (let chIdx = 0; chIdx < results.length; chIdx++) {
            await this._checkPauseCancel();
            const chapter = results[chIdx];
            if (!chapter || !chapter.sentences || chapter.sentences.length === 0) {
                optimizedResults.push(chapter);
                continue;
            }

            this._emit('optimizeChapterStart', {
                chapterIndex: chIdx,
                title: chapter.title,
                sentenceCount: chapter.sentences.length
            });

            const optimizedChapter = await this.optimizeChapterEnhanced(chapter, chIdx);
            optimizedResults.push(optimizedChapter);

            completedChapters++;
            this._emit('optimizeChapterComplete', {
                chapterIndex: chIdx,
                completedChapters,
                totalChapters
            });
        }

        this._emit('optimizeComplete', { totalChapters });
        return optimizedResults;
    }

    async _optimizeBatch(batch, prevContext, nextContext, chapterTitle, chapterSummary) {
        const glossaryHint = this.glossary.entries.slice(0, 20)
            .map(e => `${e.original} → ${e.translation}`)
            .join('\n');

        const contextBefore = prevContext.length > 0
            ? '前文译文：\n' + prevContext.map(p => p.translation).join('\n') + '\n\n'
            : '';

        const contextAfter = nextContext.length > 0
            ? '\n\n后文译文：\n' + nextContext.map(p => p.translation).join('\n')
            : '';

        const pairsText = batch.map((p, i) =>
            `[${i + 1}]\n原文: ${p.original}\n译文: ${p.translation}`
        ).join('\n\n');

        const summaryHint = chapterSummary ? `章节摘要：${chapterSummary}\n` : '';

        const prompt = `你是资深翻译审校编辑。审阅以下原文与译文对照，找出需要修正或润色的译文。

审校与润色标准：
1. 错误修正：漏译、误译、增译、术语不一致
2. 表达润色：生硬、不自然、不符合中文习惯的表达
3. 语境适配：不符合上下文语境、语气不连贯、风格突兀的句子
