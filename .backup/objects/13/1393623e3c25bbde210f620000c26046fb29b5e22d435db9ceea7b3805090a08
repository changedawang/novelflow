/* NovelFlow — 组件样式 */

/* ═══ 1. 书架页 ═══ */
.shelf-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--sp-lg)}
.shelf-header h2{font-family:var(--font-heading);font-size:1.4rem;color:var(--text-primary)}
.shelf-empty{text-align:center;padding:var(--sp-xl) var(--sp-md);color:var(--text-dim)}
.shelf-empty-icon{font-size:3rem;margin-bottom:var(--sp-sm);opacity:.5}
.shelf-empty p{margin:4px 0}.shelf-empty .sub{font-size:.85rem}
.shelf-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:var(--sp-md)}

.book-card{position:relative;border-radius:var(--r-md);overflow:hidden;cursor:pointer;transition:all .3s var(--ease);box-shadow:var(--shadow-book);background:linear-gradient(135deg,var(--paper-lightest) 0%,var(--paper-light) 40%,var(--paper-base) 100%);border:1px solid var(--border-mid)}
.book-card:hover{transform:translateY(-4px) scale(1.02);box-shadow:0 12px 40px rgba(58,46,31,.22)}
.book-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:6px;background:linear-gradient(180deg,var(--accent),var(--accent-hover));border-radius:var(--r-md) 0 0 var(--r-md)}
.book-card-inner{padding:20px 16px 16px 20px;display:flex;flex-direction:column;min-height:200px}
.book-emoji{font-size:2.2rem;margin-bottom:10px}
.book-title{font-family:var(--font-heading);font-size:.95rem;font-weight:700;color:var(--text-primary);line-height:1.4;margin-bottom:6px;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
.book-lang{font-family:var(--font-ui);font-size:.7rem;color:var(--text-dim);margin-bottom:auto;padding-bottom:12px}
.book-progress{margin-top:auto}
.book-progress-bar{height:4px;background:var(--paper-mid);border-radius:2px;overflow:hidden;margin-bottom:6px}
.book-progress-fill{height:100%;border-radius:2px;transition:width .5s var(--ease);background:linear-gradient(90deg,var(--accent),var(--accent-hover))}
.book-progress-fill.complete{background:linear-gradient(90deg,var(--success),#6a8a57)}
.book-meta{display:flex;justify-content:space-between;align-items:center}
.book-status{font-family:var(--font-ui);font-size:.7rem;font-weight:600;padding:2px 8px;border-radius:10px;letter-spacing:.3px}
.book-status.s-translating{background:var(--accent-light);color:var(--accent)}
.book-status.s-paused{background:rgba(184,134,11,.15);color:var(--warning)}
.book-status.s-completed{background:rgba(90,114,71,.15);color:var(--success)}
.book-status.s-cancelled{background:rgba(160,65,58,.1);color:var(--danger)}
.book-date{font-family:var(--font-ui);font-size:.65rem;color:var(--text-dim)}
.book-delete{position:absolute;top:8px;right:8px;width:24px;height:24px;border-radius:50%;background:rgba(160,65,58,.8);color:#fff;border:none;font-size:.7rem;cursor:pointer;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .2s}
.book-card:hover .book-delete{opacity:1}

/* ═══ 2. 上传页 ═══ */
.upload-card{max-width:520px;margin:var(--sp-xl) auto}
.upload-area{text-align:center;padding:var(--sp-xl) var(--sp-lg);border:2px dashed var(--border-mid);border-radius:var(--r-lg);background:var(--paper-lightest);transition:all .3s var(--ease);cursor:pointer}
.upload-area.dragover{border-color:var(--accent);background:var(--accent-light);box-shadow:0 0 0 4px var(--accent-light)}
.upload-icon{font-size:3rem;display:block;margin-bottom:var(--sp-md)}
.upload-area h3{font-family:var(--font-heading);margin-bottom:8px;color:var(--text-primary)}
.upload-area p{font-family:var(--font-ui);color:var(--text-dim);font-size:.85rem;margin-bottom:var(--sp-md)}
.upload-or{margin-top:var(--sp-md);padding-top:var(--sp-md);border-top:1px solid var(--border-light)}

/* ═══ 3. 配置页 ═══ */
.config-card{max-width:600px;margin:0 auto;background:var(--paper-lightest);border:1px solid var(--border-mid);border-radius:var(--r-lg);padding:var(--sp-lg);box-shadow:var(--shadow-md)}
.config-header h3{font-family:var(--font-heading);font-size:1.15rem;margin-bottom:var(--sp-md)}
.config-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--sp-sm);margin-bottom:var(--sp-md)}
.cstat{text-align:center;padding:12px 8px;background:var(--paper-light);border-radius:var(--r-md);border:1px solid var(--border-light)}
.cstat-val{display:block;font-family:var(--font-mono);font-size:1.3rem;font-weight:700;color:var(--accent)}
.cstat-lbl{display:block;font-family:var(--font-ui);font-size:.7rem;color:var(--text-dim);margin-top:2px;text-transform:uppercase}
.config-preview{max-height:120px;overflow-y:auto;padding:var(--sp-sm);background:var(--paper-light);border-radius:var(--r-sm);border:1px solid var(--border-light);font-size:.8rem;color:var(--text-secondary);line-height:1.6;margin-bottom:var(--sp-md);font-family:var(--font-mono)}
.config-form{margin-bottom:var(--sp-lg)}
.cfg-row{display:flex;align-items:center;gap:var(--sp-sm);margin-bottom:var(--sp-sm)}
.cfg-row label{min-width:90px;flex-shrink:0}
.cfg-row select,.cfg-row input{flex:1}
.cfg-hint{font-family:var(--font-ui);font-size:.72rem;color:var(--text-dim);white-space:nowrap}
.cfg-advanced{margin-top:var(--sp-sm);border:1px solid var(--border-light);border-radius:var(--r-md);padding:var(--sp-sm) var(--sp-md)}
.cfg-advanced summary{font-family:var(--font-ui);font-size:.85rem;font-weight:600;cursor:pointer;color:var(--text-secondary);padding:4px 0}
.cfg-advanced[open]{padding-bottom:var(--sp-md)}
.config-actions{text-align:center}

/* ═══ 4. 翻译工作台 ═══ */
.work-topbar{display:flex;align-items:center;gap:var(--sp-md);margin-bottom:var(--sp-md);padding-bottom:var(--sp-sm);border-bottom:1px solid var(--border-light)}
.work-title{flex:1;font-family:var(--font-heading);font-size:1rem;font-weight:600;color:var(--text-primary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.work-actions{display:flex;gap:6px}
.pause-bar{display:none;align-items:center;justify-content:center;gap:var(--sp-md);padding:10px var(--sp-md);background:rgba(184,134,11,.12);border:1px solid var(--warning);border-radius:var(--r-md);margin-bottom:var(--sp-md);font-family:var(--font-ui);font-size:.85rem;color:var(--warning);font-weight:600}
.pause-bar.show{display:flex}
.work-status{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:var(--sp-sm);margin-bottom:var(--sp-sm);font-family:var(--font-ui);font-size:.82rem}
.ws-left,.ws-right{display:flex;align-items:center;gap:8px}
.ws-dot{width:8px;height:8px;border-radius:50%;background:var(--text-dim);flex-shrink:0}
.ws-dot.active{background:var(--success);box-shadow:0 0 6px var(--success);animation:pulse 1.5s infinite}
.ws-dot.paused{background:var(--warning)}.ws-dot.error{background:var(--danger)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.ws-phase{font-weight:600;color:var(--text-primary)}
.ws-detail{color:var(--text-dim)}
.ws-tokens{font-family:var(--font-mono);font-size:.75rem;color:var(--text-dim);padding:2px 8px;background:var(--paper-light);border-radius:var(--r-sm)}
.progress-wrap{margin-bottom:var(--sp-md)}
.progress-track{height:8px;background:var(--paper-mid);border-radius:4px;overflow:hidden;box-shadow:inset 0 1px 3px rgba(0,0,0,.1)}
.progress-bar{height:100%;width:0%;border-radius:4px;background:linear-gradient(90deg,var(--accent),var(--accent-hover));transition:width .4s var(--ease)}
.progress-info{display:flex;justify-content:space-between;margin-top:4px;font-family:var(--font-mono);font-size:.75rem;color:var(--text-dim)}
.done-banner{text-align:center;padding:var(--sp-lg);background:rgba(90,114,71,.08);border:1px solid var(--success);border-radius:var(--r-lg);margin-bottom:var(--sp-md)}
.done-banner h3{color:var(--success);margin-bottom:8px;font-family:var(--font-heading)}
.done-banner p{font-family:var(--font-ui);font-size:.85rem;color:var(--text-secondary);margin-bottom:var(--sp-md)}
.done-actions{display:flex;justify-content:center;gap:var(--sp-sm)}
.work-tabs{display:flex;gap:2px;border-bottom:2px solid var(--border-mid);margin-bottom:var(--sp-md);overflow-x:auto}
.wtab{font-family:var(--font-ui);font-size:.82rem;padding:8px 16px;border:none;background:transparent;color:var(--text-dim);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;transition:all .2s;white-space:nowrap}
.wtab:hover{color:var(--text-primary)}
.wtab.active{color:var(--accent);border-bottom-color:var(--accent);font-weight:600}
.wtab-badge{font-size:.7rem;background:var(--accent-light);color:var(--accent);padding:1px 6px;border-radius:8px;margin-left:4px}
.wpanel{display:none}.wpanel.active{display:block}
.trans-view{display:grid;grid-template-columns:1fr 1fr;gap:2px;border:1px solid var(--border-light);border-radius:var(--r-md);overflow:hidden;background:var(--border-light)}
.trans-col{background:var(--paper-lightest)}
.trans-col-head{font-family:var(--font-ui);font-size:.75rem;font-weight:600;color:var(--text-dim);text-transform:uppercase;padding:8px 12px;background:var(--paper-light);border-bottom:1px solid var(--border-light);letter-spacing:.5px}
.trans-col-body{padding:8px;max-height:50vh;overflow-y:auto}
.sent-row{padding:6px 8px;border-radius:var(--r-sm);font-size:.85rem;line-height:1.6;margin-bottom:2px;transition:background .2s}
.sent-row:hover{background:var(--accent-light)}
.sent-row.current{background:rgba(139,69,19,.08);border-left:3px solid var(--accent);padding-left:5px}
.sent-row.failed{color:var(--danger);opacity:.7}
.gl-toolbar{display:flex;gap:var(--sp-sm);margin-bottom:var(--sp-md);flex-wrap:wrap}
.gl-toolbar input{flex:1;min-width:120px}
.gl-table{width:100%;border-collapse:collapse;font-family:var(--font-ui);font-size:.82rem}
.gl-table th{text-align:left;padding:8px;color:var(--text-dim);font-size:.72rem;text-transform:uppercase;border-bottom:2px solid var(--border-mid);letter-spacing:.5px}
.gl-table td{padding:6px 8px;border-bottom:1px solid var(--border-light)}
.gl-table tr:hover td{background:var(--accent-light)}
.gl-cat{font-size:.7rem;padding:2px 6px;border-radius:8px;font-weight:600}
.gl-cat-character{background:rgba(139,69,19,.1);color:var(--cat-char)}
.gl-cat-location{background:rgba(90,114,71,.1);color:var(--cat-loc)}
.gl-cat-item{background:rgba(184,134,11,.1);color:var(--cat-item)}
.gl-cat-organization{background:rgba(74,107,138,.1);color:var(--cat-org)}
.gl-cat-concept{background:rgba(123,94,167,.1);color:var(--cat-concept)}
.gl-cat-other{background:rgba(154,138,110,.1);color:var(--cat-other)}
.panel-content{padding:var(--sp-md);background:var(--paper-lightest);border:1px solid var(--border-light);border-radius:var(--r-md);min-height:100px;font-family:var(--font-ui);font-size:.85rem;line-height:1.7;color:var(--text-secondary)}
.panel-empty{text-align:center;color:var(--text-dim);padding:var(--sp-lg)}

/* ═══ 5. 阅读器 ═══ */
.reader-topbar{display:flex;align-items:center;gap:var(--sp-md);margin-bottom:var(--sp-md);padding-bottom:var(--sp-sm);border-bottom:1px solid var(--border-light)}
.reader-title{flex:1;font-family:var(--font-heading);font-size:1.1rem;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.reader-actions{display:flex;gap:6px}
.reader-mode-toggle{display:flex;gap:2px;margin-bottom:var(--sp-md);background:var(--paper-light);border-radius:var(--r-md);padding:3px;border:1px solid var(--border-light)}
.rm-btn{font-family:var(--font-ui);font-size:.8rem;padding:6px 14px;border:none;background:transparent;color:var(--text-dim);cursor:pointer;border-radius:var(--r-sm);transition:all .2s}
.rm-btn:hover{color:var(--text-primary)}
.rm-btn.active{background:var(--paper-lightest);color:var(--accent);font-weight:600;box-shadow:var(--shadow-sm)}
.reader-body{background:var(--paper-lightest);border:1px solid var(--border-light);border-radius:var(--r-lg);padding:var(--sp-lg);min-height:60vh;box-shadow:var(--shadow-md);font-size:.95rem;line-height:1.9}
.reader-para{margin-bottom:var(--sp-md)}
.reader-src{color:var(--text-dim);font-size:.85rem;font-style:italic;margin-bottom:4px}
.reader-tgt{color:var(--text-primary)}
.reader-chapter{font-family:var(--font-heading);font-size:1.2rem;font-weight:700;color:var(--accent);margin:var(--sp-lg) 0 var(--sp-md);padding-bottom:var(--sp-sm);border-bottom:1px solid var(--border-light)}

/* ═══ 6. 弹窗 ═══ */
.modal-bg{position:fixed;inset:0;z-index:200;background:rgba(58,46,31,.5);display:flex;align-items:center;justify-content:center;padding:var(--sp-md);backdrop-filter:blur(4px)}
.modal-card{background:var(--paper-lightest);border:1px solid var(--border-mid);border-radius:var(--r-lg);width:100%;max-width:480px;max-height:90vh;overflow-y:auto;box-shadow:var(--shadow-lg)}
.modal-sm{max-width:380px}
.modal-head{display:flex;align-items:center;justify-content:space-between;padding:var(--sp-md) var(--sp-lg);border-bottom:1px solid var(--border-light)}
.modal-head h3{font-family:var(--font-heading);font-size:1rem}
.modal-close{background:none;border:none;font-size:1.2rem;cursor:pointer;color:var(--text-dim);padding:4px}
.modal-close:hover{color:var(--text-primary)}
.modal-body{padding:var(--sp-lg)}
.fg{margin-bottom:var(--sp-md)}
.fg label{display:block;margin-bottom:4px}
.fg-row{display:grid;grid-template-columns:1fr 1fr;gap:var(--sp-md)}
.modal-note{font-family:var(--font-ui);font-size:.78rem;color:var(--text-dim);text-align:center}
.modal-actions{display:flex;justify-content:flex-end;gap:var(--sp-sm);margin-top:var(--sp-md)}
.export-list{display:flex;flex-direction:column;gap:var(--sp-sm)}
.export-item{display:flex;align-items:center;gap:var(--sp-md);padding:12px var(--sp-md);border:1px solid var(--border-light);border-radius:var(--r-md);cursor:pointer;transition:all .2s}
.export-item:hover{border-color:var(--accent);background:var(--accent-light)}
.export-item span:first-child{font-size:1.5rem}
.export-item strong{font-size:.9rem;display:block}
.export-item p{font-size:.75rem;color:var(--text-dim);margin:2px 0 0}

@media(max-width:640px){
    .trans-view{grid-template-columns:1fr}
    .config-stats{grid-template-columns:repeat(2,1fr)}
    .shelf-grid{grid-template-columns:repeat(auto-fill,minmax(150px,1fr))}
    .fg-row{grid-template-columns:1fr}
}
