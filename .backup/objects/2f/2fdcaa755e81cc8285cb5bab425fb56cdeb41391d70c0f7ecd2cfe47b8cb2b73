<!DOCTYPE html>
<html>
<head><meta charset="utf-8"><title>CORS Test</title></head>
<body>
<h2>CORS Test for api.ccroute.net</h2>
<pre id="log" style="white-space:pre-wrap;font-size:14px;background:#f0f0f0;padding:12px;"></pre>
<script>
const log = document.getElementById('log');
function L(msg){ log.textContent += msg + '\n'; }

async function test() {
    const url = 'https://api.ccroute.net/v1/models';
    const key = 'ccp_e89cd0260f3c49971e09124b920f98af';
    
    L('=== Test 1: fetch with Authorization header ===');
    try {
        const r = await fetch(url, { method:'GET', headers:{ 'Authorization':'Bearer '+key } });
        L('Status: ' + r.status);
        const data = await r.json();
        L('Response: ' + JSON.stringify(data).slice(0,500));
    } catch(e) {
        L('ERROR: ' + e.name + ': ' + e.message);
    }
    
    L('\n=== Test 2: fetch without Authorization (simple request) ===');
    try {
        const r = await fetch(url);
        L('Status: ' + r.status);
        const text = await r.text();
        L('Response: ' + text.slice(0,300));
    } catch(e) {
        L('ERROR: ' + e.name + ': ' + e.message);
    }

    L('\n=== Test 3: XMLHttpRequest ===');
    try {
        const xhr = new XMLHttpRequest();
        xhr.open('GET', url, false);
        xhr.setRequestHeader('Authorization', 'Bearer ' + key);
        xhr.send();
        L('Status: ' + xhr.status);
        L('Response: ' + xhr.responseText.slice(0,500));
    } catch(e) {
        L('ERROR: ' + e.name + ': ' + e.message);
    }
}

test();
</script>
</body>
</html>
</pre></body></html>
</script>
</body>
</html>