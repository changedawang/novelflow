/* NovelFlow — UI Controller v4 书架版 */
class UIController {
    constructor() {
        this.pages = { shelf:'page-shelf', upload:'page-upload', config:'page-config', work:'page-work', reader:'page-reader' };
        this.currentPage = 'shelf';
        this.engine = null;
        this.chapters = null;
        this.fileName = '';
        this.currentBookId = null;
        this.translationResults = [];
        this._autoScroll = true;
        this._init();
    }

    /* ── 初始化 ── */
    _init() {
        this._loadSettings();
        this._bindNav();
        this._bindUpload();
        this._bindConfig();
        this._bindWork();
        this._bindReader();
        this._bindModals();
        this._renderShelf();
    }

    /* ── 页面切换 ── */
    _showPage(name) {
        Object.values(this.pages).forEach(id => document.getElementById(id).classList.add('hidden'));
        document.getElementById(this.pages[name]).classList.remove('hidden');
        this.currentPage = name;
    }

    /* ── localStorage 书籍数据 ── */
    _getBooks() { return Utils.loadLocal('books', []); }
    _saveBooks(books) { Utils.saveLocal('books', books); }
    _getBook(id) { return this._getBooks().find(b => b.id === id); }
    _saveBook(book) {
        const books = this._getBooks();
        const idx = books.findIndex(b => b.id === book.id);
        if (idx >= 0) books[idx] = book; else books.unshift(book);
        this._saveBooks(books);
    }
    _deleteBook(id) { this._saveBooks(this._getBooks().filter(b => b.id !== id)); }

    /* ── 书架渲染 ── */
    _renderShelf() {
        const books = this._getBooks();
        const grid = document.getElementById('shelf-grid');
        const empty = document.getElementById('shelf-empty');
        if (books.length === 0) { empty.classList.remove('hidden'); grid.innerHTML = ''; return; }
        empty.classList.add('hidden');
        const emojis = ['📕','📗','📘','📙','📓','📔','📒'];
        grid.innerHTML = books.map((b, i) => {
            const pct = b.total > 0 ? Math.round(b.completed / b.total * 100) : 0;
            const emoji = emojis[i % emojis.length];
            const status = b.status || 'completed';
            const statusLabel = {translating:'翻译中',paused:'已暂停',completed:'已完成',cancelled:'已取消'}[status] || status;
            const date = b.updatedAt ? new Date(b.updatedAt).toLocaleDateString() : '';
            return `<div class="book-card" data-id="${b.id}">
                <button class="book-delete" data-del="${b.id}" title="删除">✕</button>
                <div class="book-card-inner">
                    <div class="book-emoji">${emoji}</div>
                    <div class="book-title">${Utils.escapeHtml(b.fileName || '未命名')}</div>
                    <div class="book-lang">→ ${Utils.escapeHtml(b.targetLang || '简体中文')}</div>
                    <div class="book-progress">
                        <div class="book-progress-bar"><div class="book-progress-fill ${pct>=100?'complete':''}" style="width:${pct}%"></div></div>
                        <div class="book-meta">
                            <span class="book-status s-${status}">${statusLabel} ${pct}%</span>
                            <span class="book-date">${date}</span>
                        </div>
                    </div>
                </div>
            </div>`;
        }).join('');
        grid.querySelectorAll('.book-card').forEach(card => {
            card.addEventListener('click', e => {
                if (e.target.classList.contains('book-delete')) return;
                this._openBook(card.dataset.id);
            });
        });
        grid.querySelectorAll('.book-delete').forEach(btn => {
            btn.addEventListener('click', e => {
                e.stopPropagation();
                if (confirm('确定删除这本书？')) { this._deleteBook(btn.dataset.del); this._renderShelf(); }
            });
        });
    }

    _openBook(id) {
        const book = this._getBook(id);
        if (!book) return;
        if (book.status === 'completed' || book.status === 'cancelled') {
            this._openReader(book);
        } else {
            this._resumeBook(book);
        }
    }

    /* ── 导航绑定 ── */
    _bindNav() {
        document.getElementById('btn-new-book').addEventListener('click', () => this._showPage('upload'));
        document.getElementById('btn-back-shelf').addEventListener('click', () => { this._showPage('shelf'); this._renderShelf(); });
        document.getElementById('btn-back-upload').addEventListener('click', () => this._showPage('upload'));
        document.getElementById('btn-back-shelf2').addEventListener('click', () => { this._showPage('shelf'); this._renderShelf(); });
        document.getElementById('btn-settings').addEventListener('click', () => this._openSettingsModal());
    }

    /* ── 设置 ── */
    _loadSettings() {
        this.settings = Utils.loadLocal('settings', { provider:'deepseek', apiKey:'', baseUrl:'', model:'deepseek-chat', temperature:0.3, maxTokens:1024 });
    }
    _openSettingsModal() {
        const s = this.settings;
        document.getElementById('api-provider').value = s.provider || 'deepseek';
        document.getElementById('api-key').value = s.apiKey || '';
        document.getElementById('api-base-url').value = s.baseUrl || '';
        document.getElementById('api-model').value = s.model || 'deepseek-chat';
        document.getElementById('api-temp').value = s.temperature || 0.3;
        document.getElementById('api-max-tokens').value = s.maxTokens || 1024;
        this._toggleCustomUrl();
        document.getElementById('modal-settings').classList.remove('hidden');
    }
    _toggleCustomUrl() {
        const p = document.getElementById('api-provider').value;
        document.getElementById('custom-url-group').classList.toggle('hidden', p !== 'custom');
    }

    /* ── 上传绑定 ── */
    _bindUpload() {
        const area = document.getElementById('upload-area');
        const input = document.getElementById('file-input');
        document.getElementById('btn-choose-file').addEventListener('click', e => { e.stopPropagation(); input.click(); });
        area.addEventListener('click', () => input.click());
        area.addEventListener('dragover', e => { e.preventDefault(); area.classList.add('dragover'); });
        area.addEventListener('dragleave', () => area.classList.remove('dragover'));
        area.addEventListener('drop', e => { e.preventDefault(); area.classList.remove('dragover'); if(e.dataTransfer.files[0]) this._handleFile(e.dataTransfer.files[0]); });
        input.addEventListener('change', () => { if(input.files[0]) this._handleFile(input.files[0]); input.value=''; });
        document.getElementById('btn-demo').addEventListener('click', e => { e.stopPropagation(); this._loadDemo(); });
    }
    _handleFile(file) {
        this.fileName = file.name.replace(/\.txt$/i,'');
        const reader = new FileReader();
        reader.onload = () => this._processText(reader.result);
        reader.readAsText(file);
    }
    _loadDemo() {
        this.fileName = 'Demo - The Garden';
        const demo = `Chapter 1\n\nThe old house stood at the edge of the village, its windows dark and silent. Margaret had not visited since her grandmother's passing three winters ago. The garden, once a magnificent tapestry of roses and lavender, had surrendered to wild brambles.\n\n"You'll find it changed," Mrs. Chen had warned her at the station. The old woman's eyes held something—pity, perhaps, or was it fear?\n\nMargaret pushed open the iron gate. It protested with a sound like a wounded animal. The path to the front door was barely visible beneath the overgrowth.\n\nChapter 2\n\nInside, the air was thick with dust and memory. Photographs lined the hallway—faces she recognized and faces she did not. Her grandmother's portrait hung above the fireplace, those piercing blue eyes seeming to follow her across the room.\n\nA floorboard creaked upstairs. Margaret froze. The house was supposed to be empty.\n\n"Hello?" she called, her voice braver than she felt. Silence answered, but it was the wrong kind of silence—too deliberate, too watchful.`;
        this._processText(demo);
    }
    _processText(text) {
        const splitter = new TextSplitter();
        this.chapters = splitter.parse(text);
        const totalSent = this.chapters.reduce((s,c)=>s+c.sentences.length,0);
        const totalChars = text.length;
        document.getElementById('cfg-filename').textContent = this.fileName;
        document.getElementById('cfg-chars').textContent = Utils.formatNumber(totalChars);
        document.getElementById('cfg-sentences').textContent = totalSent;
        document.getElementById('cfg-chapters').textContent = this.chapters.length;
        document.getElementById('cfg-tokens').textContent = Utils.formatNumber(totalSent * 1650);
        document.getElementById('cfg-preview').textContent = text.slice(0,500) + (text.length>500?'...':'');
        this._showPage('config');
    }

    /* ── 配置绑定 ── */
    _bindConfig() {
        document.getElementById('btn-start-translate').addEventListener('click', () => this._startTranslation());
    }
    _startTranslation() {
        if(!this.settings.apiKey){ alert('请先在设置中填写API Key'); this._openSettingsModal(); return; }
        if(!this.chapters || this.chapters.length===0){ alert('没有可翻译的内容'); return; }
        const bookId = Utils.uid();
        this.currentBookId = bookId;
        this.translationResults = [];
        const totalSent = this.chapters.reduce((s,c)=>s+c.sentences.length,0);
        const book = {
            id: bookId, fileName: this.fileName,
            targetLang: document.getElementById('cfg-lang').value,
            chapters: this.chapters, results: [], glossary: null, styleProfile: null,
            globalSummary:'', chapterSummaries:{}, tokensIn:0, tokensOut:0,
            completed:0, total:totalSent, status:'translating',
            createdAt: Date.now(), updatedAt: Date.now()
        };
        this._saveBook(book);
        this._launchEngine(book);
    }

    _resumeBook(book) {
        this.currentBookId = book.id;
        this.fileName = book.fileName;
        this.chapters = book.chapters;
        this.translationResults = book.results || [];
        book.status = 'translating';
        book.updatedAt = Date.now();
        this._saveBook(book);
        this._launchEngine(book);
    }

    _launchEngine(book) {
        document.getElementById('work-title').textContent = book.fileName;
        document.getElementById('src-list').innerHTML = '';
        document.getElementById('tgt-list').innerHTML = '';
        document.getElementById('done-banner').classList.add('hidden');
        document.getElementById('pause-bar').classList.remove('show');
        this._setDot('active');
        this._showPage('work');
        // 恢复已翻译的UI
        if(book.results && book.results.length>0){
            for(const ch of book.results){
                for(const s of ch.sentences){
                    this._addSentRow(s.original, s.translation, s.failed);
                }
            }
        }
        const s = this.settings;
        const cfg = {
            api:{ apiKey:s.apiKey, model:s.model, baseUrl:s.baseUrl, provider:s.provider },
            targetLang: book.targetLang,
            windowSize: parseInt(document.getElementById('cfg-window').value)||8,
            temperature: parseFloat(s.temperature)||0.3,
            autoGlossary: document.getElementById('cfg-glossary').checked,
            autoStyle: document.getElementById('cfg-style').checked,
        };
        this.engine = new TranslationEngine(cfg);
        // 恢复引擎状态
        if(book.glossary) this.engine.glossary.fromJSON(book.glossary);
        if(book.styleProfile) this.engine.styleProfile = book.styleProfile;
        if(book.globalSummary) this.engine.globalSummary = book.globalSummary;
        if(book.chapterSummaries) this.engine.chapterSummaries = book.chapterSummaries;
        this.engine.tokensInput = book.tokensIn||0;
        this.engine.tokensOutput = book.tokensOut||0;
        this.engine.completedSentences = book.completed||0;

        // 计算剩余章节
        const doneChapters = (book.results||[]).length;
        const remaining = this.chapters.slice(doneChapters);
        this.engine.totalSentences = this.chapters.reduce((s,c)=>s+c.sentences.length,0);

        this.engine.translateBook(remaining, (ev,d) => this._onProgress(ev,d))
            .then(results => {
                this.translationResults = [...(book.results||[]), ...results];
                this._onComplete();
            })
            .catch(err => {
                if(err.message==='CANCELLED'){ this._onCancelled(); }
                else { console.error(err); alert('翻译错误: '+err.message); }
            });
    }
