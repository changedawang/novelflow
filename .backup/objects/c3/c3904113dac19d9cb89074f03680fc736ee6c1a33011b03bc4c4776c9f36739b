/* ============================================
   NovelFlow — 多格式文本解析器
   支持: TXT / EPUB / HTML / Markdown / DOCX
   ============================================ */

class TextSplitter {
    constructor() {
        this.chapterPatterns = [
            /^(Chapter|CHAPTER)\s+(\d+|[IVXLC]+)/i,
            /^(Part|PART)\s+(\d+|[IVXLC]+|One|Two|Three|Four|Five)/i,
            /^第[一二三四五六七八九十百千零\d]+[章节回卷部篇]/,
            /^(Prologue|PROLOGUE|Epilogue|EPILOGUE)/i,
            /^(BOOK|Book)\s+(\d+|[IVXLC]+)/i,
        ];
    }

    /* ═══════════════════════════════════════
       入口：根据文件类型自动分发
       file: File对象
       返回: Promise<{chapters, fileName, format}>
       ═══════════════════════════════════════ */
    async parseFile(file) {
        const name = file.name;
        const ext = name.split('.').pop().toLowerCase();
        let chapters;

        switch (ext) {
            case 'epub':
                chapters = await this._parseEpub(file);
                break;
            case 'html':
            case 'htm':
                chapters = await this._parseHtml(await this._readText(file));
                break;
            case 'md':
            case 'markdown':
                chapters = await this._parseMarkdown(await this._readText(file));
                break;
            case 'docx':
                chapters = await this._parseDocx(file);
                break;
            case 'txt':
            default:
                chapters = this.parse(await this._readText(file));
                break;
        }

        return {
            chapters: chapters.filter(ch => ch.sentences.length > 0),
            fileName: name.replace(/\.[^.]+$/, ''),
            format: ext,
        };
    }

    /* ═══ 读取文件为文本 ═══ */
    _readText(file) {
        return new Promise((resolve, reject) => {
            const r = new FileReader();
            r.onload = () => resolve(r.result);
            r.onerror = () => reject(new Error('文件读取失败'));
            r.readAsText(file);
        });
    }

    _readArrayBuffer(file) {
        return new Promise((resolve, reject) => {
            const r = new FileReader();
            r.onload = () => resolve(r.result);
            r.onerror = () => reject(new Error('文件读取失败'));
            r.readAsArrayBuffer(file);
        });
    }

    /* ═══════════════════════════════════════
       EPUB 解析 (使用 JSZip)
       ═══════════════════════════════════════ */
    async _parseEpub(file) {
        if (typeof JSZip === 'undefined') throw new Error('JSZip 未加载，无法解析 EPUB');
        const buf = await this._readArrayBuffer(file);
        const zip = await JSZip.loadAsync(buf);

        // 1. 读取 container.xml 找到 OPF 路径
        const containerXml = await zip.file('META-INF/container.xml')?.async('string');
        if (!containerXml) throw new Error('无效的 EPUB：缺少 container.xml');
        const opfPath = this._extractAttr(containerXml, 'rootfile', 'full-path');
        if (!opfPath) throw new Error('无效的 EPUB：无法找到 OPF');

        const opfDir = opfPath.includes('/') ? opfPath.substring(0, opfPath.lastIndexOf('/') + 1) : '';

        // 2. 读取 OPF 获取 spine 顺序
        const opfXml = await zip.file(opfPath)?.async('string');
        if (!opfXml) throw new Error('无法读取 OPF 文件');

        const manifest = this._parseManifest(opfXml);
        const spineIds = this._parseSpine(opfXml);

        // 3. 按 spine 顺序读取 HTML 内容
        const chapters = [];
        for (const id of spineIds) {
            const item = manifest[id];
            if (!item) continue;
            const href = opfDir + item.href;
            const content = await zip.file(href)?.async('string');
            if (!content) continue;

            // 提取文本
            const { title, text } = this._extractFromHtml(content);
            if (!text.trim()) continue;

            const chTitle = title || `章节 ${chapters.length + 1}`;
            const sentences = this._splitSentences(text);
            if (sentences.length > 0) {
                chapters.push({ title: chTitle, sentences });
            }
        }

        // 如果EPUB只解析到1章但内容很长，尝试按章节模式再拆分
        if (chapters.length === 1 && chapters[0].sentences.length > 50) {
            const fullText = chapters[0].sentences.join(' ');
            const reParsed = this.parse(fullText);
            if (reParsed.length > 1) return reParsed;
        }

        return chapters.length > 0 ? chapters : [{ title: '全文', sentences: this._splitSentences('EPUB内容解析为空') }];
    }

    _extractAttr(xml, tag, attr) {
        const re = new RegExp(`<${tag}[^>]*${attr}="([^"]*)"`, 'i');
        const m = xml.match(re);
        return m ? m[1] : null;
    }

    _parseManifest(opfXml) {
        const manifest = {};
        const re = /<item\s+[^>]*id="([^"]*)"[^>]*href="([^"]*)"[^>]*media-type="([^"]*)"[^>]*\/?>/gi;
        let m;
        while ((m = re.exec(opfXml)) !== null) {
            manifest[m[1]] = { href: decodeURIComponent(m[2]), type: m[3] };
        }
        // 有些EPUB的id和href属性顺序不同
        const re2 = /<item\s+[^>]*href="([^"]*)"[^>]*id="([^"]*)"[^>]*media-type="([^"]*)"[^>]*\/?>/gi;
        while ((m = re2.exec(opfXml)) !== null) {
            if (!manifest[m[2]]) manifest[m[2]] = { href: decodeURIComponent(m[1]), type: m[3] };
        }
        return manifest;
    }

    _parseSpine(opfXml) {
        const ids = [];
        const re = /<itemref\s+[^>]*idref="([^"]*)"[^>]*\/?>/gi;
        let m;
        while ((m = re.exec(opfXml)) !== null) {
            ids.push(m[1]);
        }
        return ids;
    }

    /* ═══════════════════════════════════════
       HTML 解析
       ═══════════════════════════════════════ */
    async _parseHtml(htmlStr) {
        const { title, text } = this._extractFromHtml(htmlStr);
        // 尝试按章节模式拆分
        const chapters = this.parse(text);
        if (chapters.length === 1 && title) {
            chapters[0].title = title;
        }
        return chapters;
    }

    _extractFromHtml(html) {
        // 提取title
        const titleMatch = html.match(/<title[^>]*>([\s\S]*?)<\/title>/i);
        const title = titleMatch ? titleMatch[1].trim() : '';

        // 移除 script/style/nav
        let cleaned = html
            .replace(/<script[\s\S]*?<\/script>/gi, '')
            .replace(/<style[\s\S]*?<\/style>/gi, '')
            .replace(/<nav[\s\S]*?<\/nav>/gi, '')
            .replace(/<header[\s\S]*?<\/header>/gi, '');

        // 标题标签转为换行+标记（用于章节检测）
        cleaned = cleaned.replace(/<h([1-3])[^>]*>([\s\S]*?)<\/h\1>/gi, (_, level, content) => {
            const t = this._stripTags(content).trim();
            return '\n\n' + t + '\n\n';
        });

        // p/div/br 转换行
        cleaned = cleaned
            .replace(/<br\s*\/?>/gi, '\n')
            .replace(/<\/p>/gi, '\n\n')
            .replace(/<\/div>/gi, '\n')
            .replace(/<\/li>/gi, '\n')
            .replace(/<[^>]+>/g, ' ');

        // 解码HTML实体
        const text = this._decodeEntities(cleaned).replace(/[ \t]+/g, ' ').replace(/\n{3,}/g, '\n\n').trim();
        return { title, text };
    }

    _stripTags(html) {
        return html.replace(/<[^>]+>/g, '').trim();
    }

    _decodeEntities(str) {
        var map = {};
        map['\x26amp;'] = '\x26';
        map['\x26lt;'] = '<';
        map['\x26gt;'] = '>';
        map['\x26quot;'] = '"';
        map['\x26#39;'] = "'";
        map['\x26apos;'] = "'";
        map['\x26nbsp;'] = ' ';
        map['\x26#x27;'] = "'";
        return str.replace(/&(?:#x?[\da-f]+|[a-z]+);/gi, function(m) { return map[m] || m; });
    }

    /* ═══════════════════════════════════════
       Markdown 解析
       ═══════════════════════════════════════ */
    async _parseMarkdown(mdText) {
        const lines = mdText.split(/\r?\n/);
        const chapters = [];
        let currentTitle = '';
        let currentLines = [];

        for (const line of lines) {
            // 检测 ATX 标题 (# ## ###)
            const headMatch = line.match(/^(#{1,3})\s+(.+)/);
            if (headMatch) {
                // 保存上一章
                if (currentLines.length > 0 || currentTitle) {
                    const text = currentLines.join('\n').trim();
                    if (text) {
                        chapters.push({
                            title: currentTitle || `章节 ${chapters.length + 1}`,
                            sentences: this._splitSentences(this._mdToPlain(text)),
                        });
                    }
                }
                currentTitle = headMatch[2].trim();
                currentLines = [];
            } else {
                currentLines.push(line);
            }
        }

        // 最后一段
        const lastText = currentLines.join('\n').trim();
        if (lastText) {
            chapters.push({
                title: currentTitle || `章节 ${chapters.length + 1}`,
                sentences: this._splitSentences(this._mdToPlain(lastText)),
            });
        }

        // 如果只有一章或没章节标题，尝试用通用章节检测
        if (chapters.length <= 1) {
            const plain = this._mdToPlain(mdText);
            const reParsed = this.parse(plain);
            if (reParsed.length > chapters.length) return reParsed;
        }

        return chapters;
    }

    _mdToPlain(md) {
        return md
            .replace(/!\[.*?\]\(.*?\)/g, '')      // 图片
            .replace(/\[([^\]]*)\]\(.*?\)/g, '$1') // 链接
            .replace(/[*_]{1,3}(.*?)[*_]{1,3}/g, '$1') // 粗体/斜体
            .replace(/`{1,3}[\s\S]*?`{1,3}/g, '')  // 代码
            .replace(/^[-*+]\s+/gm, '')             // 无序列表
            .replace(/^\d+\.\s+/gm, '')             // 有序列表
            .replace(/^>\s+/gm, '')                 // 引用
            .replace(/^---+$/gm, '')                // 分隔线
            .replace(/^#{1,6}\s+/gm, '')            // 标题标记
            .trim();
    }

    /* ═══════════════════════════════════════
       DOCX 解析 (使用 JSZip)
       ═══════════════════════════════════════ */
    async _parseDocx(file) {
        if (typeof JSZip === 'undefined') throw new Error('JSZip 未加载，无法解析 DOCX');
        const buf = await this._readArrayBuffer(file);
        const zip = await JSZip.loadAsync(buf);

        // DOCX 的正文在 word/document.xml
        const docXml = await zip.file('word/document.xml')?.async('string');
        if (!docXml) throw new Error('无效的 DOCX：缺少 document.xml');

        // 提取段落
        const paragraphs = [];
        const re = /<w:p[\s>][\s\S]*?<\/w:p>/gi;
        let m;
        while ((m = re.exec(docXml)) !== null) {
            const pXml = m[0];
            // 检测是否为标题样式
            const isHeading = /<w:pStyle\s+w:val="Heading[123]"/i.test(pXml) ||
                              /<w:pStyle\s+w:val="(Title|Subtitle)"/i.test(pXml);
            // 提取文本 runs
            const texts = [];
            const runRe = /<w:t[^>]*>([\s\S]*?)<\/w:t>/gi;
            let rm;
            while ((rm = runRe.exec(pXml)) !== null) {
                texts.push(rm[1]);
            }
            const text = texts.join('').trim();
            if (text) {
                paragraphs.push({ text, isHeading });
            }
        }

        // 按标题拆分章节
        const chapters = [];
        let currentTitle = '';
        let currentTexts = [];

        for (const p of paragraphs) {
            if (p.isHeading) {
                if (currentTexts.length > 0) {
                    chapters.push({
                        title: currentTitle || `章节 ${chapters.length + 1}`,
                        sentences: this._splitSentences(currentTexts.join('\n\n')),
                    });
                }
                currentTitle = p.text;
                currentTexts = [];
            } else {
                currentTexts.push(p.text);
            }
        }
        if (currentTexts.length > 0) {
            chapters.push({
                title: currentTitle || `章节 ${chapters.length + 1}`,
                sentences: this._splitSentences(currentTexts.join('\n\n')),
            });
        }

        // fallback
        if (chapters.length <= 1 && chapters[0]) {
            const fullText = paragraphs.map(p => p.text).join('\n');
            const reParsed = this.parse(fullText);
            if (reParsed.length > chapters.length) return reParsed;
        }

        return chapters.length > 0 ? chapters : [{ title: '全文', sentences: ['文档内容为空'] }];
    }

    /* ═══════════════════════════════════════
       TXT 解析 (原逻辑)
       ═══════════════════════════════════════ */
    parse(text) {
        const lines = text.split(/\r?\n/);
        const chapters = this._detectChapters(lines);

        if (chapters.length === 0) {
            const allText = text.trim();
            const sentences = this._splitSentences(allText);
            return [{ title: '全文', sentences }];
        }

        for (const ch of chapters) {
            const chText = lines.slice(ch._startLine, ch._endLine + 1).join('\n').trim();
            const bodyStart = chText.indexOf('\n');
            const body = bodyStart > 0 ? chText.slice(bodyStart).trim() : chText;
            ch.sentences = this._splitSentences(body);
            delete ch._startLine;
            delete ch._endLine;
        }

        return chapters.filter(ch => ch.sentences.length > 0);
    }

    _detectChapters(lines) {
        const chapters = [];
        let currentStart = -1;
        let currentTitle = '';

        for (let i = 0; i < lines.length; i++) {
            const line = lines[i].trim();
            if (!line) continue;

            let isChapter = false;
            for (const pattern of this.chapterPatterns) {
                if (pattern.test(line)) { isChapter = true; break; }
            }

            if (isChapter) {
                if (currentStart >= 0) {
                    chapters.push({ title: currentTitle, _startLine: currentStart, _endLine: i - 1 });
                }
                currentStart = i;
                currentTitle = line;
            }
        }

        if (currentStart >= 0) {
            chapters.push({ title: currentTitle, _startLine: currentStart, _endLine: lines.length - 1 });
        }

        return chapters;
    }

    /* ═══════════════════════════════════════
       智能分句 (通用)
       ═══════════════════════════════════════ */
    _splitSentences(text) {
        if (!text.trim()) return [];

        const paragraphs = text.split(/\n\s*\n/).filter(p => p.trim());
        const sentences = [];

        for (const para of paragraphs) {
            const cleaned = para.replace(/\s+/g, ' ').trim();
            if (!cleaned) continue;

            const abbrevs = '(?:Mr|Mrs|Ms|Dr|Prof|St|Jr|Sr|Inc|Ltd|Corp|vs|etc|al|eg|ie|cf)';
            const sentenceEnders = new RegExp(
                `(?<!${abbrevs})\\.(?=\\s+[A-Z"'"\\(])|[!?]+(?=\\s)|(?<=[。！？」』])`, 'g'
            );

            let lastIdx = 0;
            let match;
            const regex = new RegExp(sentenceEnders.source, 'g');

            while ((match = regex.exec(cleaned)) !== null) {
                const endIdx = match.index + match[0].length;
                const sent = cleaned.slice(lastIdx, endIdx).trim();
                if (sent.length > 0) sentences.push(sent);
                lastIdx = endIdx;
            }

            const remaining = cleaned.slice(lastIdx).trim();
            if (remaining.length > 0) {
                if (remaining.length > 300) {
                    const parts = remaining.split(/(?<=[.!?])\s+/);
                    for (const p of parts) { if (p.trim()) sentences.push(p.trim()); }
                } else {
                    sentences.push(remaining);
                }
            }
        }

        // 合并过短句
        const merged = [];
        for (let i = 0; i < sentences.length; i++) {
            const s = sentences[i];
            if (s.length < 10 && !s.startsWith('"') && !s.startsWith('\u201c') && merged.length > 0) {
                merged[merged.length - 1] += ' ' + s;
            } else {
                merged.push(s);
            }
        }

        return merged;
    }
}
